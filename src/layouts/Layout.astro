---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import AskAIModal from '../components/AskAIModal.astro';
import MobileBottomNav from '../components/MobileBottomNav.astro';
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
}

const { 
	title = "FileMitra - Premium Image & PDF Processing Tools", 
	description = "Compress, resize, and convert images, or merge, split, and extract PDFs client-side in seconds with absolute privacy." 
} = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		
		<!-- SEO Meta Tags -->
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta name="robots" content="index, follow" />
		
		<!-- Google Fonts for Inter and JetBrains Mono -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&family=JetBrains+Mono:ital,wght@0,100..800;1,100..800&display=swap" rel="stylesheet">
	</head>
	<body class="bg-canvas-soft text-ink font-sans min-h-screen flex flex-col antialiased selection:bg-primary selection:text-on-primary pb-16 md:pb-0">
		<Header />
		<main class="flex-grow flex flex-col">
			<slot />
		</main>
		<Footer />
		<AskAIModal />
		<MobileBottomNav />
	</body>
</html>
