---
---

<footer class="hidden md:block bg-canvas border-t border-hairline py-16 px-6 lg:px-8 mt-auto">
  <div class="max-w-[1200px] mx-auto grid grid-cols-2 md:grid-cols-4 gap-8">
    <!-- Col 1: Product -->
    <div>
      <h3 class="font-mono text-[11px] tracking-wider text-mute uppercase font-semibold mb-4 select-none">
        Product
      </h3>
      <ul class="flex flex-col gap-3">
        <li><a href="/#tools" class="text-body hover:text-ink text-sm transition-colors">Image Compress</a></li>
        <li><a href="/#tools" class="text-body hover:text-ink text-sm transition-colors">Image Resize</a></li>
        <li><a href="/#tools" class="text-body hover:text-ink text-sm transition-colors">Format Converter</a></li>
        <li><a href="/#tools" class="text-body hover:text-ink text-sm transition-colors">Image to PDF</a></li>
      </ul>
    </div>

    <!-- Col 2: Resources -->
    <div>
      <h3 class="font-mono text-[11px] tracking-wider text-mute uppercase font-semibold mb-4 select-none">
        Resources
      </h3>
      <ul class="flex flex-col gap-3">
        <li><a href="/#pricing" class="text-body hover:text-ink text-sm transition-colors">Pricing Plans</a></li>
        <li><a href="https://github.com" class="text-body hover:text-ink text-sm transition-colors">GitHub Repository</a></li>
        <li><a href="/docs" class="text-body hover:text-ink text-sm transition-colors">Developer API</a></li>
        <li><a href="/status" class="text-body hover:text-ink text-sm transition-colors">Service Status</a></li>
      </ul>
    </div>

    <!-- Col 3: Company -->
    <div>
      <h3 class="font-mono text-[11px] tracking-wider text-mute uppercase font-semibold mb-4 select-none">
        Company
      </h3>
      <ul class="flex flex-col gap-3">
        <li><a href="/about" class="text-body hover:text-ink text-sm transition-colors">About Us</a></li>
        <li><a href="/careers" class="text-body hover:text-ink text-sm transition-colors">Careers</a></li>
        <li><a href="/blog" class="text-body hover:text-ink text-sm transition-colors">Blog</a></li>
        <li><a href="/customers" class="text-body hover:text-ink text-sm transition-colors">Customers</a></li>
      </ul>
    </div>

    <!-- Col 4: Legal -->
    <div>
      <h3 class="font-mono text-[11px] tracking-wider text-mute uppercase font-semibold mb-4 select-none">
        Legal
      </h3>
      <ul class="flex flex-col gap-3">
        <li><a href="/privacy" class="text-body hover:text-ink text-sm transition-colors">Privacy Policy</a></li>
        <li><a href="/terms" class="text-body hover:text-ink text-sm transition-colors">Terms of Service</a></li>
        <li><a href="/security" class="text-body hover:text-ink text-sm transition-colors">Security</a></li>
        <li><a href="/gdpr" class="text-body hover:text-ink text-sm transition-colors">GDPR Compliance</a></li>
      </ul>
    </div>
  </div>

  <div class="max-w-[1200px] mx-auto border-t border-hairline mt-12 pt-8 flex flex-col sm:flex-row items-center justify-between gap-4">
    <div class="flex items-center gap-2.5">
      <!-- Monochrome brand logo -->
      <svg viewBox="0 0 100 100" class="w-5 h-5 opacity-60 grayscale transition-opacity hover:opacity-100" aria-hidden="true">
        <polygon points="20,35 50,15 50,85 20,65" fill="#a1a1a1" />
        <polygon points="80,35 50,15 50,85 80,65" fill="#888888" />
        <polygon points="50,15 80,35 50,55 20,35" fill="#ffffff" fill-opacity="0.2" />
      </svg>
      <p class="text-mute text-xs">
        &copy; {new Date().getFullYear()} imageMitra Inc. All rights reserved.
      </p>
    </div>
    <div class="flex items-center gap-4 text-xs text-mute">
      <span>Stark Canvas Style</span>
      <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse" title="All systems operational"></span>
      <span class="font-mono text-[10px]">v1.0.0-beta</span>
    </div>
  </div>
</footer>
