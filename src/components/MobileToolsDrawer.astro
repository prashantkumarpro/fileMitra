---
import { X, Image, FileText, Layers, Expand, RefreshCw, Compass, ArrowRight, Sparkles } from 'lucide-astro';

const imageTools = [
  { id: 'bg-remover', name: 'BG Remover & Passport Maker', desc: 'Remove backgrounds & create passport photos.', href: '/tools/bg-remover', icon: Sparkles },
  { id: 'image-compress', name: 'Compress Image', desc: 'Reduce JPG, PNG, WebP sizes.', href: '/tools/image-compress', icon: Layers },
  { id: 'image-resize', name: 'Resize Image', desc: 'Crop, scale, rotate & filter image properties.', href: '/tools/image-resize', icon: Expand },
  { id: 'image-convert', name: 'Convert Format', desc: 'Convert between PNG, JPG, WebP.', href: '/tools/image-convert', icon: RefreshCw },
  { id: 'image-to-pdf', name: 'Image to PDF', desc: 'Convert images to single PDF.', href: '/tools/image-to-pdf', icon: FileText },
];
---

<!-- Bottom Sheet Container (Hidden by default) -->
<div id="mobile-tools-drawer" class="fixed inset-0 z-50 hidden md:hidden" role="dialog" aria-modal="true">
  <!-- Backdrop Overlay -->
  <div id="drawer-backdrop" class="absolute inset-0 bg-primary/40 backdrop-blur-xs opacity-0 transition-opacity duration-300"></div>

  <!-- Sheet content slides up from bottom -->
  <div 
    id="drawer-sheet" 
    class="absolute bottom-0 left-0 right-0 bg-canvas border-t border-hairline rounded-t-xl max-h-[85vh] overflow-y-auto flex flex-col translate-y-full transition-transform duration-300 shadow-level-5 pb-safe"
  >
    <!-- Header Handle (Drag representation) -->
    <div class="w-full flex justify-center py-3 select-none cursor-pointer" id="drawer-handle">
      <div class="w-10 h-1 bg-hairline-strong/60 rounded-full"></div>
    </div>

    <!-- Title and Close -->
    <div class="flex items-center justify-between px-6 pb-4 border-b border-hairline">
      <div class="flex items-center gap-2">
        <span class="p-1 bg-violet-soft/20 text-violet rounded-sm border border-violet-soft">
          <Compass class="w-4 h-4" />
        </span>
        <h2 class="text-sm font-semibold text-ink font-sans">Explore Utilities</h2>
      </div>
      <button id="drawer-close-btn" class="p-1 text-mute hover:text-ink hover:bg-canvas-soft-2 rounded-sm transition-colors" aria-label="Close drawer">
        <X class="w-4 h-4" />
      </button>
    </div>

    <!-- Scrollable content area -->
    <div class="flex flex-col gap-6 p-6">
      
      <!-- Image Tools Category -->
      <div class="flex flex-col gap-2">
        <span class="font-mono text-[10px] text-mute uppercase font-semibold tracking-wider select-none flex items-center gap-1.5 px-1">
          <Image class="w-3.5 h-3.5" />
          Image Processing
        </span>
        <div class="grid grid-cols-1 gap-2">
          {imageTools.map(tool => {
            const Icon = tool.icon;
            return (
              <a 
                href={tool.href}
                class="drawer-link flex items-center justify-between p-3.5 bg-canvas-soft-2 hover:bg-canvas border border-hairline rounded-md transition-all duration-200 active:scale-[0.98]"
              >
                <div class="flex items-center gap-3 min-w-0 pr-4">
                  <span class="p-2 bg-canvas border border-hairline text-ink rounded-sm">
                    <Icon class="w-4 h-4" />
                  </span>
                  <div class="flex flex-col min-w-0">
                    <span class="text-xs font-semibold text-ink">{tool.name}</span>
                    <span class="text-[10px] text-mute truncate mt-0.5">{tool.desc}</span>
                  </div>
                </div>
                <ArrowRight class="w-4 h-4 text-mute" />
              </a>
            );
          })}
        </div>
      </div>

    </div>
  </div>
</div>

<script>
  const drawer = document.getElementById('mobile-tools-drawer');
  const backdrop = document.getElementById('drawer-backdrop');
  const sheet = document.getElementById('drawer-sheet');
  const closeBtn = document.getElementById('drawer-close-btn');
  const links = document.querySelectorAll('.drawer-link');
  const handle = document.getElementById('drawer-handle');

  function openDrawer() {
    if (!drawer || !backdrop || !sheet) return;
    
    drawer.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
    
    // Trigger transition Reflow
    void drawer.offsetWidth;
    
    backdrop.classList.remove('opacity-0');
    backdrop.classList.add('opacity-100');
    
    sheet.classList.remove('translate-y-full');
    sheet.classList.add('translate-y-0');
  }

  function closeDrawer() {
    if (!drawer || !backdrop || !sheet) return;
    
    backdrop.classList.remove('opacity-100');
    backdrop.classList.add('opacity-0');
    
    sheet.classList.remove('translate-y-0');
    sheet.classList.add('translate-y-full');
    
    // Hide drawer block after transitions finish
    setTimeout(() => {
      drawer.classList.add('hidden');
      document.body.style.overflow = '';
    }, 300);
  }

  // Bind close buttons and links
  closeBtn?.addEventListener('click', closeDrawer);
  backdrop?.addEventListener('click', closeDrawer);
  handle?.addEventListener('click', closeDrawer);
  
  links.forEach(link => {
    link.addEventListener('click', closeDrawer);
  });

  // Global listener for opening drawer
  window.addEventListener('open-tools-drawer', () => {
    openDrawer();
  });
</script>
