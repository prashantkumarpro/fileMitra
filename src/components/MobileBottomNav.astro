---
import { Home, Sparkles, User, Compass } from 'lucide-astro';
---

<nav class="md:hidden fixed bottom-0 left-0 right-0 z-40 bg-canvas/90 backdrop-blur-md border-t border-hairline h-14 flex items-center justify-around px-6 shadow-level-5 select-none pb-safe">
  
  <!-- Tab 1: Home Dashboard -->
  <a href="/" class="flex flex-col items-center justify-center gap-1 text-body hover:text-ink active:scale-95 transition-all flex-1 py-1">
    <Home class="w-4.5 h-4.5" />
    <span class="text-[9px] font-sans font-medium">Home</span>
  </a>

  <!-- Tab 2: Tools (Drawer trigger) -->
  <button id="mobile-bottom-explore-tools" class="flex flex-col items-center justify-center gap-1 text-body hover:text-ink active:scale-95 transition-all flex-1 py-1 cursor-pointer outline-none">
    <Compass class="w-4.5 h-4.5" />
    <span class="text-[9px] font-sans font-medium">Tools</span>
  </button>

  <!-- Tab 3: Ask AI (Stateful shortcut) -->
  <button id="mobile-bottom-ask-ai" class="flex flex-col items-center justify-center gap-1 text-body hover:text-ink active:scale-95 transition-all flex-1 py-1 cursor-pointer outline-none">
    <Sparkles class="w-4.5 h-4.5 text-violet animate-pulse" />
    <span class="text-[9px] font-sans font-medium text-violet-deep">Ask AI</span>
  </button>

  <!-- Tab 4: Account Profile -->
  <a href="/auth" id="mobile-bottom-auth" class="flex flex-col items-center justify-center gap-1 text-body hover:text-ink active:scale-95 transition-all flex-1 py-1">
    <div id="mobile-bottom-avatar-container" class="relative w-5 h-5 flex items-center justify-center">
      <User id="mobile-bottom-user-icon" class="w-4.5 h-4.5" />
      <span id="mobile-bottom-user-char" class="hidden text-[8px] font-bold bg-primary text-on-primary rounded-full w-4.5 h-4.5 items-center justify-center animate-in zoom-in-50 duration-150">U</span>
    </div>
    <span id="mobile-bottom-account-label" class="text-[9px] font-sans font-medium">Account</span>
  </a>

</nav>

<script>
  function checkBottomNavAuth() {
    const userStr = localStorage.getItem('imagemitra_user');
    const userIcon = document.getElementById('mobile-bottom-user-icon');
    const userChar = document.getElementById('mobile-bottom-user-char');
    const accountLabel = document.getElementById('mobile-bottom-account-label');
    const accountLink = document.getElementById('mobile-bottom-auth') as HTMLAnchorElement;

    if (userStr) {
      try {
        const user = JSON.parse(userStr);
        const email = user.email || 'user@example.com';
        const char = email.substring(0, 1).toUpperCase();

        if (userIcon) userIcon.classList.add('hidden');
        if (userChar) {
          userChar.innerText = char;
          userChar.classList.remove('hidden');
          userChar.classList.add('flex');
        }
        if (accountLabel) accountLabel.innerText = 'Profile';
        if (accountLink) {
          accountLink.href = '/auth';
        }
      } catch (err) {
        console.error(err);
      }
    }
  }

  checkBottomNavAuth();

  // Bind Tools trigger click to dispatch global open event
  document.getElementById('mobile-bottom-explore-tools')?.addEventListener('click', (e) => {
    e.preventDefault();
    window.dispatchEvent(new CustomEvent('open-tools-drawer'));
  });

  // Bind AI trigger click to global listener
  document.getElementById('mobile-bottom-ask-ai')?.addEventListener('click', (e) => {
    e.preventDefault();
    const trigger = document.getElementById('mobile-ask-ai-trigger');
    if (trigger) {
      trigger.click();
    } else {
      const desktopTrigger = document.getElementById('ask-ai-trigger');
      desktopTrigger?.click();
    }
  });
</script>
