---
import { Sparkles, X, Upload, Check, RefreshCw, FileText, ArrowRight, Download, Mic, MicOff, Volume2, VolumeX, Layers, Expand, Search, Settings } from 'lucide-astro';
---

<!-- Modal Backdrop -->
<div id="ask-ai-modal" class="fixed inset-0 z-50 bg-primary/20 backdrop-blur-sm hidden items-center justify-center p-4" aria-modal="true" role="dialog">
  
  <!-- Modal Card (ex-modal-card style) -->
  <div class="relative z-10 w-full max-w-lg bg-canvas border border-hairline rounded-lg p-6 md:p-8 shadow-level-5 flex flex-col gap-5 animate-in fade-in zoom-in-95 duration-200">
    
    <!-- Modal Close Button -->
    <button id="modal-close-btn" class="absolute top-4 right-4 p-1 text-mute hover:text-ink rounded-sm hover:bg-canvas-soft transition-colors" aria-label="Close modal">
      <X class="w-4 h-4" />
    </button>

    <!-- Header Title -->
    <div class="flex items-center gap-2 select-none">
      <span class="p-1.5 bg-violet-soft/30 rounded-sm text-violet border border-violet-soft">
        <Sparkles class="w-5 h-5 text-violet animate-pulse" />
      </span>
      <div class="flex flex-col">
        <h2 class="font-sans font-semibold text-sm text-ink leading-tight">Ask FileMitra AI</h2>
        <span class="font-mono text-[9px] text-mute uppercase">On-device client processing agent</span>
      </div>
    </div>

    <!-- Main Workspace Section -->
    <div id="ai-input-stage" class="flex flex-col gap-4">
      
      <!-- Prompt input box -->
      <div class="flex flex-col gap-1.5">
        <div class="flex items-center justify-between select-none">
          <label for="ai-prompt" class="font-sans font-medium text-xs text-ink select-none font-sans">What should we do?</label>
          
          <!-- Speech / Voice Control Toolbar -->
          <div class="flex items-center gap-1.5">
            <!-- Listening Button -->
            <button id="voice-listen-btn" type="button" class="flex items-center justify-center w-6 h-6 rounded-full border border-hairline hover:border-hairline-strong bg-canvas text-body hover:text-ink transition-all active:scale-90 cursor-pointer shadow-level-1" title="Speak instruction">
              <Mic id="icon-mic-on" class="w-3.5 h-3.5 text-mute" />
              <MicOff id="icon-mic-off" class="w-3.5 h-3.5 text-error hidden animate-pulse" />
            </button>
            
            <!-- Speaking Feedback Toggle -->
            <button id="voice-speak-btn" type="button" class="flex items-center justify-center w-6 h-6 rounded-full border border-hairline hover:border-hairline-strong bg-canvas text-body hover:text-ink transition-all active:scale-90 cursor-pointer shadow-level-1" title="Toggle voice feedback">
              <Volume2 id="icon-vol-on" class="w-3.5 h-3.5 text-violet" />
              <VolumeX id="icon-vol-off" class="w-3.5 h-3.5 text-mute hidden" />
            </button>
          </div>
        </div>

        <textarea
          id="ai-prompt"
          placeholder="Ask AI to process your files (e.g., 'Compress this image to 50%', 'Convert this PNG to WebP')"
          class="w-full bg-canvas text-ink border border-hairline focus:border-hairline-strong text-xs rounded-sm p-3 min-h-[90px] outline-none resize-none transition-all placeholder:text-mute shadow-level-1 font-sans"
        ></textarea>
      </div>

      <!-- Visual Voice Status Toast/Banner -->
      <div id="voice-status-banner" class="hidden items-center gap-2 bg-violet-soft/20 text-violet border border-violet-soft/30 px-3 py-2.5 rounded-sm text-[11px] font-medium select-none shadow-level-2 animate-in fade-in slide-in-from-top-2 duration-200">
        <div class="relative w-2 h-2 flex items-center justify-center">
          <span class="absolute w-2 h-2 bg-violet rounded-full animate-ping"></span>
          <span class="relative w-1.5 h-1.5 bg-violet rounded-full"></span>
        </div>
        <span id="voice-status-text">AI is listening... Speak your command</span>
      </div>

      <!-- Compact File Attachment Dropzone -->
      <div id="ai-dropzone" class="border border-dashed border-hairline hover:border-hairline-strong bg-canvas-soft rounded-sm p-4 flex flex-col items-center justify-center text-center cursor-pointer transition-all select-none">
        <input type="file" id="ai-file-input" accept="image/png, image/jpeg, image/webp, application/pdf" multiple class="hidden" />
        <Upload class="w-4 h-4 text-mute mb-1" />
        <span class="text-[11px] font-semibold text-ink">Attach a file to process</span>
        <span class="text-[9px] text-mute">PNG, JPEG, WebP, or PDF</span>
      </div>

      <!-- Attached File Display Card (Hidden by default) -->
      <div id="ai-attached-file" class="hidden items-center justify-between border border-hairline bg-canvas-soft rounded-sm p-3 shadow-level-1">
        <div class="flex items-center gap-2.5 min-w-0 pr-4">
          <span class="p-1.5 bg-canvas border border-hairline rounded-sm text-ink flex-shrink-0">
            <FileText class="w-4 h-4" />
          </span>
          <div class="flex flex-col min-w-0">
            <span id="attached-name" class="text-xs font-semibold text-ink truncate">image.png</span>
            <span id="attached-size" class="font-mono text-[9px] text-mute mt-0.5">0 KB</span>
          </div>
        </div>
        <button id="remove-attached-btn" class="p-1 text-mute hover:text-error rounded-sm hover:bg-error-soft transition-colors">
          <X class="w-3.5 h-3.5" />
        </button>
      </div>

      <!-- Suggested prompts layout list -->
      <div class="flex flex-col gap-2.5 select-none">
        <div class="flex items-center justify-between px-1">
          <span class="font-mono text-[9px] text-mute uppercase font-semibold tracking-wider">Suggested Voice Commands</span>
          <span class="text-[8.5px] text-violet font-semibold animate-pulse">💡 Click to try one</span>
        </div>
        <div class="flex flex-col gap-2">
          
          <button class="ai-suggestion-chip flex items-center justify-between p-2.5 bg-canvas-soft hover:bg-canvas border border-hairline hover:border-hairline-strong rounded-md transition-all text-left group cursor-pointer active:scale-[0.99] shadow-level-1 w-full">
            <div class="flex items-center gap-3">
              <span class="p-1.5 bg-amber-500/10 text-amber-600 rounded-sm">
                <Layers class="w-4 h-4" />
              </span>
              <div class="flex flex-col">
                <span class="text-xs font-semibold text-ink">Compress Image</span>
                <span class="text-[10px] text-body mt-0.5">Reduce file size on local engine</span>
              </div>
            </div>
            <div class="flex items-center gap-2">
              <span class="text-[10.5px] font-mono text-mute italic bg-canvas-soft-2 px-2.5 py-1 rounded-sm border border-hairline group-hover:text-violet group-hover:border-violet-soft/30 transition-colors">"Compress to 50%"</span>
            </div>
            <span class="hidden">Compress this image by 50%</span>
          </button>

          <button class="ai-suggestion-chip flex items-center justify-between p-2.5 bg-canvas-soft hover:bg-canvas border border-hairline hover:border-hairline-strong rounded-md transition-all text-left group cursor-pointer active:scale-[0.99] shadow-level-1 w-full">
            <div class="flex items-center gap-3">
              <span class="p-1.5 bg-purple-500/10 text-purple-600 rounded-sm">
                <RefreshCw class="w-4 h-4" />
              </span>
              <div class="flex flex-col">
                <span class="text-xs font-semibold text-ink">Convert Format</span>
                <span class="text-[10px] text-body mt-0.5">Save as optimized web format</span>
              </div>
            </div>
            <div class="flex items-center gap-2">
              <span class="text-[10.5px] font-mono text-mute italic bg-canvas-soft-2 px-2.5 py-1 rounded-sm border border-hairline group-hover:text-violet group-hover:border-violet-soft/30 transition-colors">"Convert to WebP"</span>
            </div>
            <span class="hidden">Convert this image to WebP format</span>
          </button>

          <button class="ai-suggestion-chip flex items-center justify-between p-2.5 bg-canvas-soft hover:bg-canvas border border-hairline hover:border-hairline-strong rounded-md transition-all text-left group cursor-pointer active:scale-[0.99] shadow-level-1 w-full">
            <div class="flex items-center gap-3">
              <span class="p-1.5 bg-blue-500/10 text-blue-600 rounded-sm">
                <Expand class="w-4 h-4" />
              </span>
              <div class="flex flex-col">
                <span class="text-xs font-semibold text-ink">Resize Image</span>
                <span class="text-[10px] text-body mt-0.5">Scale to custom dimensions</span>
              </div>
            </div>
            <div class="flex items-center gap-2">
              <span class="text-[10.5px] font-mono text-mute italic bg-canvas-soft-2 px-2.5 py-1 rounded-sm border border-hairline group-hover:text-violet group-hover:border-violet-soft/30 transition-colors">"Resize width to 800px"</span>
            </div>
            <span class="hidden">Resize image width to 800px</span>
          </button>

          <button class="ai-suggestion-chip flex items-center justify-between p-2.5 bg-canvas-soft hover:bg-canvas border border-hairline hover:border-hairline-strong rounded-md transition-all text-left group cursor-pointer active:scale-[0.99] shadow-level-1 w-full">
            <div class="flex items-center gap-3">
              <span class="p-1.5 bg-pink-500/10 text-pink-600 rounded-sm">
                <Sparkles class="w-4 h-4" />
              </span>
              <div class="flex flex-col">
                <span class="text-xs font-semibold text-ink">Remove Background</span>
                <span class="text-[10px] text-body mt-0.5">Erase backgrounds automatically</span>
              </div>
            </div>
            <div class="flex items-center gap-2">
              <span class="text-[10.5px] font-mono text-mute italic bg-canvas-soft-2 px-2.5 py-1 rounded-sm border border-hairline group-hover:text-violet group-hover:border-violet-soft/30 transition-colors">"Remove background"</span>
            </div>
            <span class="hidden">Remove background from this image</span>
          </button>

        </div>
      </div>

      <!-- Action Button -->
      <button id="ai-submit-btn" class="bg-primary text-on-primary hover:bg-primary/95 text-xs font-semibold h-10 rounded-pill flex items-center justify-center gap-1.5 transition-all shadow-level-3 mt-1 select-none">
        <Sparkles class="w-4 h-4 text-cyan" />
        Execute AI Command
      </button>

    </div>

    <!-- Processing Stage (Hidden by default) -->
    <div id="ai-processing-stage" class="hidden flex-col gap-6 py-6 items-center text-center">
      <span class="animate-spin text-violet"><RefreshCw class="w-8 h-8" /></span>
      <div class="flex flex-col gap-1.5">
        <h3 id="processing-status" class="font-sans font-semibold text-sm text-ink">Analyzing instructions...</h3>
        <p id="processing-details" class="text-mute text-xs font-mono">Initializing processing canvas...</p>
      </div>
      
      <!-- Graphical Step progress indicators (Horizontal) -->
      <div class="w-full border-t border-hairline pt-5 flex items-center justify-around select-none">
        
        <!-- Step 1: Parse -->
        <div id="step-1" class="flex flex-col items-center gap-1.5 text-mute opacity-50 transition-all duration-300">
          <div class="w-8 h-8 rounded-full border border-hairline flex items-center justify-center bg-canvas shadow-level-1 text-ink" id="step-1-dot">
            <Search class="w-3.5 h-3.5" />
          </div>
          <span class="text-[9px] font-bold font-sans">Parse</span>
        </div>

        <div class="h-px flex-1 bg-hairline max-w-[24px] mb-4"></div>

        <!-- Step 2: Load -->
        <div id="step-2" class="flex flex-col items-center gap-1.5 text-mute opacity-50 transition-all duration-300">
          <div class="w-8 h-8 rounded-full border border-hairline flex items-center justify-center bg-canvas shadow-level-1 text-ink" id="step-2-dot">
            <Upload class="w-3.5 h-3.5" />
          </div>
          <span class="text-[9px] font-bold font-sans">Load</span>
        </div>

        <div class="h-px flex-1 bg-hairline max-w-[24px] mb-4"></div>

        <!-- Step 3: Run -->
        <div id="step-3" class="flex flex-col items-center gap-1.5 text-mute opacity-50 transition-all duration-300">
          <div class="w-8 h-8 rounded-full border border-hairline flex items-center justify-center bg-canvas shadow-level-1 text-ink" id="step-3-dot">
            <Settings class="w-3.5 h-3.5" />
          </div>
          <span class="text-[9px] font-bold font-sans">Process</span>
        </div>

        <div class="h-px flex-1 bg-hairline max-w-[24px] mb-4"></div>

        <!-- Step 4: Compile -->
        <div id="step-4" class="flex flex-col items-center gap-1.5 text-mute opacity-50 transition-all duration-300">
          <div class="w-8 h-8 rounded-full border border-hairline flex items-center justify-center bg-canvas shadow-level-1 text-ink" id="step-4-dot">
            <FileText class="w-3.5 h-3.5" />
          </div>
          <span class="text-[9px] font-bold font-sans">Compile</span>
        </div>

      </div>
    </div>

    <!-- Output Download Stage (Hidden by default) -->
    <div id="ai-output-stage" class="hidden flex-col gap-4 text-center">
      
      <!-- Compact success banner -->
      <div class="flex items-center gap-2.5 p-3 bg-emerald-50 border border-emerald-200 rounded-sm text-left select-none">
        <span class="p-1.5 bg-emerald-500 text-on-primary rounded-full flex-shrink-0">
          <Check class="w-3.5 h-3.5" />
        </span>
        <div class="flex flex-col">
          <h3 class="font-sans font-bold text-xs text-ink">File Processed Successfully!</h3>
          <p class="text-[10px] text-body">Executed client-side browser pipeline.</p>
        </div>
      </div>

      <!-- Visual Preview Area of Output -->
      <div class="border border-hairline bg-canvas-soft-2 rounded-md p-3 flex flex-col items-center justify-center min-h-[160px] relative select-none">
        
        <!-- Image Preview Frame (Rendered if image) -->
        <div id="ai-output-image-preview-container" class="hidden w-full h-full max-h-[180px] items-center justify-center">
          <img id="ai-output-image-preview" src="" class="max-h-[180px] max-w-full object-contain rounded-sm border border-hairline bg-white shadow-level-2 pointer-events-none select-none" />
        </div>

        <!-- Document Preview Frame (Rendered if PDF) -->
        <div id="ai-output-pdf-preview-container" class="hidden flex-col items-center gap-2 text-rose-500">
          <svg viewBox="0 0 24 24" class="w-12 h-12 fill-rose-500/10 stroke-rose-500" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
            <polyline points="14 2 14 8 20 8"></polyline>
            <line x1="16" y1="13" x2="8" y2="13"></line>
            <line x1="16" y1="17" x2="8" y2="17"></line>
          </svg>
          <span class="font-mono text-[9px] text-mute uppercase font-semibold">PDF Document</span>
        </div>

      </div>

      <!-- Compact diagnostic details -->
      <div class="bg-canvas-soft border border-hairline rounded-sm p-3.5 flex flex-col gap-2 text-left text-xs text-body select-none">
        <div class="flex justify-between">
          <span class="text-mute">Output Name:</span>
          <span id="output-name" class="font-mono text-ink max-w-[220px] truncate font-semibold">image-compressed.webp</span>
        </div>
        <div class="flex justify-between">
          <span class="text-mute">Command:</span>
          <span id="output-command" class="font-mono text-ink italic truncate max-w-[220px]">"Compress to balanced quality"</span>
        </div>
      </div>

      <div class="flex flex-col gap-2">
        <button id="ai-download-btn" class="bg-primary text-on-primary hover:bg-primary/95 text-xs font-semibold h-10 rounded-pill flex items-center justify-center gap-1.5 transition-all shadow-level-3 cursor-pointer">
          <Download class="w-4 h-4" />
          Download AI Result
        </button>
        <button id="ai-again-btn" class="bg-canvas border border-hairline hover:bg-canvas-soft text-ink text-xs font-semibold h-10 rounded-pill flex items-center justify-center gap-1.5 transition-all shadow-level-1 cursor-pointer">
          <RefreshCw class="w-3.5 h-3.5" />
          Process Another File
        </button>
      </div>
    </div>

  </div>
</div>

<script>
  import { PDFDocument } from 'pdf-lib';
  import { addProcessedFile } from '../utils/db.js';

  // Elements
  const modal = document.getElementById('ask-ai-modal');
  const closeBtn = document.getElementById('modal-close-btn');
  
  // Voice Controls Elements
  const voiceListenBtn = document.getElementById('voice-listen-btn');
  const iconMicOn = document.getElementById('icon-mic-on');
  const iconMicOff = document.getElementById('icon-mic-off');
  
  const voiceSpeakBtn = document.getElementById('voice-speak-btn');
  const iconVolOn = document.getElementById('icon-vol-on');
  const iconVolOff = document.getElementById('icon-vol-off');
  
  const voiceStatusBanner = document.getElementById('voice-status-banner');
  const voiceStatusText = document.getElementById('voice-status-text');
  
  const inputStage = document.getElementById('ai-input-stage');
  const processingStage = document.getElementById('ai-processing-stage');
  const outputStage = document.getElementById('ai-output-stage');
  
  const promptInput = document.getElementById('ai-prompt') as HTMLTextAreaElement;
  const dropzone = document.getElementById('ai-dropzone');
  const fileInput = document.getElementById('ai-file-input') as HTMLInputElement;
  
  const attachedFileCard = document.getElementById('ai-attached-file');
  const attachedNameText = document.getElementById('attached-name');
  const attachedSizeText = document.getElementById('attached-size');
  const removeAttachedBtn = document.getElementById('remove-attached-btn');
  
  const suggestionChips = document.querySelectorAll('.ai-suggestion-chip');
  const submitBtn = document.getElementById('ai-submit-btn');
  
  const processingStatus = document.getElementById('processing-status');
  const processingDetails = document.getElementById('processing-details');
  
  const step1 = document.getElementById('step-1');
  const step2 = document.getElementById('step-2');
  const step3 = document.getElementById('step-3');
  const step4 = document.getElementById('step-4');
  
  const outputNameText = document.getElementById('output-name');
  const outputCommandText = document.getElementById('output-command');
  const downloadBtn = document.getElementById('ai-download-btn');
  const againBtn = document.getElementById('ai-again-btn');

  let activeFiles: File[] = [];
  let sourceImages: { name: string; img: HTMLImageElement }[] = [];
  let resultUrl = '';
  let resultBlob: Blob | null = null;
  let resultName = '';

  // Trigger modal display from anywhere in the document
  window.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    // Check if the click target is a trigger for Ask AI
    const isTrigger = target.closest('#ask-ai-trigger') || target.closest('#mobile-ask-ai-trigger');
    
    if (isTrigger) {
      e.preventDefault();
      
      // Accessing the feature requires user to be logged in!
      const userStr = localStorage.getItem('filemitra_user');
      if (!userStr) {
        window.location.href = '/auth?tab=login';
      } else {
        openModal();
      }
    }
  });

  // Speech Synthesis & Recognition States
  let voiceFeedbackEnabled = localStorage.getItem('voice_feedback') !== 'disabled';
  let isListening = false;
  // @ts-ignore
  const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
  let recognition: any = null;
  let voices: SpeechSynthesisVoice[] = [];

  // Initialize Speech Button States
  if (!voiceFeedbackEnabled) {
    iconVolOn?.classList.add('hidden');
    iconVolOff?.classList.remove('hidden');
  }

  // Load human-sounding voices from API registry
  function loadVoices() {
    voices = window.speechSynthesis.getVoices();
  }
  loadVoices();
  if (window.speechSynthesis.onvoiceschanged !== undefined) {
    window.speechSynthesis.onvoiceschanged = loadVoices;
  }

  function speak(text: string) {
    if (!voiceFeedbackEnabled) return;
    window.speechSynthesis.cancel(); // stop current speech
    const utterance = new SpeechSynthesisUtterance(text);
    
    // Refresh voices list in case they loaded dynamically after initial boot
    const currentVoices = window.speechSynthesis.getVoices();
    
    // Attempt to locate high-fidelity human English voice
    let selectedVoice = currentVoices.find(v => v.lang.startsWith('en') && (
      v.name.includes('Natural') || 
      v.name.includes('Google') || 
      v.name.includes('Microsoft') || 
      v.name.includes('Premium') ||
      v.name.includes('Samantha') ||
      v.name.includes('Daniel')
    ));
    
    if (!selectedVoice) {
      selectedVoice = currentVoices.find(v => v.lang.startsWith('en'));
    }
    
    if (selectedVoice) {
      utterance.voice = selectedVoice;
    }

    utterance.rate = 0.95; // Slightly slower, much more natural and human-like
    utterance.pitch = 1.0;  // Standard natural pitch
    window.speechSynthesis.speak(utterance);
  }

  // Toggle Voice Feedback Speaker
  voiceSpeakBtn?.addEventListener('click', () => {
    voiceFeedbackEnabled = !voiceFeedbackEnabled;
    if (voiceFeedbackEnabled) {
      localStorage.setItem('voice_feedback', 'enabled');
      iconVolOn?.classList.remove('hidden');
      iconVolOff?.classList.add('hidden');
      speak("Voice feedback enabled.");
    } else {
      localStorage.setItem('voice_feedback', 'disabled');
      iconVolOn?.classList.add('hidden');
      iconVolOff?.classList.remove('hidden');
      window.speechSynthesis.cancel();
    }
  });

  // Speech Recognition setups
  if (SpeechRecognition) {
    recognition = new SpeechRecognition();
    recognition.continuous = false;
    recognition.lang = 'en-US';
    recognition.interimResults = false;
    recognition.maxAlternatives = 1;

    recognition.onstart = () => {
      isListening = true;
      iconMicOn?.classList.add('hidden');
      iconMicOff?.classList.remove('hidden');
      
      if (voiceStatusBanner) {
        voiceStatusBanner.classList.remove('hidden');
        voiceStatusBanner.classList.add('flex');
      }
      if (voiceStatusText) {
        voiceStatusText.innerText = "AI is listening... Speak your command now.";
      }
      speak("Listening for commands...");
    };

    recognition.onresult = (event: any) => {
      const transcript = event.results[0][0].transcript;
      if (promptInput) {
        promptInput.value = transcript;
      }
      
      if (voiceStatusText) {
        voiceStatusText.innerText = `Recognized: "${transcript}"`;
      }
      speak(`Received command: ${transcript}`);

      // Check for automatic execution triggers
      const lower = transcript.toLowerCase();
      if (lower.includes('execute') || lower.includes('run') || lower.includes('do it') || lower.includes('process')) {
        if (voiceStatusText) {
          voiceStatusText.innerText = `Executing command: "${transcript}"...`;
        }
        speak("Executing command now.");
        setTimeout(() => {
          submitBtn?.click();
        }, 1000);
      }
    };

    recognition.onerror = (event: any) => {
      console.error(event.error);
      iconMicOn?.classList.remove('hidden');
      iconMicOff?.classList.add('hidden');
      isListening = false;
      
      if (voiceStatusText) {
        if (event.error === 'not-allowed') {
          voiceStatusText.innerText = "Error: Microphone access denied.";
          speak("Microphone access denied.");
        } else {
          voiceStatusText.innerText = `Error: Speech recognition failed (${event.error}).`;
          speak("Speech recognition failed.");
        }
      }

      setTimeout(() => {
        voiceStatusBanner?.classList.add('hidden');
        voiceStatusBanner?.classList.remove('flex');
      }, 3000);
    };

    recognition.onend = () => {
      isListening = false;
      iconMicOn?.classList.remove('hidden');
      iconMicOff?.classList.add('hidden');
      
      const prompt = (promptInput?.value || '').toLowerCase();
      const willExecute = prompt.includes('execute') || prompt.includes('run') || prompt.includes('do it') || prompt.includes('process');
      if (!willExecute) {
        setTimeout(() => {
          if (!isListening) {
            voiceStatusBanner?.classList.add('hidden');
            voiceStatusBanner?.classList.remove('flex');
          }
        }, 2500);
      }
    };

    voiceListenBtn?.addEventListener('click', () => {
      if (isListening) {
        recognition.stop();
      } else {
        recognition.start();
      }
    });
  } else {
    if (voiceListenBtn) voiceListenBtn.style.display = 'none';
  }

  function openModal() {
    if (!modal) return;
    modal.classList.remove('hidden');
    modal.classList.add('flex');
    document.body.style.overflow = 'hidden';
    
    // Reset view
    inputStage?.classList.remove('hidden');
    processingStage?.classList.add('hidden');
    outputStage?.classList.add('hidden');
    resetAttachedFile();

    // Welcome speech
    speak("Hi there! I'm FileMitra AI. Please attach a file and type or speak your command.");
  }

  function closeModal() {
    if (!modal) return;
    modal.classList.add('hidden');
    modal.classList.remove('flex');
    document.body.style.overflow = '';
  }

  closeBtn?.addEventListener('click', closeModal);
  modal?.addEventListener('click', (e) => {
    if (e.target === modal) closeModal();
  });

  // Chip populate prompt
  suggestionChips.forEach(chip => {
    chip.addEventListener('click', (e) => {
      const target = e.currentTarget as HTMLElement;
      const hiddenSpan = target.querySelector('.hidden');
      const text = hiddenSpan ? hiddenSpan.textContent || '' : target.innerText;
      if (promptInput) {
        promptInput.value = text.trim();
      }
    });
  });

  // Dropzone handling
  dropzone?.addEventListener('click', () => fileInput.click());
  dropzone?.addEventListener('dragover', (e) => {
    e.preventDefault();
    dropzone.classList.add('border-primary', 'bg-canvas-soft-2');
  });
  dropzone?.addEventListener('dragleave', () => {
    dropzone.classList.remove('border-primary', 'bg-canvas-soft-2');
  });
  dropzone?.addEventListener('drop', (e) => {
    e.preventDefault();
    dropzone.classList.remove('border-primary', 'bg-canvas-soft-2');
    if (e.dataTransfer?.files && e.dataTransfer.files.length > 0) {
      attachFiles(e.dataTransfer.files);
    }
  });
  fileInput?.addEventListener('change', () => {
    if (fileInput.files && fileInput.files.length > 0) {
      attachFiles(fileInput.files);
    }
  });

  function attachFiles(files: FileList | File[]) {
    const list = Array.from(files);
    if (list.length === 0) return;

    activeFiles = [...activeFiles, ...list];
    dropzone?.classList.add('hidden');
    attachedFileCard?.classList.remove('hidden');
    attachedFileCard?.classList.add('flex');
    
    const totalSize = activeFiles.reduce((acc, f) => acc + f.size, 0);

    if (attachedNameText) {
      if (activeFiles.length === 1) {
        attachedNameText.innerText = activeFiles[0].name;
      } else {
        attachedNameText.innerText = `${activeFiles.length} files attached`;
      }
    }
    
    if (attachedSizeText) {
      if (activeFiles.length === 1) {
        attachedSizeText.innerText = formatBytes(activeFiles[0].size);
      } else {
        const names = activeFiles.map(f => f.name).join(', ');
        attachedSizeText.innerText = `${formatBytes(totalSize)} (${names})`;
      }
    }

    activeFiles.forEach(file => {
      if (file.type.startsWith('image/')) {
        if (sourceImages.some(item => item.name === file.name)) return;
        const reader = new FileReader();
        reader.onload = (e) => {
          const img = new Image();
          img.onload = () => {
            sourceImages.push({ name: file.name, img });
          };
          img.src = e.target?.result as string;
        };
        reader.readAsDataURL(file);
      }
    });
  }

  function resetAttachedFile() {
    activeFiles = [];
    sourceImages = [];
    if (resultUrl) {
      URL.revokeObjectURL(resultUrl);
    }
    resultUrl = '';
    resultBlob = null;
    resultName = '';
    fileInput.value = '';
    
    dropzone?.classList.remove('hidden');
    attachedFileCard?.classList.add('hidden');
    attachedFileCard?.classList.remove('flex');
    
    if (promptInput) promptInput.value = '';
  }

  removeAttachedBtn?.addEventListener('click', resetAttachedFile);

  // Submit Prompt Execution handler
  submitBtn?.addEventListener('click', async () => {
    if (activeFiles.length === 0) {
      alert('Please attach a file first.');
      return;
    }
    
    const prompt = (promptInput?.value || '').trim().toLowerCase();
    if (!prompt) {
      alert('Please write an instruction prompt.');
      return;
    }

    // Go to Processing view
    inputStage?.classList.add('hidden');
    processingStage?.classList.remove('hidden');
    processingStage?.classList.add('flex');

    // Run Simulated steps
    await runSimulatedSteps(prompt);
  });

  function loadScript(src: string): Promise<void> {
    return new Promise((resolve, reject) => {
      if (document.querySelector(`script[src="${src}"]`)) {
        resolve();
        return;
      }
      const script = document.createElement('script');
      script.src = src;
      script.onload = () => resolve();
      script.onerror = () => reject(new Error(`Failed to load script ${src}`));
      document.head.appendChild(script);
    });
  }

  async function runSimulatedSteps(prompt: string) {
    if (activeFiles.length === 0) return;

    resetStepsUI();

    try {
      // Show voice status banner when executing
      if (voiceStatusBanner) {
        voiceStatusBanner.classList.remove('hidden');
        voiceStatusBanner.classList.add('flex');
      }

      // Step 1: Parse instructions
      setStepActive(step1, true);
      speak("Let's look at your command first.");
      if (voiceStatusText) voiceStatusText.innerText = "Let's look at your command first...";
      if (processingStatus) processingStatus.innerText = 'Analyzing instructions...';
      if (processingDetails) processingDetails.innerText = `Tokenizing prompt query: "${prompt}"`;
      
      // Parse targets - size in KB
      const targetSizeMatch = prompt.match(/(\d+)\s*(?:kb|kilobytes)/i);
      const targetKb = targetSizeMatch ? parseFloat(targetSizeMatch[1]) : 0;

      // Parse dimensions robustly
      const digits = prompt.match(/\d+/g);
      let targetWidth = 0;
      let targetHeight = 0;
      
      if (digits && digits.length >= 2 && prompt.includes('x')) {
        targetWidth = parseInt(digits[0]);
        targetHeight = parseInt(digits[1]);
      } else if (digits && digits.length === 1) {
        const val = parseInt(digits[0]);
        // Avoid matching percent values as dimensions
        if (!prompt.includes(val + '%') && !prompt.includes(val + ' %')) {
          if (prompt.includes('height') || prompt.includes('tall')) {
            targetHeight = val;
          } else {
            targetWidth = val;
          }
        }
      }

      let convertFormat = '';
      if (prompt.includes('webp')) convertFormat = 'image/webp';
      else if (prompt.includes('png')) convertFormat = 'image/png';
      else if (prompt.includes('jpg') || prompt.includes('jpeg')) convertFormat = 'image/jpeg';
      else if (prompt.includes('pdf')) convertFormat = 'application/pdf';

      await sleep(600);
      setStepDone(step1);

      // Step 2: Load buffer
      setStepActive(step2, true);
      speak("Now, loading your file into my memory.");
      if (voiceStatusText) voiceStatusText.innerText = "Now, loading your file into my memory...";
      if (processingStatus) processingStatus.innerText = 'Loading target buffer...';
      if (processingDetails) {
        if (activeFiles.length === 1) {
          processingDetails.innerText = `Reading file byte array of ${activeFiles[0].name}...`;
        } else {
          processingDetails.innerText = `Reading byte arrays of ${activeFiles.length} files...`;
        }
      }
      await sleep(600);
      setStepDone(step2);

      // Step 3: Run processing execution
      setStepActive(step3, true);
      speak("Alright, I'm working on the file details.");
      if (voiceStatusText) voiceStatusText.innerText = "Alright, I'm working on the file details...";
      if (processingStatus) processingStatus.innerText = 'Executing file operations...';
      if (processingDetails) processingDetails.innerText = 'Running client-side pipeline in memory...';

      // ─── PIPELINE SELECTION ───
      const cleanName = activeFiles[0].name.substring(0, activeFiles[0].name.lastIndexOf('.')) || activeFiles[0].name;

      // 1. Multiple Files Merge PDF
      if (activeFiles.length > 1 && activeFiles.every(f => f.type === 'application/pdf') && (prompt.includes('merge') || prompt.includes('combine') || prompt.includes('join') || prompt.includes('concat'))) {
        const mergedPdf = await PDFDocument.create();
        for (const file of activeFiles) {
          const arrayBuffer = await file.arrayBuffer();
          const doc = await PDFDocument.load(arrayBuffer);
          const copiedPages = await mergedPdf.copyPages(doc, doc.getPageIndices());
          copiedPages.forEach((page) => mergedPdf.addPage(page));
        }
        const mergedPdfBytes = await mergedPdf.save();
        resultBlob = new Blob([mergedPdfBytes], { type: 'application/pdf' });
        resultUrl = URL.createObjectURL(resultBlob);
        resultName = 'merged-document.pdf';
      }
      // 2. Multiple Files / Single file Image compiler to PDF
      else if ((activeFiles.length > 1 && activeFiles.every(f => f.type.startsWith('image/'))) || (activeFiles.length === 1 && activeFiles[0].type.startsWith('image/') && convertFormat === 'application/pdf')) {
        const pdfDoc = await PDFDocument.create();
        for (const file of activeFiles) {
          const arrayBuffer = await file.arrayBuffer();
          let pdfImage;
          if (file.type === 'image/png') {
            pdfImage = await pdfDoc.embedPng(arrayBuffer);
          } else if (file.type === 'image/jpeg' || file.type === 'image/jpg') {
            pdfImage = await pdfDoc.embedJpg(arrayBuffer);
          } else {
            // WebP fallback using Canvas to draw as PNG
            const imgItem = sourceImages.find(item => item.name === file.name);
            if (!imgItem) continue;
            const canvas = document.createElement('canvas');
            canvas.width = imgItem.img.width;
            canvas.height = imgItem.img.height;
            const ctx = canvas.getContext('2d');
            ctx?.drawImage(imgItem.img, 0, 0);
            const pngUrl = canvas.toDataURL('image/png');
            const res = await fetch(pngUrl);
            const pngBytes = await res.arrayBuffer();
            pdfImage = await pdfDoc.embedPng(pngBytes);
          }

          const page = pdfDoc.addPage([pdfImage.width, pdfImage.height]);
          page.drawImage(pdfImage, {
            x: 0,
            y: 0,
            width: pdfImage.width,
            height: pdfImage.height
          });
        }
        const pdfBytes = await pdfDoc.save();
        resultBlob = new Blob([pdfBytes], { type: 'application/pdf' });
        resultUrl = URL.createObjectURL(resultBlob);
        resultName = `${cleanName}-compiled.pdf`;
      }
      // 3. Single PDF split/extract range
      else if (activeFiles.length === 1 && activeFiles[0].type === 'application/pdf' && (prompt.includes('split') || prompt.includes('extract') || prompt.includes('page') || prompt.includes('range'))) {
        const arrayBuffer = await activeFiles[0].arrayBuffer();
        const sourceDoc = await PDFDocument.load(arrayBuffer);
        const maxPages = sourceDoc.getPageCount();

        const rangeMatch = prompt.match(/(?:pages?|extract|split|range)\s*([0-9\s,-]+)/i) || prompt.match(/\b([0-9\s,-]+)\b/);
        let pageRangeStr = '';
        if (rangeMatch) {
          pageRangeStr = rangeMatch[1] || rangeMatch[0];
        }

        let targets: number[] = [];
        if (pageRangeStr) {
          targets = parsePageRange(pageRangeStr, maxPages);
        }

        if (targets.length === 0) {
          if (prompt.includes('first page') || prompt.includes('page 1')) {
            targets = [0];
          } else if (prompt.includes('last page')) {
            targets = [maxPages - 1];
          } else {
            targets = [0]; // default first page
          }
        }

        const subDoc = await PDFDocument.create();
        const copiedPages = await subDoc.copyPages(sourceDoc, targets);
        copiedPages.forEach(page => subDoc.addPage(page));

        const subDocBytes = await subDoc.save();
        resultBlob = new Blob([subDocBytes], { type: 'application/pdf' });
        resultUrl = URL.createObjectURL(resultBlob);
        resultName = `${cleanName}-split.pdf`;
      }
      // 4. Single PDF to Image conversion
      else if (activeFiles.length === 1 && activeFiles[0].type === 'application/pdf' && (prompt.includes('image') || prompt.includes('png') || prompt.includes('jpg') || prompt.includes('jpeg') || prompt.includes('convert'))) {
        // Load PDF.js dynamically
        await loadScript('https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.4.120/pdf.min.js');
        // @ts-ignore
        const pdfjsLib = window['pdfjs-dist/build/pdf'];
        pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.4.120/pdf.worker.min.js';

        const arrayBuffer = await activeFiles[0].arrayBuffer();
        const loadingTask = pdfjsLib.getDocument({ data: arrayBuffer });
        const pdf = await loadingTask.promise;

        let targetPageNum = 1;
        const pageMatch = prompt.match(/(?:page)\s*(\d+)/i);
        if (pageMatch) {
          const num = parseInt(pageMatch[1]);
          if (num >= 1 && num <= pdf.numPages) targetPageNum = num;
        }

        const page = await pdf.getPage(targetPageNum);
        const viewport = page.getViewport({ scale: 1.5 });
        const canvas = document.createElement('canvas');
        canvas.width = viewport.width;
        canvas.height = viewport.height;
        const context = canvas.getContext('2d');
        if (!context) throw new Error("Could not create canvas context");

        await page.render({
          canvasContext: context,
          viewport: viewport
        }).promise;

        const mime = convertFormat || 'image/png';
        const ext = mime.split('/')[1];

        resultBlob = await new Promise<Blob | null>((resolve) => canvas.toBlob(b => resolve(b), mime));
        if (resultBlob) {
          resultUrl = URL.createObjectURL(resultBlob);
          resultName = `${cleanName}-page-${targetPageNum}.${ext}`;
        }
      }
      // 5. Single Image Canvas pipeline (Compress / Resize / Convert Format / Remove BG)
      else if (activeFiles.length === 1 && activeFiles[0].type.startsWith('image/')) {
        const imgItem = sourceImages.find(item => item.name === activeFiles[0].name);
        const imgEl = imgItem ? imgItem.img : null;
        if (!imgEl) throw new Error("Image buffer not fully loaded in workspace.");

        const isBgRemoval = prompt.includes('background') || prompt.includes('bg') || prompt.includes('cutout');

        let mimeType = convertFormat || activeFiles[0].type;
        if (isBgRemoval) {
          mimeType = 'image/png';
        } else if (!['image/jpeg', 'image/png', 'image/webp'].includes(mimeType)) {
          mimeType = 'image/jpeg';
        }
        const ext = mimeType.split('/')[1] === 'jpeg' ? 'jpg' : mimeType.split('/')[1];

        // Dimensions
        let w = imgEl.width;
        let h = imgEl.height;
        if (targetWidth > 0 && targetHeight > 0) {
          w = targetWidth;
          h = targetHeight;
        } else if (targetWidth > 0) {
          const ratio = imgEl.width / imgEl.height;
          w = targetWidth;
          h = Math.round(targetWidth / ratio);
        } else if (targetHeight > 0) {
          const ratio = imgEl.width / imgEl.height;
          h = targetHeight;
          w = Math.round(targetHeight * ratio);
        }

        const canvas = document.createElement('canvas');
        canvas.width = w;
        canvas.height = h;
        const ctx = canvas.getContext('2d');
        if (!ctx) throw new Error("Failed to create canvas context.");
        
        ctx.drawImage(imgEl, 0, 0, w, h);

        // Client-side automatic background removal
        if (isBgRemoval) {
          const imgData = ctx.getImageData(0, 0, w, h);
          const data = imgData.data;
          
          // Sample corner pixel (top-left) as background color
          const rKey = data[0];
          const gKey = data[1];
          const bKey = data[2];
          
          const tolerance = 45;
          
          for (let i = 0; i < data.length; i += 4) {
            const r = data[i];
            const g = data[i+1];
            const b = data[i+2];
            
            const dist = Math.sqrt(
              Math.pow(r - rKey, 2) +
              Math.pow(g - gKey, 2) +
              Math.pow(b - bKey, 2)
            );
            
            if (dist < tolerance) {
              data[i+3] = 0; // Make transparent
            }
          }
          ctx.putImageData(imgData, 0, 0);
        }

        const qualityMimeTypes = ['image/jpeg', 'image/webp'];
        const supportsQuality = qualityMimeTypes.includes(mimeType);

        if (!isBgRemoval && supportsQuality && targetKb > 0) {
          // Binary Search compression
          const targetBytes = targetKb * 1024;
          let minQ = 0.01;
          let maxQ = 1.0;
          let bestQ = 0.75;
          let bestBlob: Blob | null = null;

          for (let i = 0; i < 7; i++) {
            const midQ = (minQ + maxQ) / 2;
            const blob = await new Promise<Blob | null>((resolve) => canvas.toBlob(b => resolve(b), mimeType, midQ));
            if (!blob) continue;

            if (blob.size <= targetBytes) {
              bestQ = midQ;
              bestBlob = blob;
              minQ = midQ;
            } else {
              maxQ = midQ;
              if (!bestBlob) bestBlob = blob;
            }
          }
          resultBlob = bestBlob;
        } else {
          // Default output
          let q = 0.85;
          const percentMatch = prompt.match(/(\d+)\s*%/);
          if (percentMatch) {
            q = parseInt(percentMatch[1]) / 100;
          } else if (prompt.includes('compress') || prompt.includes('quality')) {
            q = 0.4;
            if (prompt.includes('balanced')) q = 0.7;
            if (prompt.includes('high')) q = 0.95;
          }
          resultBlob = await new Promise<Blob | null>((resolve) => canvas.toBlob(b => resolve(b), mimeType, supportsQuality ? q : undefined));
        }

        if (resultBlob) {
          resultUrl = URL.createObjectURL(resultBlob);
          resultName = isBgRemoval ? `${cleanName}-transparent.png` : `${cleanName}-processed.${ext}`;
        }
      } else {
        // Fallback catch-all mock file copy
        resultBlob = activeFiles[0];
        resultUrl = URL.createObjectURL(resultBlob);
        resultName = activeFiles[0].name;
      }

      if (!resultBlob || !resultUrl) {
        throw new Error("Could not construct output document. Verify inputs.");
      }

      await sleep(1000);
      setStepDone(step3);

      // Step 4: Compile output document
      setStepActive(step4, true);
      speak("Finishing up, packaging your file.");
      if (voiceStatusText) voiceStatusText.innerText = "Finishing up, packaging your file...";
      if (processingStatus) processingStatus.innerText = 'Compiling output...';
      if (processingDetails) processingDetails.innerText = 'Structuring document binary streams...';
      await sleep(600);
      setStepDone(step4);

      // Success Display Transition
      await sleep(200);
      processingStage?.classList.add('hidden');
      processingStage?.classList.remove('flex');
      outputStage?.classList.remove('hidden');
      outputStage?.classList.add('flex');

      speak("Done! Your file is ready. Let's download it.");
      if (voiceStatusText) voiceStatusText.innerText = "File processed successfully!";
      setTimeout(() => {
        voiceStatusBanner?.classList.add('hidden');
        voiceStatusBanner?.classList.remove('flex');
      }, 4000);

      if (outputNameText) outputNameText.innerText = resultName;
      if (outputCommandText) outputCommandText.innerText = `"${prompt}"`;

      // Update success visual preview cards
      const isImage = resultBlob.type.startsWith('image/');
      const imgPreviewContainer = document.getElementById('ai-output-image-preview-container');
      const imgPreview = document.getElementById('ai-output-image-preview') as HTMLImageElement;
      const pdfPreviewContainer = document.getElementById('ai-output-pdf-preview-container');

      if (isImage && imgPreview && imgPreviewContainer && pdfPreviewContainer) {
        imgPreview.src = resultUrl;
        imgPreviewContainer.classList.remove('hidden');
        imgPreviewContainer.classList.add('flex');
        pdfPreviewContainer.classList.add('hidden');
        pdfPreviewContainer.classList.remove('flex');
      } else if (imgPreviewContainer && pdfPreviewContainer) {
        imgPreviewContainer.classList.add('hidden');
        imgPreviewContainer.classList.remove('flex');
        pdfPreviewContainer.classList.remove('hidden');
        pdfPreviewContainer.classList.add('flex');
      }

    } catch (err: any) {
      console.error(err);
      alert(`AI execution failed: ${err.message || 'Unknown error'}`);
      processingStage?.classList.add('hidden');
      inputStage?.classList.remove('hidden');
    }
  }

  // Visual highlights
  function resetStepsUI() {
    [step1, step2, step3, step4].forEach((step, idx) => {
      if (step) {
        step.className = 'flex flex-col items-center gap-1.5 text-mute opacity-50 transition-all duration-300';
        const dot = document.getElementById(`step-${idx + 1}-dot`);
        if (dot) {
          dot.className = 'w-8 h-8 rounded-full border border-hairline flex items-center justify-center bg-canvas shadow-level-1 text-ink';
          
          // Restore original icons
          const icons = [
            `<svg viewBox="0 0 24 24" class="w-3.5 h-3.5 fill-none stroke-current" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>`, // Search
            `<svg viewBox="0 0 24 24" class="w-3.5 h-3.5 fill-none stroke-current" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="17 8 12 3 7 8"></polyline><line x1="12" y1="3" x2="12" y2="15"></line></svg>`, // Upload
            `<svg viewBox="0 0 24 24" class="w-3.5 h-3.5 fill-none stroke-current" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"></circle><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"></path></svg>`, // Settings
            `<svg viewBox="0 0 24 24" class="w-3.5 h-3.5 fill-none stroke-current" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>` // FileText
          ];
          dot.innerHTML = icons[idx] || '';
        }
      }
    });
  }

  function setStepActive(step: HTMLElement | null, active: boolean) {
    if (!step) return;
    const idx = step.id;
    if (active) {
      step.className = 'flex flex-col items-center gap-1.5 text-violet font-semibold opacity-100 transition-all duration-300 scale-105';
      const dot = document.getElementById(`${idx}-dot`);
      if (dot) {
        dot.className = 'w-8 h-8 rounded-full border border-violet bg-violet-soft/30 flex items-center justify-center text-violet animate-pulse shadow-level-2';
      }
    }
  }

  function setStepDone(step: HTMLElement | null) {
    if (!step) return;
    const idx = step.id;
    step.className = 'flex flex-col items-center gap-1.5 text-emerald-500 font-medium opacity-100 transition-all duration-300';
    const dot = document.getElementById(`${idx}-dot`);
    if (dot) {
      dot.className = 'w-8 h-8 rounded-full border border-emerald-500 bg-emerald-500 text-on-primary flex items-center justify-center shadow-level-2 scale-100';
      dot.innerHTML = `<svg viewBox="0 0 24 24" class="w-4 h-4 fill-none stroke-current" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>`;
    }
  }

  // Trigger Download
  downloadBtn?.addEventListener('click', async () => {
    if (!resultUrl || !resultBlob) return;
    
    const link = document.createElement('a');
    link.href = resultUrl;
    link.download = resultName;
    document.body.appendChild(link);
    link.click();
    document.body.removeChild(link);

    // Save to IndexedDB
    try {
      await addProcessedFile(resultName, resultBlob.type, resultBlob.size, 'ask-ai', resultBlob);
    } catch (err) {
      console.error('Failed to save AI output to history:', err);
    }
  });

  // Try again
  againBtn?.addEventListener('click', () => {
    outputStage?.classList.add('hidden');
    outputStage?.classList.remove('flex');
    inputStage?.classList.remove('hidden');
    resetAttachedFile();
  });

  // Parse custom range e.g. "1-3, 5, 8-10" to array of 0-based page indices
  function parsePageRange(rangeStr: string, maxPages: number): number[] {
    const pages = new Set<number>();
    const tokens = rangeStr.split(',');

    tokens.forEach(tok => {
      const clean = tok.trim();
      if (clean.includes('-')) {
        const parts = clean.split('-');
        const start = parseInt(parts[0].trim());
        const end = parseInt(parts[1].trim());

        if (!isNaN(start) && !isNaN(end)) {
          const min = Math.min(start, end);
          const max = Math.max(start, end);
          
          for (let i = min; i <= max; i++) {
            if (i >= 1 && i <= maxPages) {
              pages.add(i - 1);
            }
          }
        }
      } else {
        const page = parseInt(clean);
        if (!isNaN(page) && page >= 1 && page <= maxPages) {
          pages.add(page - 1);
        }
      }
    });

    return Array.from(pages).sort((a, b) => a - b);
  }

  // Helpers
  function sleep(ms: number) {
    return new Promise(resolve => setTimeout(resolve, ms));
  }

  function formatBytes(bytes: number, decimals = 2) {
    if (bytes === 0) return '0 Bytes';
    const k = 1024;
    const dm = decimals < 0 ? 0 : decimals;
    const sizes = ['Bytes', 'KB', 'MB', 'GB'];
    const i = Math.floor(Math.log(bytes) / Math.log(k));
    return parseFloat((bytes / Math.pow(k, i)).toFixed(dm)) + ' ' + (sizes[i] || 'Bytes');
  }
</script>
