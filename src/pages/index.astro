  <!-- Greeting Script -->
  <script>
    function updateDashboardGreeting() {
      const userStr = localStorage.getItem('imagemitra_user');
      const nameEl = document.getElementById('dashboard-user-name');
      const avatarEl = document.getElementById('dashboard-user-avatar');
      const tierBadge = document.getElementById('user-tier-badge');

      if (userStr) {
        try {
          const user = JSON.parse(userStr);
          const email = user.email || 'user@example.com';
          const name = user.name || email.split('@')[0];
          const initial = name.substring(0, 1).toUpperCase();

          if (nameEl) nameEl.innerText = name;
          if (avatarEl) {
            avatarEl.innerText = initial;
            avatarEl.classList.remove('bg-primary');
            avatarEl.classList.add('bg-gradient-to-tr', 'from-violet', 'to-highlight-pink', 'text-white');
          }
          if (tierBadge) {
            if (email.toLowerCase().includes('pro')) {
              tierBadge.innerText = 'Plan: Pro (Active)';
              tierBadge.classList.remove('bg-canvas');
              tierBadge.classList.add('bg-primary', 'text-on-primary');
            } else {
              tierBadge.innerText = 'Plan: Hobby (Free)';
            }
          }
        } catch (err) {
          console.error('Error updating dashboard greeting:', err);
        }
      }
    }

    // Bind AI card click to launch ask AI
    document.getElementById('stats-ai-card')?.addEventListener('click', (e) => {
      e.preventDefault();
      const trigger = document.getElementById('ask-ai-trigger');
      trigger?.click();
    });

    // PWA Custom Installation Prompt
    (function() {
      let deferredPrompt;
      const installBanner = document.getElementById('pwa-install-banner');
      const installBtn = document.getElementById('pwa-install-btn');
      const closeBtn = document.getElementById('pwa-close-btn');

      const isDismissed = sessionStorage.getItem('pwa-install-dismissed');

      window.addEventListener('beforeinstallprompt', (e) => {
        e.preventDefault();
        deferredPrompt = e;
        const isStandalone = window.matchMedia('(display-mode: standalone)').matches || navigator['standalone'];
        if (!isDismissed && !isStandalone && installBanner) {
          installBanner.classList.remove('hidden');
          installBanner.classList.add('flex');
        }
      });

      if (installBtn) {
        installBtn.addEventListener('click', async () => {
          if (!deferredPrompt) return;
          installBtn.setAttribute('disabled', 'true');
          
          deferredPrompt.prompt();
          const { outcome } = await deferredPrompt.userChoice;
          console.log('[PWA] User prompt outcome:', outcome);
          
          deferredPrompt = null;
          installBtn.removeAttribute('disabled');
          
          if (installBanner) {
            installBanner.classList.add('hidden');
            installBanner.classList.remove('flex');
          }
        });
      }

      if (closeBtn) {
        closeBtn.addEventListener('click', () => {
          if (installBanner) {
            installBanner.classList.add('hidden');
            installBanner.classList.remove('flex');
          }
          sessionStorage.setItem('pwa-install-dismissed', 'true');
        });
      }

      window.addEventListener('appinstalled', () => {
        console.log('[PWA] App installed successfully');
        if (installBanner) {
          installBanner.classList.add('hidden');
          installBanner.classList.remove('flex');
        }
      });
    })();

    window.addEventListener('load', updateDashboardGreeting);
    window.addEventListener('focus', updateDashboardGreeting);
  </script>
</Layout>

<script>
  // Simple client-side search logic
  const toolCards = document.querySelectorAll('.tool-card');
  const searchInput = document.getElementById('search-input') as HTMLInputElement;
  const emptyState = document.getElementById('search-empty-state');

  let searchQuery = '';

  function updateGrid() {
    let visibleCount = 0;
    
    toolCards.forEach(card => {
      const name = (card as HTMLElement).dataset.name || '';
      const desc = (card as HTMLElement).dataset.desc || '';
      
      const searchMatch = searchQuery === '' || name.includes(searchQuery) || desc.includes(searchQuery);

      if (searchMatch) {
        card.classList.remove('hidden');
        visibleCount++;
      } else {
        card.classList.add('hidden');
      }
    });

    if (visibleCount === 0) {
      emptyState?.classList.remove('hidden');
      emptyState?.classList.add('flex');
    } else {
      emptyState?.classList.add('hidden');
      emptyState?.classList.remove('flex');
    }
  }

  // Handle Search Input
  searchInput?.addEventListener('input', (e) => {
    searchQuery = (e.target as HTMLInputElement).value.toLowerCase().trim();
    updateGrid();
  });
</script>

<script>
  import { getAllProcessedFiles, deleteProcessedFile } from '../utils/db.js';

  const recentSection = document.getElementById('recent-files-section');
  const recentGrid = document.getElementById('recent-files-grid');

  async function loadRecentFiles() {
    const files = await getAllProcessedFiles();
    
    // Update stats files count in dashboard
    const statsFilesCount = document.getElementById('stats-files-count');
    if (statsFilesCount) {
      statsFilesCount.innerText = files.length.toString();
    }

    if (files.length === 0) {
      recentSection?.classList.add('hidden');
      return;
    }

    recentSection?.classList.remove('hidden');
    if (!recentGrid) return;
    recentGrid.innerHTML = '';

    files.forEach((file, index) => {
      const card = document.createElement('div');
      card.className = 'bg-canvas-soft border border-hairline rounded-md p-4 flex flex-col justify-between hover:shadow-level-2 transition-all duration-200 select-none opacity-0 animate-fade-in-up';
      card.style.animationDelay = `${index * 50}ms`;
      card.style.animationFillMode = 'forwards';

      // Tool name mapping
      const toolNames = {
        'image-compress': 'Compress Image',
        'image-resize': 'Edit & Resize Image',
        'image-convert': 'Convert Format',
        'pdf-merge': 'Merge PDFs',
        'pdf-split': 'Split PDF',
        'pdf-to-image': 'PDF to Image',
        'image-to-pdf': 'Image to PDF',
        'ask-ai': 'AI File Assistant'
      };
      
      const toolLabel = toolNames[file.toolId] || 'File Mitra Tool';
      const isImage = file.type.startsWith('image/');
      const dateStr = formatDateTime(file.timestamp);
      const sizeStr = formatBytes(file.size);

      let editToolId = file.toolId;
      if (editToolId === 'ask-ai') {
        editToolId = isImage ? 'image-resize' : 'pdf-split';
      }

      // Create blob URL for preview or download
      const blobUrl = URL.createObjectURL(file.blob);

      card.innerHTML = `
        <div class="flex flex-col gap-3">
          <!-- Preview Area -->
          <div class="border border-hairline bg-canvas rounded-sm h-36 overflow-hidden flex items-center justify-center p-2 relative group-hover:border-hairline-strong transition-colors">
            ${isImage 
              ? `<img src="${blobUrl}" class="max-h-full max-w-full object-contain pointer-events-none select-none rounded-sm" />`
              : `<div class="flex flex-col items-center justify-center text-rose-500 gap-1.5 select-none">
                  <svg viewBox="0 0 24 24" class="w-8 h-8 fill-rose-500/10 stroke-rose-500" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                    <polyline points="14 2 14 8 20 8"></polyline>
                    <line x1="16" y1="13" x2="8" y2="13"></line>
                    <line x1="16" y1="17" x2="8" y2="17"></line>
                    <polyline points="10 9 9 9 8 9"></polyline>
                  </svg>
                  <span class="font-mono text-[9px] uppercase tracking-wider text-mute">PDF Document</span>
                 </div>`
            }
          </div>

          <!-- Metadata -->
          <div class="flex flex-col gap-0.5">
            <span class="font-mono text-[9px] text-mute uppercase font-semibold">${toolLabel}</span>
            <h4 class="text-xs font-semibold text-ink truncate" title="${file.name}">${file.name}</h4>
            <div class="flex items-center justify-between text-[10px] text-mute mt-1">
              <span>${sizeStr}</span>
              <span>${dateStr}</span>
            </div>
          </div>
        </div>

        <!-- Action row -->
        <div class="flex items-center gap-1.5 border-t border-hairline pt-3.5 mt-3.5 select-none">
          <!-- Download -->
          <a 
            href="${blobUrl}" 
            download="${file.name}"
            class="flex-1 bg-primary text-on-primary hover:bg-primary/95 text-[10px] font-semibold py-1.5 rounded-sm flex items-center justify-center gap-1 transition-all active:scale-95 cursor-pointer shadow-level-1"
          >
            Download
          </a>

          <!-- Edit -->
          <a 
            href="/tools/${editToolId}?editId=${file.id}"
            class="px-2.5 bg-canvas border border-hairline hover:bg-canvas-soft-2 text-ink text-[10px] font-semibold py-1.5 rounded-sm flex items-center justify-center gap-1 transition-all active:scale-95 cursor-pointer shadow-level-1"
            title="Edit file back in workspace"
          >
            Edit
          </a>

          <!-- Delete -->
          <button 
            data-id="${file.id}"
            class="delete-file-btn p-1.5 bg-canvas border border-hairline hover:bg-error-soft hover:text-error hover:border-error-soft text-mute rounded-sm flex items-center justify-center transition-all active:scale-95 cursor-pointer"
            title="Delete from local history"
          >
            <svg viewBox="0 0 24 24" class="w-3.5 h-3.5 stroke-current fill-none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="3 6 5 6 21 6"></polyline>
              <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
              <line x1="10" y1="11" x2="10" y2="17"></line>
              <line x1="14" y1="11" x2="14" y2="17"></line>
            </svg>
          </button>
        </div>
      `;

      // Attach Delete Listener
      const delBtn = card.querySelector('.delete-file-btn');
      delBtn?.addEventListener('click', async (e) => {
        e.preventDefault();
        const id = parseInt((delBtn as HTMLElement).dataset.id || '');
        if (id) {
          URL.revokeObjectURL(blobUrl);
          await deleteProcessedFile(id);
          loadRecentFiles();
        }
      });

      recentGrid.appendChild(card);
    });
  }

  function formatDateTime(timestamp) {
    const d = new Date(timestamp);
    const time = d.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
    const date = d.toLocaleDateString([], { month: 'short', day: 'numeric' });
    return `${date}, ${time}`;
  }

  function formatBytes(bytes, decimals = 2) {
    if (bytes === 0) return '0 Bytes';
    const k = 1024;
    const dm = decimals < 0 ? 0 : decimals;
    const sizes = ['Bytes', 'KB', 'MB', 'GB'];
    const i = Math.floor(Math.log(bytes) / Math.log(k));
    return parseFloat((bytes / Math.pow(k, i)).toFixed(dm)) + ' ' + sizes[i];
  }

  window.addEventListener('load', loadRecentFiles);
  window.addEventListener('focus', loadRecentFiles);
</script>
