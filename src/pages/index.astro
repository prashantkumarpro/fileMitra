---
import Layout from '../layouts/Layout.astro';
import { Image, FileText, Settings, ArrowRight, Check, Search, Sparkles, Layers, Expand, RefreshCw, Scissors, FileImage, Compass, Shield } from 'lucide-astro';

const tools = [
  {
    id: 'bg-remover',
    name: 'Background Remover & Passport Maker',
    desc: 'Remove backgrounds, replace them with colors/gradients, and format passport photos.',
    category: 'image',
    href: '/tools/bg-remover',
    tags: ['Popular', 'Passport'],
  },
  {
    id: 'image-compress',
    name: 'Compress Image',
    desc: 'Reduce file sizes of JPG, PNG, and WebP images without losing quality.',
    category: 'image',
    href: '/tools/image-compress',
    tags: ['Lossless'],
  },
  {
    id: 'image-resize',
    name: 'Edit & Resize Image',
    desc: 'Scale, crop, rotate, flip, and apply adjustment filters to images client-side.',
    category: 'image',
    href: '/tools/image-resize',
    tags: ['Canvas', 'Crop'],
  },
  {
    id: 'image-convert',
    name: 'Convert Format',
    desc: 'Transform images between JPEG, PNG, WebP, and other formats instantly.',
    category: 'image',
    href: '/tools/image-convert',
    tags: ['Offline', 'Fast'],
  },
  {
    id: 'image-to-pdf',
    name: 'Image to PDF',
    desc: 'Transform individual or multiple images into a single PDF document.',
    category: 'image',
    href: '/tools/image-to-pdf',
    tags: ['New'],
  },
];

const tagStyles = {
  'Popular': 'bg-amber-500/10 text-amber-600 dark:text-amber-400 border border-amber-500/20',
  'Lossless': 'bg-emerald-500/10 text-emerald-600 dark:text-emerald-400 border border-emerald-500/20',
  'Canvas': 'bg-blue-500/10 text-blue-600 dark:text-blue-400 border border-blue-500/20',
  'Crop': 'bg-teal-500/10 text-teal-600 dark:text-teal-400 border border-teal-500/20',
  'Offline': 'bg-indigo-500/10 text-indigo-600 dark:text-indigo-400 border border-indigo-500/20',
  'Privacy': 'bg-violet-500/10 text-violet-600 dark:text-violet-400 border border-violet-500/20',
  'New': 'bg-pink-500/10 text-pink-600 dark:text-pink-400 border border-pink-500/20',
  'Fast': 'bg-sky-500/10 text-sky-600 dark:text-sky-400 border border-sky-500/20',
  'ChromaKey': 'bg-purple-500/10 text-purple-600 dark:text-purple-400 border border-purple-500/20',
  'Passport': 'bg-fuchsia-500/10 text-fuchsia-600 dark:text-fuchsia-400 border border-fuchsia-500/20'
};
---

<Layout>
  <!-- Dashboard Welcome & Stats Widget Row -->
  <section class="relative overflow-hidden bg-canvas border-b border-hairline py-8 md:py-12">
    <!-- Atmospheric Mesh Gradient Backdrop -->
    <div class="absolute inset-0 z-0 flex items-center justify-center overflow-hidden">
      <div class="w-[800px] h-[300px] rounded-full mesh-gradient-bg opacity-35 pointer-events-none"></div>
    </div>

    <div class="relative z-10 max-w-[1200px] mx-auto px-6 w-full flex flex-col gap-8">
      
      <!-- Greeting and Quick Info -->
      <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
        <div class="flex items-center gap-3">
          <div class="w-12 h-12 rounded-full bg-primary text-on-primary font-bold flex items-center justify-center text-lg shadow-level-2 select-none" id="dashboard-user-avatar">
            G
          </div>
          <div class="flex flex-col">
            <h1 class="text-xl font-bold text-ink font-sans tracking-tight leading-tight select-none">
              Hello, <span id="dashboard-user-name">Guest</span>!
            </h1>
            <p class="text-xs text-body font-sans select-none">
              Manage your local browser files and tools.
            </p>
          </div>
        </div>
        
        <!-- Quick Action Trigger Badges (Airtel-Thanks widget header style) -->
        <div class="flex flex-wrap items-center gap-2">
          <span class="inline-flex items-center gap-1.5 bg-canvas border border-hairline px-2.5 py-1 rounded-full text-[10px] font-semibold text-body shadow-level-1 select-none">
            <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"></span>
            Privacy Shield: Local Engine
          </span>
          <span class="inline-flex items-center gap-1.5 bg-canvas border border-hairline px-2.5 py-1 rounded-full text-[10px] font-semibold text-body shadow-level-1 select-none" id="user-tier-badge">
            Plan: Hobby (Free)
          </span>
        </div>
      </div>

      <!-- Custom PWA Install Banner -->
      <div id="pwa-install-banner" class="hidden bg-canvas border border-violet-soft/30 dark:border-violet-deep/30 rounded-md p-5 flex-col sm:flex-row items-start sm:items-center justify-between gap-4 shadow-level-2 relative overflow-hidden select-none animate-fade-in z-20">
        <!-- Background light gradient spotlight -->
        <div class="absolute inset-0 bg-gradient-to-r from-violet/5 via-highlight-pink/5 to-transparent pointer-events-none"></div>
        
        <div class="flex items-center gap-4 z-10">
          <div class="p-3 bg-violet/10 text-violet rounded-sm border border-violet/20 flex-shrink-0">
            <Sparkles class="w-6 h-6 animate-pulse" />
          </div>
          <div class="flex flex-col">
            <h3 class="text-sm font-semibold text-ink font-sans tracking-tight">Install imageMitra App</h3>
            <p class="text-xs text-body font-sans mt-0.5">Add to home screen for absolute privacy, offline processing, and a standalone app interface.</p>
          </div>
        </div>
        
        <div class="flex items-center gap-3 z-10 w-full sm:w-auto justify-end">
          <button id="pwa-install-btn" class="bg-primary text-on-primary hover:bg-primary/95 text-xs font-semibold px-4 h-9 rounded-pill flex items-center justify-center shadow-level-2 transition-all active:scale-95 cursor-pointer whitespace-nowrap">
            Install
          </button>
          <button id="pwa-close-btn" class="text-body hover:text-ink text-xs font-semibold px-3 h-9 rounded-pill border border-hairline hover:bg-canvas-soft-2 transition-colors cursor-pointer whitespace-nowrap">
            Maybe Later
          </button>
        </div>
      </div>

      <!-- Quick Actions / Live Stats Cards Row (3 Cards Dashboard) -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        
        <!-- Stat Widget 1: Local Library Usage -->
        <div class="bg-canvas border border-hairline rounded-md p-5 flex items-center justify-between hover:shadow-level-2 transition-all duration-200 shadow-level-1 relative overflow-hidden group select-none">
          <div class="flex flex-col gap-1.5 z-10">
            <span class="font-mono text-[9px] text-mute uppercase font-semibold tracking-wider">Local Workspaces</span>
            <div class="flex items-baseline gap-1">
              <span class="text-2xl font-bold text-ink font-sans leading-none" id="stats-files-count">0</span>
              <span class="text-mute text-xs">files cached</span>
            </div>
            <span class="text-[10px] text-body mt-1">Stored offline on your browser engine</span>
          </div>
          <div class="p-3 bg-canvas-soft-2 rounded-sm border border-hairline text-ink group-hover:bg-primary group-hover:text-on-primary transition-colors duration-300 z-10">
            <Compass class="w-5 h-5" />
          </div>
        </div>

        <!-- Stat Widget 2: Security & Local Engine -->
        <div class="bg-canvas border border-hairline rounded-md p-5 flex items-center justify-between hover:shadow-level-2 transition-all duration-200 shadow-level-1 relative overflow-hidden group select-none">
          <div class="flex flex-col gap-1.5 z-10">
            <span class="font-mono text-[9px] text-mute uppercase font-semibold tracking-wider">Security shield</span>
            <div class="flex items-baseline gap-1">
              <span class="text-2xl font-bold text-ink font-sans leading-none">100%</span>
              <span class="text-mute text-xs">On-Device</span>
            </div>
            <span class="text-[10px] text-body mt-1">Zero server uploads, full privacy</span>
          </div>
          <div class="p-3 bg-canvas-soft-2 rounded-sm border border-hairline text-ink group-hover:bg-primary group-hover:text-on-primary transition-colors duration-300 z-10">
            <Shield class="w-5 h-5" />
          </div>
        </div>

        <!-- Stat Widget 3: AI File Assistant shortcut -->
        <a href="javascript:void(0)" id="stats-ai-card" class="bg-canvas border border-hairline rounded-md p-5 flex items-center justify-between hover:shadow-level-3 hover:border-violet-soft transition-all duration-200 shadow-level-1 relative overflow-hidden group cursor-pointer">
          <div class="absolute inset-0 bg-gradient-to-br from-violet/5 via-highlight-pink/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
          
          <div class="flex flex-col gap-1.5 z-10">
            <span class="font-mono text-[9px] text-mute uppercase font-semibold tracking-wider text-violet">AI Smart Engine</span>
            <div class="flex items-baseline gap-1">
              <span class="text-lg font-bold text-ink font-sans leading-none group-hover:text-violet-deep transition-colors">Ask AI Assistant</span>
            </div>
            <span class="text-[10px] text-body mt-1">Instruct AI to convert, edit or compress</span>
          </div>
          <div class="p-3 bg-canvas-soft-2 rounded-sm border border-hairline text-violet group-hover:bg-violet group-hover:text-white transition-colors duration-300 z-10">
            <Sparkles class="w-5 h-5 animate-pulse" />
          </div>
        </a>

      </div>

    </div>
  </section>

  <!-- Quick Actions Grid (Airtel Thanks app quick circular shortcut style) -->
  <section class="py-10 px-6 bg-canvas border-b border-hairline select-none">
    <div class="max-w-[1200px] mx-auto flex flex-col gap-6">
      <div class="flex flex-col gap-1">
        <span class="font-mono text-[10px] tracking-wider text-mute uppercase font-semibold select-none">
          Quick Workspace Shortcuts
        </span>
        <h2 class="text-sm font-semibold text-ink font-sans tracking-tight">
          Select a tool to launch browser engine
        </h2>
      </div>

      <!-- Quick circular/grid buttons (5 cols on mobile, 5 cols on desktop) -->
      <div class="grid grid-cols-5 md:grid-cols-5 gap-2 sm:gap-4 md:gap-6 max-w-2xl">
        
        <!-- Shortcut 1: BG Remover -->
        <a href="/tools/bg-remover" class="flex flex-col items-center text-center group cursor-pointer">
          <div class="w-12 h-12 sm:w-14 sm:h-14 rounded-full bg-pink-500/10 text-pink-600 border border-pink-500/20 flex items-center justify-center shadow-level-1 group-hover:shadow-level-2 group-hover:scale-105 active:scale-95 transition-all duration-200">
            <Sparkles class="w-5.5 h-5.5" />
          </div>
          <span class="text-[10px] sm:text-xs font-semibold text-body group-hover:text-ink mt-2 truncate max-w-full">BG Remover</span>
        </a>

        <!-- Shortcut 2: Compress Image -->
        <a href="/tools/image-compress" class="flex flex-col items-center text-center group cursor-pointer">
          <div class="w-12 h-12 sm:w-14 sm:h-14 rounded-full bg-amber-500/10 text-amber-600 border border-amber-500/20 flex items-center justify-center shadow-level-1 group-hover:shadow-level-2 group-hover:scale-105 active:scale-95 transition-all duration-200">
            <Layers class="w-5.5 h-5.5" />
          </div>
          <span class="text-[10px] sm:text-xs font-semibold text-body group-hover:text-ink mt-2 truncate max-w-full">Compress</span>
        </a>

        <!-- Shortcut 3: Resize Image -->
        <a href="/tools/image-resize" class="flex flex-col items-center text-center group cursor-pointer">
          <div class="w-12 h-12 sm:w-14 sm:h-14 rounded-full bg-blue-500/10 text-blue-600 border border-blue-500/20 flex items-center justify-center shadow-level-1 group-hover:shadow-level-2 group-hover:scale-105 active:scale-95 transition-all duration-200">
            <Expand class="w-5.5 h-5.5" />
          </div>
          <span class="text-[10px] sm:text-xs font-semibold text-body group-hover:text-ink mt-2 truncate max-w-full">Resize</span>
        </a>

        <!-- Shortcut 4: Convert Format -->
        <a href="/tools/image-convert" class="flex flex-col items-center text-center group cursor-pointer">
          <div class="w-12 h-12 sm:w-14 sm:h-14 rounded-full bg-purple-500/10 text-purple-600 border border-purple-500/20 flex items-center justify-center shadow-level-1 group-hover:shadow-level-2 group-hover:scale-105 active:scale-95 transition-all duration-200">
            <RefreshCw class="w-5.5 h-5.5" />
          </div>
          <span class="text-[10px] sm:text-xs font-semibold text-body group-hover:text-ink mt-2 truncate max-w-full">Convert</span>
        </a>

        <!-- Shortcut 5: Image to PDF -->
        <a href="/tools/image-to-pdf" class="flex flex-col items-center text-center group cursor-pointer">
          <div class="w-12 h-12 sm:w-14 sm:h-14 rounded-full bg-emerald-500/10 text-emerald-600 border border-emerald-500/20 flex items-center justify-center shadow-level-1 group-hover:shadow-level-2 group-hover:scale-105 active:scale-95 transition-all duration-200">
            <FileText class="w-5.5 h-5.5" />
          </div>
          <span class="text-[10px] sm:text-xs font-semibold text-body group-hover:text-ink mt-2 truncate max-w-full">Image to PDF</span>
        </a>

      </div>
    </div>
  </section>

  <!-- Featured Showcase: Interactive Before/After Split comparison card (Airtel Thanks Style Hero Banner) -->
  <section class="py-12 px-6 bg-canvas-soft border-b border-hairline">
    <div class="max-w-[1200px] mx-auto">
      
      <!-- Promo Banner container with Vercel design mesh background -->
      <div class="relative bg-canvas border border-hairline rounded-lg p-6 md:p-10 shadow-level-4 overflow-hidden grid grid-cols-1 lg:grid-cols-12 gap-8 items-center">
        <!-- Background light gradient spotlight -->
        <div class="absolute inset-0 bg-gradient-to-tr from-pink-500/5 via-violet/5 to-transparent pointer-events-none"></div>

        <!-- Left Side: Copy Info -->
        <div class="lg:col-span-5 flex flex-col gap-4 z-10">
          <span class="bg-pink-500/10 text-pink-600 text-[10px] font-mono font-semibold px-2.5 py-0.5 rounded-full uppercase tracking-wider self-start border border-pink-500/25">
            Featured Utility
          </span>
          <h2 class="display-lg text-ink font-sans tracking-tight leading-tight select-none">
            Isolate subjects in seconds.
          </h2>
          <p class="text-body text-sm leading-relaxed">
            Erase backgrounds from your portrait photos cleanly. Create instant passport-sized photos with dynamic solid colored backgrounds in a single tap. 
          </p>
          <ul class="flex flex-col gap-2 font-sans text-xs text-body">
            <li class="flex items-center gap-2"><Check class="w-4 h-4 text-emerald-500" /> Auto edge detection on local CPU</li>
            <li class="flex items-center gap-2"><Check class="w-4 h-4 text-emerald-500" /> Interactive passport size generator</li>
          </ul>
          <div class="flex items-center gap-4 mt-2">
            <a href="/tools/bg-remover" class="bg-primary text-on-primary hover:bg-primary/95 text-xs font-semibold px-5 h-10 rounded-pill flex items-center justify-center shadow-level-2 transition-all active:scale-95">
              Remove Background
            </a>
            <a href="#tools" class="text-body hover:text-ink text-xs font-semibold flex items-center gap-1.5 transition-colors">
              Other Utilities
              <ArrowRight class="w-3.5 h-3.5" />
            </a>
          </div>
        </div>

        <!-- Right Side: Interactive Mockup Comparison Slider -->
        <div class="lg:col-span-7 flex justify-center z-10 w-full">
          <!-- Interactive slider frame -->
          <div class="relative w-full max-w-lg h-[260px] sm:h-[320px] rounded-md border border-hairline overflow-hidden shadow-level-3 select-none bg-canvas-soft-2 group/slider" id="compare-slider-container">
            
            <!-- Before Image Layer (Original Photo on Left Side of Mockup) -->
            <!-- We will display the generated side-by-side demonstration image -->
            <img 
              src="/assets/images/bg-remover-demo.png" 
              alt="Background Remover Demo" 
              class="w-full h-full object-cover pointer-events-none select-none"
            />
            
            <!-- Laser scanning line visual effect -->
            <div class="absolute inset-y-0 left-0 w-1 bg-gradient-to-r from-transparent via-pink-500 to-transparent shadow-[0_0_8px_rgba(236,72,153,0.8)] animate-scan pointer-events-none"></div>

            <!-- Labels -->
            <span class="absolute bottom-3 left-3 bg-primary/70 backdrop-blur-xs text-white text-[9px] font-mono uppercase px-2 py-0.5 rounded-sm">Original</span>
            <span class="absolute bottom-3 right-3 bg-emerald-500/70 backdrop-blur-xs text-white text-[9px] font-mono uppercase px-2 py-0.5 rounded-sm">Isolated</span>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Tools Grid Section -->
  <section id="tools" class="py-16 px-6 bg-canvas-soft border-b border-hairline">
    <div class="max-w-[1200px] mx-auto flex flex-col gap-10">
      
      <!-- Headline & Filter Controls -->
      <div class="flex flex-col gap-2">
        <span class="font-mono text-[11px] tracking-wider text-mute uppercase font-semibold select-none">
          Utilities Directory
        </span>
        <h2 class="display-lg text-ink">
          A compute model for all workloads.
        </h2>
      </div>

      <!-- Search Box Input -->
      <div class="relative max-w-md w-full">
        <span class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none text-mute">
          <Search class="w-4 h-4" />
        </span>
        <input
          type="text"
          id="search-input"
          placeholder="Search tools (e.g. compress, merge, resize...)"
          class="w-full bg-canvas text-ink border border-hairline focus:border-hairline-strong text-sm rounded-sm pl-10 pr-4 py-2.5 outline-none transition-all placeholder:text-mute shadow-level-2"
        />
      </div>

      <!-- Tools Grid -->
      <div id="tools-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {tools.map((tool, index) => (
          <div
            data-category={tool.category}
            data-name={tool.name.toLowerCase()}
            data-desc={tool.desc.toLowerCase()}
            class={`tool-card group bg-canvas border border-hairline rounded-md p-6 hover:shadow-level-3 hover:-translate-y-0.5 active:scale-[0.99] transition-all duration-300 flex flex-col justify-between opacity-0 animate-fade-in-up ${
              tool.category === 'image' ? 'hover:border-amber-500/35 hover:shadow-amber-500/[0.02]' : 'hover:border-rose-500/35 hover:shadow-rose-500/[0.02]'
            }`}
            style={`animation-delay: ${index * 60}ms; animation-fill-mode: forwards;`}
          >
            <div>
              <div class="flex items-center justify-between mb-4">
                <span class={`p-2.5 rounded-sm border transition-all duration-300 flex items-center justify-center ${
                  tool.category === 'image'
                    ? 'bg-amber-500/10 text-amber-600 dark:text-amber-400 border-amber-500/15 group-hover:bg-amber-500 group-hover:text-on-primary group-hover:border-amber-500'
                    : 'bg-rose-500/10 text-rose-600 dark:text-rose-400 border-rose-500/15 group-hover:bg-rose-500 group-hover:text-on-primary group-hover:border-rose-500'
                }`}>
                  {tool.category === 'image' ? <Image class="w-5 h-5" /> : <FileText class="w-5 h-5" />}
                </span>
                <div class="flex items-center gap-1.5 select-none">
                  {tool.tags.map(tag => (
                    <span class={`font-mono text-[9px] tracking-wider uppercase px-2 py-0.5 rounded-full font-semibold ${
                      tagStyles[tag] || 'bg-canvas-soft-2 text-body border border-hairline'
                    }`}>
                      {tag}
                    </span>
                  ))}
                </div>
              </div>
              <h3 class="display-sm text-ink mb-2">{tool.name}</h3>
              <p class="text-body text-sm mb-6 leading-relaxed select-none">{tool.desc}</p>
            </div>
            <a
              href={tool.href}
              class={`w-full flex items-center justify-between font-semibold text-xs border-t border-hairline pt-4 text-ink transition-all duration-300 ${
                tool.category === 'image' 
                  ? 'group-hover:text-amber-600 dark:group-hover:text-amber-400 group-hover:border-amber-500/25' 
                  : 'group-hover:text-rose-600 dark:group-hover:text-rose-400 group-hover:border-rose-500/25'
              }`}
            >
              Open Tool
              <ArrowRight class="w-4 h-4 transform group-hover:translate-x-1.5 transition-transform duration-300" />
            </a>
          </div>
        ))}
      </div>
      
      <!-- Empty State for Search -->
      <div id="search-empty-state" class="hidden flex-col items-center justify-center py-16 px-6 bg-canvas border border-hairline rounded-lg text-center shadow-level-2">
        <span class="p-4 bg-canvas-soft rounded-full text-mute border border-hairline mb-4">
          <Search class="w-6 h-6" />
        </span>
        <h3 class="text-ink font-semibold text-lg mb-1">No tools matched your search</h3>
        <p class="text-mute text-sm max-w-xs">
          Try typing a different keyword like "compress", "merge", or "resize".
        </p>
      </div>

    </div>
  </section>

  <!-- Recent Files Library Section -->
  <section id="recent-files-section" class="py-16 px-6 bg-canvas border-b border-hairline hidden">
    <div class="max-w-[1200px] mx-auto flex flex-col gap-8">
      
      <div class="flex flex-col gap-2">
        <span class="font-mono text-[11px] tracking-wider text-mute uppercase font-semibold select-none">
          Local Storage Library
        </span>
        <h2 class="display-lg text-ink animate-fade-in-up" style="animation-delay: 100ms;">
          Your processed file history.
        </h2>
        <p class="text-body text-sm max-w-[650px] leading-relaxed select-none">
          Access, re-edit, download, or delete processed files stored securely on your browser.
        </p>
      </div>

      <!-- Files Grid List -->
      <div id="recent-files-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        <!-- Rendered dynamically -->
      </div>
      
    </div>
  </section>

  <!-- Developer Highlight / Atmospheric Section (Hidden on Mobile) -->
  <section class="hidden md:block relative bg-primary text-on-primary py-24 px-6 border-b border-hairline overflow-hidden">
    <div class="absolute inset-0 z-0 flex items-center justify-center overflow-hidden">
      <div class="w-[800px] h-[400px] rounded-full bg-gradient-to-tr from-violet/40 to-highlight-pink/40 filter blur-3xl opacity-20 pointer-events-none"></div>
    </div>
    
    <div class="relative z-10 max-w-[1200px] mx-auto grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <div class="flex flex-col gap-4">
        <span class="font-mono text-[11px] tracking-wider text-mute uppercase font-semibold select-none">
          Client-Side Core Engine
        </span>
        <h2 class="display-lg text-on-primary max-w-lg">
          Fast processing, built on zero server logic.
        </h2>
        <p class="text-mute text-sm max-w-md leading-relaxed">
          Because imageMitra performs crops, background removal, and compression inside your local browser runtime via Canvas and WebGL, files never hit a network server.
        </p>
        <ul class="flex flex-col gap-2 mt-2">
          <li class="flex items-center gap-2.5 text-xs text-mute"><Check class="w-4 h-4 text-cyan" /> 100% private: Files stay in your local memory</li>
          <li class="flex items-center gap-2.5 text-xs text-mute"><Check class="w-4 h-4 text-cyan" /> Lightning speed: Zero network upload latency</li>
          <li class="flex items-center gap-2.5 text-xs text-mute"><Check class="w-4 h-4 text-cyan" /> Unlimited capability: Large sizes processed instantly</li>
        </ul>
      </div>

      <!-- Live Mockup of code editor -->
      <div class="bg-[#0c0c0c] border border-[#262626] rounded-md p-6 shadow-level-5 font-mono text-xs text-[#d4d4d4] select-none">
        <div class="flex items-center justify-between border-b border-[#262626] pb-4 mb-4">
          <div class="flex items-center gap-2">
            <span class="w-3 h-3 rounded-full bg-[#ff5f56]"></span>
            <span class="w-3 h-3 rounded-full bg-[#ffbd2e]"></span>
