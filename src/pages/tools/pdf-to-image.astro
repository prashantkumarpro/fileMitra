---
import ToolLayout from '../../layouts/ToolLayout.astro';
import { Upload, Download, RefreshCw, Layers, FileImage } from 'lucide-astro';
---

<ToolLayout
  title="PDF to Image"
  description="Convert PDF pages into high-quality PNG images directly in your browser. Preview page images and save them individually."
  activeTool="pdf-to-image"
>
  <!-- Load PDF.js from Cloudflare CDN -->
  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.4.120/pdf.min.js"></script>

  <div class="flex-grow flex flex-col gap-6">
    
    <!-- Drag & Drop Upload Zone -->
    <div
      id="upload-zone"
      class="border-2 border-dashed border-hairline hover:border-hairline-strong bg-canvas rounded-lg p-16 flex flex-col items-center justify-center text-center cursor-pointer transition-all duration-200 shadow-level-2 select-none group"
    >
      <input type="file" id="file-input" accept="application/pdf" class="hidden" />
      <span class="p-4 bg-canvas-soft rounded-full text-mute group-hover:text-primary border border-hairline mb-4 transition-colors">
        <Upload class="w-6 h-6 animate-pulse" />
      </span>
      <h3 class="text-ink font-semibold text-lg mb-1">Drag and drop your PDF to convert</h3>
      <p class="text-mute text-xs max-w-xs mb-4">
        Extract pages as high-quality PNG images. Runs entirely in your browser.
      </p>
      <button class="bg-primary text-on-primary hover:bg-primary/95 text-xs font-semibold px-4 py-2 rounded-pill shadow-level-2 transition-all">
        Select PDF
      </button>
    </div>

    <!-- Active Workspace Area -->
    <div id="workspace" class="hidden grid grid-cols-1 lg:grid-cols-3 gap-6 items-start animate-in fade-in duration-200">
      
      <!-- Side panel: Details & Global triggers (1 column) -->
      <div class="flex flex-col gap-6 lg:col-span-1">
        <div class="bg-canvas border border-hairline rounded-md p-6 shadow-level-3 flex flex-col gap-6">
          <h3 class="font-sans font-semibold text-sm text-ink pb-3 border-b border-hairline select-none flex items-center gap-1.5">
            <FileImage class="w-4 h-4 text-mute" />
            Image Conversion
          </h3>

          <div class="bg-canvas-soft border border-hairline rounded-sm p-4 flex flex-col gap-3 text-xs text-body">
            <span class="font-mono text-[10px] text-mute uppercase font-semibold select-none">PDF Diagnostics</span>
            <div class="flex justify-between">
              <span>File Name:</span>
              <span id="file-name" class="font-mono text-ink max-w-[150px] truncate">document.pdf</span>
            </div>
            <div class="flex justify-between">
              <span>Page Count:</span>
              <span id="total-pages" class="font-mono text-ink font-semibold">0</span>
            </div>
          </div>

          <div class="flex flex-col gap-2">
            <button id="reset-btn" class="bg-canvas border border-hairline hover:bg-canvas-soft text-ink text-xs font-semibold h-10 rounded-pill flex items-center justify-center gap-1.5 transition-all shadow-level-1">
              <RefreshCw class="w-3.5 h-3.5" />
              Upload Different PDF
            </button>
          </div>
        </div>
      </div>

      <!-- Main workspace: Pages Render Grid (2 columns) -->
      <div class="flex flex-col gap-6 lg:col-span-2">
        <div class="bg-canvas border border-hairline rounded-md p-6 shadow-level-3">
          <div class="flex items-center justify-between border-b border-hairline pb-4 mb-6 select-none">
            <h3 class="font-sans font-semibold text-sm text-ink">Extracted Pages</h3>
            <span id="rendered-count" class="font-mono text-[10px] text-mute uppercase">Rendering...</span>
          </div>

          <!-- Loading indicator -->
          <div id="loading-spinner" class="flex flex-col items-center justify-center py-16 gap-3">
            <span class="animate-spin text-mute"><RefreshCw class="w-6 h-6" /></span>
            <span class="text-xs text-mute font-mono">Drawing page frames on-device...</span>
          </div>

          <!-- Pages thumbnails grid -->
          <div id="pages-container" class="grid grid-cols-1 sm:grid-cols-2 gap-6 hidden">
            <!-- Dynamic rendered page cards -->
          </div>
        </div>
      </div>

    </div>

  </div>
</ToolLayout>

<script>
  import { addProcessedFile, getProcessedFile } from '../../utils/db.js';

  // Ensure PDF.js globals resolve
  // @ts-ignore
  const pdfjsLib = window['pdfjs-dist/build/pdf'];
  pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.4.120/pdf.worker.min.js';

  const uploadZone = document.getElementById('upload-zone');
  const fileInput = document.getElementById('file-input') as HTMLInputElement;
  const workspace = document.getElementById('workspace');
  
  const fileNameText = document.getElementById('file-name');
  const totalPagesText = document.getElementById('total-pages');
  const renderedCountText = document.getElementById('rendered-count');
  
  const loadingSpinner = document.getElementById('loading-spinner');
  const pagesContainer = document.getElementById('pages-container');
  const resetBtn = document.getElementById('reset-btn');

  let activeFile: File | null = null;
  let pageImages: string[] = [];

  uploadZone?.addEventListener('click', () => fileInput.click());

  uploadZone?.addEventListener('dragover', (e) => {
    e.preventDefault();
    uploadZone.classList.add('border-primary', 'bg-canvas-soft');
  });

  uploadZone?.addEventListener('dragleave', () => {
    uploadZone.classList.remove('border-primary', 'bg-canvas-soft');
  });

  uploadZone?.addEventListener('drop', (e) => {
    e.preventDefault();
    uploadZone.classList.remove('border-primary', 'bg-canvas-soft');
    if (e.dataTransfer?.files && e.dataTransfer.files.length > 0) {
      handleFile(e.dataTransfer.files[0]);
    }
  });

  fileInput?.addEventListener('change', () => {
    if (fileInput.files && fileInput.files.length > 0) {
      handleFile(fileInput.files[0]);
    }
  });

  async function handleFile(file: File) {
    if (file.type !== 'application/pdf') {
      alert('Please select a valid PDF.');
      return;
    }
    activeFile = file;

    uploadZone?.classList.add('hidden');
    workspace?.classList.remove('hidden');
    loadingSpinner?.classList.remove('hidden');
    pagesContainer?.classList.add('hidden');

    if (fileNameText) fileNameText.innerText = file.name;
    if (renderedCountText) renderedCountText.innerText = 'Rendering...';

    pageImages = [];

    try {
      const arrayBuffer = await file.arrayBuffer();
      const loadingTask = pdfjsLib.getDocument({ data: arrayBuffer });
      const pdf = await loadingTask.promise;

      const numPages = pdf.numPages;
      if (totalPagesText) totalPagesText.innerText = numPages.toString();
      
      if (pagesContainer) pagesContainer.innerHTML = '';

      for (let pageNum = 1; pageNum <= numPages; pageNum++) {
        const page = await pdf.getPage(pageNum);
        
        // Render to high-density canvas scale 1.5
        const viewport = page.getViewport({ scale: 1.5 });
        const canvas = document.createElement('canvas');
        canvas.width = viewport.width;
        canvas.height = viewport.height;
        
        const context = canvas.getContext('2d');
        if (!context) continue;

        await page.render({
          canvasContext: context,
          viewport: viewport
        }).promise;

        const dataUrl = canvas.toDataURL('image/png');
        pageImages.push(dataUrl);

        // Append page card
        const card = document.createElement('div');
        card.className = 'bg-canvas-soft border border-hairline rounded-sm p-4 flex flex-col gap-4 shadow-level-1 hover:shadow-level-2 transition-all';
        
        card.innerHTML = `
          <div class="flex justify-between items-center select-none">
            <span class="font-mono text-xs font-semibold text-ink">Page ${pageNum}</span>
            <span class="font-mono text-[9px] text-mute uppercase bg-canvas border border-hairline px-1.5 py-0.5 rounded-sm">${viewport.width} × ${viewport.height} px</span>
          </div>
          <div class="bg-canvas border border-hairline rounded-sm h-64 flex items-center justify-center p-2 overflow-hidden">
            <img src="${dataUrl}" class="max-h-full max-w-full object-contain" alt="Page ${pageNum}" />
          </div>
          <button data-index="${pageNum - 1}" class="download-page-btn w-full bg-canvas border border-hairline hover:border-hairline-strong text-ink hover:bg-canvas-soft-2 text-xs font-semibold py-2 rounded-pill flex items-center justify-center gap-1.5 transition-all shadow-level-1">
            <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M7 10l5 5 5-5M12 15V3"/></svg>
            Download PNG
          </button>
        `;
        pagesContainer.appendChild(card);
      }

      // Hook up download handlers
      document.querySelectorAll('.download-page-btn').forEach(btn => {
        btn.addEventListener('click', (e) => {
          const target = e.currentTarget as HTMLElement;
          const index = parseInt(target.dataset.index || '0');
          downloadPage(index);
        });
      });

      loadingSpinner?.classList.add('hidden');
      pagesContainer?.classList.remove('hidden');
      if (renderedCountText) renderedCountText.innerText = `${numPages} pages extracted`;

    } catch (err) {
      console.error('Error rendering PDF pages:', err);
      alert('Could not render PDF document pages.');
      loadingSpinner?.classList.add('hidden');
    }
  }

  async function downloadPage(index: number) {
    if (!activeFile || index < 0 || index >= pageImages.length) return;
    
    const cleanName = activeFile.name.substring(0, activeFile.name.lastIndexOf('.')) || activeFile.name;
    const downloadName = `${cleanName}-page-${index + 1}.png`;

    const link = document.createElement('a');
    link.href = pageImages[index];
    link.download = downloadName;
    document.body.appendChild(link);
    link.click();
    document.body.removeChild(link);

    // Save to IndexedDB
    try {
      const response = await fetch(pageImages[index]);
      const blob = await response.blob();
      await addProcessedFile(downloadName, 'image/png', blob.size, 'pdf-to-image', blob);
    } catch (err) {
      console.error('Failed to save extracted page image to history:', err);
    }
  }

  resetBtn?.addEventListener('click', () => {
    activeFile = null;
    pageImages = [];
    fileInput.value = '';
    
    workspace?.classList.add('hidden');
    uploadZone?.classList.remove('hidden');
  });

  // Check for editId on load
  window.addEventListener('load', async () => {
    const urlParams = new URLSearchParams(window.location.search);
    const editId = urlParams.get('editId');
    if (editId) {
      const record = await getProcessedFile(parseInt(editId));
      if (record) {
        if (record.type.startsWith('image/')) {
          window.location.href = `/tools/image-resize?editId=${editId}`;
        } else {
          const file = new File([record.blob], record.name, { type: record.type });
          handleFile(file);
        }
      }
    }
  });

  function formatBytes(bytes: number, decimals = 2) {
    if (bytes === 0) return '0 Bytes';
    const k = 1024;
    const dm = decimals < 0 ? 0 : decimals;
    const sizes = ['Bytes', 'KB', 'MB', 'GB'];
    const i = Math.floor(Math.log(bytes) / Math.log(k));
    return parseFloat((bytes / Math.pow(k, i)).toFixed(dm)) + ' ' + sizes[i];
  }
</script>
