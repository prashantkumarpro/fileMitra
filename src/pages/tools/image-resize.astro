---
import ToolLayout from '../../layouts/ToolLayout.astro';
import { Upload, Download, RefreshCw, Maximize2 } from 'lucide-astro';
---

<ToolLayout
  title="Resize Image"
  description="Scale your images to custom dimensions (pixels or percentage). Lock aspect ratios and convert format completely client-side."
  activeTool="image-resize"
>
  <div class="flex-grow flex flex-col gap-6">
    
    <!-- Drag & Drop Upload Zone -->
    <div
      id="upload-zone"
      class="border-2 border-dashed border-hairline hover:border-hairline-strong bg-canvas rounded-lg p-16 flex flex-col items-center justify-center text-center cursor-pointer transition-all duration-200 shadow-level-2 select-none group"
    >
      <input type="file" id="file-input" accept="image/png, image/jpeg, image/webp" class="hidden" />
      <span class="p-4 bg-canvas-soft rounded-full text-mute group-hover:text-primary border border-hairline mb-4 transition-colors">
        <Upload class="w-6 h-6 animate-pulse" />
      </span>
      <h3 class="text-ink font-semibold text-lg mb-1">Drag and drop your image to resize</h3>
      <p class="text-mute text-xs max-w-xs mb-4">
        Supports PNG, JPEG, and WebP formats. Files stay completely in your browser memory.
      </p>
      <button class="bg-primary text-on-primary hover:bg-primary/95 text-xs font-semibold px-4 py-2 rounded-pill shadow-level-2 transition-all">
        Select File
      </button>
    </div>

    <!-- Active Workspace Area -->
    <div id="workspace" class="hidden grid grid-cols-1 lg:grid-cols-3 gap-6 items-start animate-in fade-in duration-200">
      
      <!-- Controls Panel (1 column) -->
      <div class="flex flex-col gap-6 lg:col-span-1">
        <div class="bg-canvas border border-hairline rounded-md p-6 shadow-level-3 flex flex-col gap-6">
          <h3 class="font-sans font-semibold text-sm text-ink pb-3 border-b border-hairline select-none flex items-center gap-1.5">
            <Maximize2 class="w-4 h-4 text-mute" />
            Resize Controls
          </h3>

          <!-- Dimensions Config -->
          <div class="flex flex-col gap-4">
            <div class="grid grid-cols-2 gap-4">
              <div class="flex flex-col gap-1.5">
                <label for="width-input" class="font-medium text-xs text-ink select-none font-sans">Width (px)</label>
                <input
                  type="number"
                  id="width-input"
                  min="1"
                  class="bg-canvas text-ink border border-hairline focus:border-hairline-strong text-xs rounded-sm px-2.5 h-9 outline-none transition-all shadow-level-1"
                />
              </div>
              <div class="flex flex-col gap-1.5">
                <label for="height-input" class="font-medium text-xs text-ink select-none font-sans">Height (px)</label>
                <input
                  type="number"
                  id="height-input"
                  min="1"
                  class="bg-canvas text-ink border border-hairline focus:border-hairline-strong text-xs rounded-sm px-2.5 h-9 outline-none transition-all shadow-level-1"
                />
              </div>
            </div>

            <!-- Lock Aspect Ratio -->
            <label class="flex items-center gap-2 text-xs text-body cursor-pointer select-none">
              <input
                type="checkbox"
                id="aspect-ratio-lock"
                checked
                class="rounded-sm border-hairline text-primary focus:ring-primary/20 w-4 h-4 cursor-pointer"
              />
              Lock Aspect Ratio
            </label>
          </div>

          <!-- Format conversion option -->
          <div class="flex flex-col gap-2">
            <label for="format-select" class="font-medium text-xs text-ink select-none">Output Format</label>
            <select
              id="format-select"
              class="w-full bg-canvas text-ink border border-hairline focus:border-hairline-strong text-xs rounded-sm px-2.5 h-9 outline-none transition-all shadow-level-1 cursor-pointer"
            >
              <option value="original">Keep Original Format</option>
              <option value="image/jpeg">JPEG (.jpg)</option>
              <option value="image/png">PNG (.png)</option>
              <option value="image/webp">WebP (.webp)</option>
            </select>
          </div>

          <!-- Stats Block -->
          <div class="bg-canvas-soft border border-hairline rounded-sm p-4 flex flex-col gap-2.5 text-xs text-body">
            <span class="font-mono text-[10px] text-mute uppercase font-semibold select-none">Scaling Diagnostics</span>
            <div class="flex justify-between">
              <span>Original size:</span>
              <span id="original-specs" class="font-mono text-ink">0 × 0 px</span>
            </div>
            <div class="flex justify-between">
              <span>Resized size:</span>
              <span id="resized-specs" class="font-mono text-ink font-semibold">0 × 0 px</span>
            </div>
          </div>

          <!-- Action targets -->
          <div class="flex flex-col gap-2">
            <button id="download-btn" class="bg-primary text-on-primary hover:bg-primary/95 text-xs font-semibold h-10 rounded-pill flex items-center justify-center gap-1.5 transition-all shadow-level-3">
              <Download class="w-4 h-4" />
              Resize & Download
            </button>
            <button id="reset-btn" class="bg-canvas border border-hairline hover:bg-canvas-soft text-ink text-xs font-semibold h-10 rounded-pill flex items-center justify-center gap-1.5 transition-all shadow-level-1">
              <RefreshCw class="w-3.5 h-3.5" />
              Reset Workspace
            </button>
          </div>
        </div>
      </div>

      <!-- Preview Workspace (2 columns) -->
      <div class="flex flex-col gap-6 lg:col-span-2">
        <div class="bg-canvas border border-hairline rounded-md p-6 shadow-level-3 flex flex-col gap-4">
          <div class="flex items-center justify-between select-none">
            <h3 class="font-sans font-semibold text-sm text-ink">Interactive Scale Preview</h3>
            <span id="scale-indicator" class="font-mono text-[10px] text-mute uppercase">Scaling ratio: 100%</span>
          </div>

          <div class="border border-hairline bg-canvas-soft-2 rounded-sm h-[380px] overflow-hidden flex items-center justify-center p-4 relative">
            <img id="img-preview" class="max-h-full max-w-full object-contain" alt="Workspace Resize Target" />
          </div>
        </div>
      </div>

    </div>

  </div>
</ToolLayout>

<script>
  const uploadZone = document.getElementById('upload-zone');
  const fileInput = document.getElementById('file-input') as HTMLInputElement;
  const workspace = document.getElementById('workspace');
  
  const widthInput = document.getElementById('width-input') as HTMLInputElement;
  const heightInput = document.getElementById('height-input') as HTMLInputElement;
  const aspectRatioLock = document.getElementById('aspect-ratio-lock') as HTMLInputElement;
  const formatSelect = document.getElementById('format-select') as HTMLSelectElement;
  
  const originalSpecs = document.getElementById('original-specs');
  const resizedSpecs = document.getElementById('resized-specs');
  const scaleIndicator = document.getElementById('scale-indicator');
  const imgPreview = document.getElementById('img-preview') as HTMLImageElement;
  
  const downloadBtn = document.getElementById('download-btn');
  const resetBtn = document.getElementById('reset-btn');

  let activeFile: File | null = null;
  let sourceImage = new Image();
  let originalRatio = 1;

  // Bind drop / selection trigger
  uploadZone?.addEventListener('click', () => fileInput.click());

  uploadZone?.addEventListener('dragover', (e) => {
    e.preventDefault();
    uploadZone.classList.add('border-primary', 'bg-canvas-soft');
  });

  uploadZone?.addEventListener('dragleave', () => {
    uploadZone.classList.remove('border-primary', 'bg-canvas-soft');
  });

  uploadZone?.addEventListener('drop', (e) => {
    e.preventDefault();
    uploadZone.classList.remove('border-primary', 'bg-canvas-soft');
    if (e.dataTransfer?.files && e.dataTransfer.files.length > 0) {
      handleFileSelection(e.dataTransfer.files[0]);
    }
  });

  fileInput?.addEventListener('change', () => {
    if (fileInput.files && fileInput.files.length > 0) {
      handleFileSelection(fileInput.files[0]);
    }
  });

  function handleFileSelection(file: File) {
    if (!file.type.startsWith('image/')) {
      alert('Please upload an image file.');
      return;
    }
    activeFile = file;

    // Show workspace
    uploadZone?.classList.add('hidden');
    workspace?.classList.remove('hidden');

    const reader = new FileReader();
    reader.onload = (e) => {
      const dataUrl = e.target?.result as string;
      imgPreview.src = dataUrl;

      sourceImage.onload = () => {
        // Load initial widths/heights
        widthInput.value = sourceImage.width.toString();
        heightInput.value = sourceImage.height.toString();
        originalRatio = sourceImage.width / sourceImage.height;

        if (originalSpecs) {
          originalSpecs.innerText = `${sourceImage.width} × ${sourceImage.height} px`;
        }
        updateDiagnostics();
      };
      sourceImage.src = dataUrl;
    };
    reader.readAsDataURL(file);
  }

  function updateDiagnostics() {
    const w = parseInt(widthInput.value) || 0;
    const h = parseInt(heightInput.value) || 0;
    
    if (resizedSpecs) {
      resizedSpecs.innerText = `${w} × ${h} px`;
    }

    if (sourceImage.width > 0 && scaleIndicator) {
      const ratio = Math.round((w / sourceImage.width) * 100);
      scaleIndicator.innerText = `Scaling ratio: ${ratio}%`;
    }
  }

  // Width dimension changes
  widthInput?.addEventListener('input', () => {
    const w = parseInt(widthInput.value) || 0;
    if (aspectRatioLock.checked && w > 0 && originalRatio > 0) {
      heightInput.value = Math.round(w / originalRatio).toString();
    }
    updateDiagnostics();
  });

  // Height dimension changes
  heightInput?.addEventListener('input', () => {
    const h = parseInt(heightInput.value) || 0;
    if (aspectRatioLock.checked && h > 0 && originalRatio > 0) {
      widthInput.value = Math.round(h * originalRatio).toString();
    }
    updateDiagnostics();
  });

  // Download Trigger
  downloadBtn?.addEventListener('click', () => {
    if (!activeFile || !sourceImage.src) return;

    const w = parseInt(widthInput.value) || 0;
    const h = parseInt(heightInput.value) || 0;

    if (w <= 0 || h <= 0) {
      alert('Width and height must be greater than 0.');
      return;
    }

    // Perform canvas resize
    const canvas = document.createElement('canvas');
    canvas.width = w;
    canvas.height = h;

    const ctx = canvas.getContext('2d');
    if (!ctx) return;
    ctx.drawImage(sourceImage, 0, 0, w, h);

    // Mimetype config
    let mimeType = formatSelect.value;
    if (mimeType === 'original') mimeType = activeFile.type;
    const ext = mimeType.split('/')[1];

    const cleanName = activeFile.name.substring(0, activeFile.name.lastIndexOf('.')) || activeFile.name;
    const downloadName = `${cleanName}-${w}x${h}.${ext}`;

    const dataUrl = canvas.toDataURL(mimeType);

    const link = document.createElement('a');
    link.href = dataUrl;
    link.download = downloadName;
    document.body.appendChild(link);
    link.click();
    document.body.removeChild(link);
  });

  // Reset page
  resetBtn?.addEventListener('click', () => {
    activeFile = null;
    fileInput.value = '';
    
    workspace?.classList.add('hidden');
    uploadZone?.classList.remove('hidden');
    
    imgPreview.removeAttribute('src');
  });
</script>
