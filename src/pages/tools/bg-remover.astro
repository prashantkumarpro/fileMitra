---
import ToolLayout from '../../layouts/ToolLayout.astro';
import { Upload, Download, RefreshCw, Layers, FileImage, Sparkles, Compass, Check, Trash2, Sliders, Type, Wand2 } from 'lucide-astro';
---

<ToolLayout
  title="Portrait & Image Design Studio"
  description="Remove background instantly with AI, apply lighting and color adjustments, add styled text overlays, and touch up with manual brushes."
  activeTool="bg-remover"
>
  <div class="flex-grow flex flex-col gap-6 font-sans">
    
    <!-- Drag & Drop Upload Zone -->
    <div
      id="upload-zone"
      class="border-2 border-dashed border-hairline hover:border-hairline-strong bg-canvas rounded-lg p-16 flex flex-col items-center justify-center text-center cursor-pointer transition-all duration-200 shadow-level-2 select-none group"
    >
      <input type="file" id="file-input" accept="image/png, image/jpeg, image/webp" class="hidden" />
      <span class="p-4 bg-canvas-soft rounded-full text-mute group-hover:text-primary border border-hairline mb-4 transition-colors">
        <Upload class="w-6 h-6 animate-pulse" />
      </span>
      <h3 class="text-ink font-semibold text-lg mb-1">Upload portrait image</h3>
      <p class="text-mute text-xs max-w-xs mb-4">
        Supports PNG, JPEG, and WebP. Processed 100% locally.
      </p>
      <button class="bg-primary text-on-primary hover:bg-primary/95 text-xs font-semibold px-4 py-2 rounded-pill shadow-level-2 transition-all cursor-pointer">
        Select File
      </button>
    </div>

    <!-- Active Workspace Area -->
    <div id="workspace" class="hidden grid grid-cols-1 lg:grid-cols-3 gap-6 items-start animate-in fade-in duration-200">
      
      <!-- Side panel: Configurations (1 column) -->
      <div class="flex flex-col gap-4 lg:col-span-1 max-h-[85vh] overflow-y-auto pr-1 order-2 lg:order-1">
        
        <!-- Sidebar Navigation Tabs -->
        <div class="flex overflow-x-auto scrollbar-none bg-canvas-soft-2 border border-hairline rounded-sm p-0.5 select-none shadow-level-1 gap-0.5 w-full">
          <button id="sidebar-tab-cutout" class="sidebar-config-tab flex-1 min-w-[56px] text-center py-2 rounded-sm text-[9.5px] font-semibold text-ink bg-canvas shadow-level-1 transition-all active:scale-[0.97] cursor-pointer flex flex-col items-center gap-0.5" data-tab="cutout">
            <Sparkles class="w-3.5 h-3.5 text-violet" />
            <span>Cutout</span>
          </button>
          <button id="sidebar-tab-backdrop" class="sidebar-config-tab flex-1 min-w-[56px] text-center py-2 rounded-sm text-[9.5px] font-semibold text-body hover:text-ink transition-all active:scale-[0.97] cursor-pointer flex flex-col items-center gap-0.5" data-tab="backdrop">
            <Layers class="w-3.5 h-3.5" />
            <span>Backdrop</span>
          </button>
          <button id="sidebar-tab-refine" class="sidebar-config-tab flex-1 min-w-[56px] text-center py-2 rounded-sm text-[9.5px] font-semibold text-body hover:text-ink transition-all active:scale-[0.97] cursor-pointer flex flex-col items-center gap-0.5" data-tab="refine">
            <Sliders class="w-3.5 h-3.5" />
            <span>Brush</span>
          </button>
          <button id="sidebar-tab-adjust" class="sidebar-config-tab flex-1 min-w-[56px] text-center py-2 rounded-sm text-[9.5px] font-semibold text-body hover:text-ink transition-all active:scale-[0.97] cursor-pointer flex flex-col items-center gap-0.5" data-tab="adjust">
            <Wand2 class="w-3.5 h-3.5" />
            <span>Adjust</span>
          </button>
          <button id="sidebar-tab-text" class="sidebar-config-tab flex-1 min-w-[56px] text-center py-2 rounded-sm text-[9.5px] font-semibold text-body hover:text-ink transition-all active:scale-[0.97] cursor-pointer flex flex-col items-center gap-0.5" data-tab="text">
            <Type class="w-3.5 h-3.5" />
            <span>Text</span>
          </button>
          <button id="sidebar-tab-size" class="sidebar-config-tab flex-1 min-w-[56px] text-center py-2 rounded-sm text-[9.5px] font-semibold text-body hover:text-ink transition-all active:scale-[0.97] cursor-pointer flex flex-col items-center gap-0.5" data-tab="size">
            <Compass class="w-3.5 h-3.5" />
            <span>Crop/Size</span>
          </button>
        </div>

        <!-- 1. Background Removal Controls (Cutout Tab) -->
        <div id="config-section-cutout" class="bg-canvas border border-hairline rounded-md p-5 shadow-level-3 flex flex-col gap-4">
          <h3 class="font-sans font-semibold text-xs text-ink pb-2.5 border-b border-hairline select-none flex items-center gap-1.5 uppercase tracking-wider">
            <Sparkles class="w-3.5 h-3.5 text-mute" />
            1. Background Removal
          </h3>

          <div class="flex flex-col gap-2">
            <button id="ai-remove-bg-btn" class="w-full bg-primary text-on-primary hover:bg-primary/95 text-xs font-semibold py-2.5 rounded-sm flex items-center justify-center gap-1.5 transition-all active:scale-[0.98] cursor-pointer shadow-level-3">
              <Sparkles class="w-3.5 h-3.5 text-violet animate-pulse" />
              <span>Remove Background with AI (Fast)</span>
            </button>
            <div id="ai-remove-loading" class="hidden flex-col items-center gap-1.5 py-3 border border-dashed border-violet-soft/30 bg-violet-soft/10 text-violet rounded-sm select-none">
              <span class="animate-spin"><RefreshCw class="w-4 h-4" /></span>
              <span id="ai-remove-loading-text" class="text-[10px] font-mono text-center px-2">AI is removing background...</span>
            </div>
          </div>
        </div>

        <!-- 2. Manual Touch-up Brush (Refine Tab) -->
        <div id="config-section-refine" class="bg-canvas border border-hairline rounded-md p-5 shadow-level-3 flex flex-col gap-4 hidden">
          <h3 class="font-sans font-semibold text-xs text-ink pb-2.5 border-b border-hairline select-none flex items-center gap-1.5 uppercase tracking-wider">
            <Sliders class="w-3.5 h-3.5 text-mute" />
            2. Brush Touch-Up
          </h3>
          
          <div class="flex flex-col gap-2.5">
            <span class="text-xs font-medium text-ink select-none">Manual Touch-up Brush</span>
            
            <div class="grid grid-cols-3 gap-1.5">
              <button data-brush="none" class="brush-tab px-2 py-1.5 rounded-sm text-[10px] font-semibold text-ink bg-canvas border border-hairline-strong transition-all active:scale-95 cursor-pointer text-center">
                None (Pan)
              </button>
              <button data-brush="erase" class="brush-tab px-2 py-1.5 rounded-sm text-[10px] font-semibold text-body hover:text-ink bg-canvas border border-hairline transition-all active:scale-95 cursor-pointer text-center">
                Erase BG
              </button>
              <button data-brush="restore" class="brush-tab px-2 py-1.5 rounded-sm text-[10px] font-semibold text-body hover:text-ink bg-canvas border border-hairline transition-all active:scale-95 cursor-pointer text-center">
                Restore
              </button>
            </div>

            <!-- Brush Size Slider -->
            <div class="flex flex-col gap-1.5">
              <div class="flex justify-between text-[10px] font-medium select-none">
                <span class="text-body">Brush Size</span>
                <span id="brush-size-val" class="font-mono text-mute">30px</span>
              </div>
              <input type="range" id="brush-size-slider" min="5" max="100" value="30" class="w-full h-1 bg-canvas-soft-2 rounded-lg appearance-none cursor-pointer accent-primary border border-hairline" />
            </div>

            <button id="clear-mask-btn" class="text-[10px] text-mute hover:text-ink font-semibold flex items-center justify-center gap-1 select-none self-end cursor-pointer">
              <RefreshCw class="w-2.5 h-2.5" /> Clear Manual Brush Marks
            </button>
          </div>
        </div>

        <!-- 4. Adjustments & Filters Panel (Adjust Tab) -->
        <div id="config-section-adjust" class="bg-canvas border border-hairline rounded-md p-5 shadow-level-3 flex flex-col gap-4 hidden">
          <h3 class="font-sans font-semibold text-xs text-ink pb-2.5 border-b border-hairline select-none flex items-center gap-1.5 uppercase tracking-wider">
            <Wand2 class="w-3.5 h-3.5 text-mute" />
            4. Adjust & Enhance
          </h3>

          <!-- Magic Auto-Enhance Switch -->
          <div class="flex items-center justify-between bg-canvas-soft-2 p-3 rounded-sm border border-hairline">
            <div class="flex flex-col">
              <span class="text-xs font-semibold text-ink">Magic Auto-Enhance</span>
              <span class="text-[10px] text-mute">Instant portrait lighting boost</span>
            </div>
            <label class="relative inline-flex items-center cursor-pointer select-none">
              <input type="checkbox" id="magic-enhance-toggle" class="sr-only peer" />
              <div class="w-8 h-4 bg-canvas border border-hairline-strong rounded-full peer peer-focus:ring-0 peer-checked:after:translate-x-full after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-mute peer-checked:after:bg-primary after:border-hairline after:border after:rounded-full after:h-3 after:w-3 after:transition-all peer-checked:bg-primary/10 peer-checked:border-primary"></div>
            </label>
          </div>

          <!-- Adjustments sliders -->
          <div class="flex flex-col gap-3">
            <!-- Brightness -->
            <div class="flex flex-col gap-1.5">
              <div class="flex justify-between text-[10px] font-medium select-none">
                <span class="text-body">Brightness</span>
                <span id="brightness-val" class="font-mono text-mute">100%</span>
              </div>
              <input type="range" id="brightness-slider" min="50" max="150" value="100" class="w-full h-1 bg-canvas-soft-2 rounded-lg appearance-none cursor-pointer accent-primary border border-hairline" />
            </div>

            <!-- Contrast -->
            <div class="flex flex-col gap-1.5">
              <div class="flex justify-between text-[10px] font-medium select-none">
                <span class="text-body">Contrast</span>
                <span id="contrast-val" class="font-mono text-mute">100%</span>
              </div>
              <input type="range" id="contrast-slider" min="50" max="150" value="100" class="w-full h-1 bg-canvas-soft-2 rounded-lg appearance-none cursor-pointer accent-primary border border-hairline" />
            </div>

            <!-- Saturation -->
            <div class="flex flex-col gap-1.5">
              <div class="flex justify-between text-[10px] font-medium select-none">
                <span class="text-body">Saturation</span>
                <span id="saturation-val" class="font-mono text-mute">100%</span>
              </div>
              <input type="range" id="saturation-slider" min="0" max="200" value="100" class="w-full h-1 bg-canvas-soft-2 rounded-lg appearance-none cursor-pointer accent-primary border border-hairline" />
            </div>

            <!-- Blur -->
            <div class="flex flex-col gap-1.5">
              <div class="flex justify-between text-[10px] font-medium select-none">
                <span class="text-body">Blur</span>
                <span id="blur-val" class="font-mono text-mute">0px</span>
              </div>
              <input type="range" id="blur-slider" min="0" max="20" value="0" class="w-full h-1 bg-canvas-soft-2 rounded-lg appearance-none cursor-pointer accent-primary border border-hairline" />
            </div>
          </div>
        </div>

        <!-- 5. Text Overlays (Text Tab) -->
        <div id="config-section-text" class="bg-canvas border border-hairline rounded-md p-5 shadow-level-3 flex flex-col gap-4 hidden">
          <h3 class="font-sans font-semibold text-xs text-ink pb-2.5 border-b border-hairline select-none flex items-center gap-1.5 uppercase tracking-wider">
            <Type class="w-3.5 h-3.5 text-mute" />
            5. Text Overlays
          </h3>

          <div class="flex flex-col gap-3">
            <button id="add-text-btn" class="w-full bg-primary text-on-primary hover:bg-primary/95 text-xs font-semibold py-2.5 rounded-sm flex items-center justify-center gap-1.5 transition-all active:scale-[0.98] cursor-pointer shadow-level-3">
              <Type class="w-3.5 h-3.5" />
              <span>Add Styled Text</span>
            </button>

            <!-- Text Settings Editor (shown when a text layer is selected) -->
            <div id="text-editor-container" class="hidden flex flex-col gap-3 border-t border-hairline pt-3 mt-1">
              <div class="flex flex-col gap-1.5">
                <label for="text-content-input" class="font-medium text-[10px] text-ink select-none font-sans">Text Content</label>
                <input
                  type="text"
                  id="text-content-input"
                  placeholder="Enter text..."
                  class="bg-canvas text-ink border border-hairline focus:border-hairline-strong text-xs rounded-sm px-2.5 h-8.5 outline-none transition-all shadow-level-1"
                />
              </div>

              <div class="grid grid-cols-2 gap-3">
                <div class="flex flex-col gap-1">
                  <label for="text-font-family" class="font-medium text-[10px] text-ink select-none font-sans">Font Family</label>
                  <select
                    id="text-font-family"
                    class="bg-canvas text-ink border border-hairline focus:border-hairline-strong text-xs rounded-sm px-2.5 h-8.5 outline-none transition-all cursor-pointer"
                  >
                    <option value="sans-serif">Sans-Serif</option>
                    <option value="serif">Serif</option>
                    <option value="'Outfit', sans-serif">Outfit</option>
                    <option value="'Fira Mono', monospace">Fira Mono</option>
                    <option value="'Playfair Display', serif">Playfair</option>
                  </select>
                </div>

                <div class="flex flex-col gap-1">
                  <label for="text-color-picker" class="font-medium text-[10px] text-ink select-none font-sans font-semibold">Color</label>
                  <div class="flex items-center gap-1.5">
                    <input
                      type="color"
                      id="text-color-picker"
                      class="w-8 h-8 bg-transparent border-0 cursor-pointer p-0"
                    />
                    <input
                      type="text"
                      id="text-color-hex"
                      value="#ffffff"
                      placeholder="#ffffff"
                      class="w-full bg-canvas text-ink border border-hairline focus:border-hairline-strong text-[10px] rounded-sm px-1.5 h-8 outline-none transition-all shadow-level-1 font-mono"
                    />
                  </div>
                </div>
              </div>

              <div class="flex flex-col gap-1">
                <div class="flex justify-between text-[10px] font-medium select-none">
                  <span class="text-body">Font Size</span>
                  <span id="text-size-val" class="font-mono text-mute">24px</span>
                </div>
                <input type="range" id="text-size-slider" min="10" max="120" value="24" class="w-full h-1 bg-canvas-soft-2 rounded-lg appearance-none cursor-pointer accent-primary border border-hairline" />
              </div>

              <!-- Font Styles -->
              <div class="flex items-center gap-2 pt-1">
                <button id="text-bold-btn" class="flex-1 bg-canvas border border-hairline hover:border-hairline-strong hover:bg-canvas-soft text-ink text-xs font-semibold py-1.5 rounded-sm transition-all active:scale-[0.98] cursor-pointer">Bold</button>
                <button id="text-italic-btn" class="flex-1 bg-canvas border border-hairline hover:border-hairline-strong hover:bg-canvas-soft text-ink text-xs font-semibold py-1.5 rounded-sm transition-all active:scale-[0.98] cursor-pointer font-serif italic">Italic</button>
                <button id="delete-text-btn" class="px-2.5 bg-canvas border border-hairline hover:bg-error-soft hover:text-error hover:border-error-soft text-mute py-1.5 rounded-sm transition-all cursor-pointer" title="Delete Text">
                  <Trash2 class="w-3.5 h-3.5" />
                </button>
              </div>
              <span class="text-[9px] text-mute select-none text-center pt-1 font-sans">
                Drag text directly on canvas to reposition
              </span>
            </div>
            
            <div id="no-text-selected-msg" class="text-[10px] text-mute text-center py-4 border border-dashed border-hairline bg-canvas-soft-2 rounded-sm select-none">
              No text layer active. Click "Add Styled Text" or click text on canvas.
            </div>
          </div>
        </div>

        <!-- 3. Background Replacement Panel (Backdrop Tab) -->
        <div id="config-section-backdrop" class="bg-canvas border border-hairline rounded-md p-5 shadow-level-3 flex flex-col gap-4 hidden">
          <h3 class="font-sans font-semibold text-xs text-ink pb-2.5 border-b border-hairline select-none flex items-center gap-1.5 uppercase tracking-wider">
            <Layers class="w-3.5 h-3.5 text-mute" />
            3. New Background
          </h3>

          <!-- Solid Colors Grid -->
          <div class="flex flex-col gap-2">
            <span class="text-[11px] font-medium text-body select-none">Passport Solid Colors</span>
            <div class="grid grid-cols-8 gap-2">
              <button class="bg-color-btn w-6 h-6 rounded-sm border border-hairline-strong cursor-pointer active:scale-90 transition-transform" data-color="#ffffff" style="background-color: #ffffff;" title="White"></button>
              <button class="bg-color-btn w-6 h-6 rounded-sm border border-hairline cursor-pointer active:scale-90 transition-transform" data-color="#f2f2f2" style="background-color: #f2f2f2;" title="Off-White"></button>
              <button class="bg-color-btn w-6 h-6 rounded-sm border border-hairline cursor-pointer active:scale-90 transition-transform" data-color="#a4c2f4" style="background-color: #a4c2f4;" title="Light Blue (Passport)"></button>
              <button class="bg-color-btn w-6 h-6 rounded-sm border border-hairline cursor-pointer active:scale-90 transition-transform" data-color="#0033aa" style="background-color: #0033aa;" title="Royal Blue (Passport)"></button>
              <button class="bg-color-btn w-6 h-6 rounded-sm border border-hairline cursor-pointer active:scale-90 transition-transform" data-color="#d9d9d9" style="background-color: #d9d9d9;" title="Light Gray"></button>
              <button class="bg-color-btn w-6 h-6 rounded-sm border border-hairline cursor-pointer active:scale-90 transition-transform" data-color="#ff0000" style="background-color: #ff0000;" title="Red"></button>
              <button class="bg-color-btn w-6 h-6 rounded-sm border border-hairline cursor-pointer active:scale-90 transition-transform" data-color="#0b172a" style="background-color: #0b172a;" title="Dark Blue"></button>
              <button class="bg-color-btn w-6 h-6 rounded-sm border border-hairline cursor-pointer active:scale-90 transition-transform" data-color="transparent" style="background: repeating-conic-gradient(#f0f0f0 0% 25%, #ffffff 0% 50%) 50% / 8px 8px;" title="Transparent"></button>
            </div>
          </div>

          <!-- Gradient Presets -->
          <div class="flex flex-col gap-2 pt-2 border-t border-hairline">
            <span class="text-[11px] font-medium text-body select-none">Studio Gradients</span>
            <div class="grid grid-cols-4 gap-2">
              <button class="bg-grad-btn h-6 rounded-sm border border-hairline cursor-pointer active:scale-90 transition-transform" data-grad="blue-pink" style="background: linear-gradient(135deg, #d3e5ff 0%, #ffd3e5 100%);" title="Blue Pink"></button>
              <button class="bg-grad-btn h-6 rounded-sm border border-hairline cursor-pointer active:scale-90 transition-transform" data-grad="sunset" style="background: linear-gradient(135deg, #ffe5cf 0%, #ffcfd3 100%);" title="Sunset"></button>
              <button class="bg-grad-btn h-6 rounded-sm border border-hairline cursor-pointer active:scale-90 transition-transform" data-grad="mesh" style="background: linear-gradient(135deg, #50e3c2 0%, #7928ca 100%);" title="Mesh"></button>
              <button class="bg-grad-btn h-6 rounded-sm border border-hairline cursor-pointer active:scale-90 transition-transform" data-grad="monochrome" style="background: linear-gradient(135deg, #ebebeb 0%, #a1a1a1 100%);" title="Monochrome"></button>
            </div>
          </div>

          <!-- Custom Image BG -->
          <div class="flex flex-col gap-2 pt-2 border-t border-hairline">
            <label class="text-[11px] font-medium text-body select-none">Custom Background Image</label>
            <input type="file" id="bg-file-input" accept="image/*" class="hidden" />
            <button id="bg-upload-btn" class="w-full bg-canvas border border-hairline hover:border-hairline-strong text-ink text-xs font-semibold py-2 rounded-sm flex items-center justify-center gap-1.5 transition-all active:scale-[0.98] cursor-pointer">
              <FileImage class="w-3.5 h-3.5 text-mute" />
              <span>Upload Custom Backdrop</span>
            </button>
          </div>
        </div>

        <!-- 4. Passport Guide & Position (Size Tab) -->
        <div id="config-section-size" class="bg-canvas border border-hairline rounded-md p-5 shadow-level-3 flex flex-col gap-4 hidden">
          <h3 class="font-sans font-semibold text-xs text-ink pb-2.5 border-b border-hairline select-none flex items-center gap-1.5 uppercase tracking-wider">
            <Compass class="w-3.5 h-3.5 text-mute" />
            4. Size & Position
          </h3>

          <!-- Passport Sizes -->
          <div class="flex flex-col gap-1.5">
            <label for="passport-size-select" class="font-medium text-[11px] text-ink select-none">Size / Aspect Ratio</label>
            <select
              id="passport-size-select"
              class="w-full bg-canvas text-ink border border-hairline focus:border-hairline-strong text-xs rounded-sm px-2.5 h-8.5 outline-none transition-all cursor-pointer"
            >
              <option value="custom" selected>No Crop (Fit Original Ratio)</option>
              <option value="custom_dimensions">Custom Dimensions</option>
              <option value="us">US Passport (2" x 2" / 1:1)</option>
              <option value="india">India / UK / EU (3.5 x 4.5 cm / 7:9)</option>
              <option value="china">China Passport (3.3 x 4.8 cm / 11:16)</option>
            </select>
          </div>

          <!-- Custom Size Inputs -->
          <div id="custom-size-inputs" class="hidden flex flex-col gap-2 pt-1">
            <div class="grid grid-cols-2 gap-3">
              <div class="flex flex-col gap-1">
                <label for="custom-width" class="font-medium text-[10px] text-ink select-none font-sans">Width (px)</label>
                <input
                  type="number"
                  id="custom-width"
                  placeholder="e.g. 800"
                  min="10"
                  class="bg-canvas text-ink border border-hairline focus:border-hairline-strong text-xs rounded-sm px-2.5 h-8.5 outline-none transition-all shadow-level-1"
                />
              </div>
              <div class="flex flex-col gap-1">
                <label for="custom-height" class="font-medium text-[10px] text-ink select-none font-sans">Height (px)</label>
                <input
                  type="number"
                  id="custom-height"
                  placeholder="e.g. 600"
                  min="10"
                  class="bg-canvas text-ink border border-hairline focus:border-hairline-strong text-xs rounded-sm px-2.5 h-8.5 outline-none transition-all shadow-level-1"
                />
              </div>
            </div>
          </div>

          <!-- Toggle Guides -->
          <label class="flex items-center gap-2 text-xs text-body cursor-pointer select-none">
            <input
              type="checkbox"
              id="guide-toggle"
              checked
              class="rounded-sm border-hairline text-primary focus:ring-primary/20 w-4 h-4 cursor-pointer"
            />
            Show Face Alignment Overlay
          </label>

          <!-- Position adjustments -->
          <div class="flex flex-col gap-3 pt-2 border-t border-hairline">
            <!-- Zoom -->
            <div class="flex flex-col gap-1">
              <div class="flex justify-between text-[10px] font-medium select-none">
                <span class="text-body">Zoom / Scale</span>
                <span id="zoom-val" class="font-mono text-mute">1.0x</span>
              </div>
              <input type="range" id="zoom-slider" min="0.5" max="4.0" step="0.05" value="1.0" class="w-full h-1 bg-canvas-soft-2 rounded-lg appearance-none cursor-pointer accent-primary border border-hairline" />
            </div>

            <!-- X Offset -->
            <div class="flex flex-col gap-1">
              <div class="flex justify-between text-[10px] font-medium select-none">
                <span class="text-body">Move Horizontal (X)</span>
                <span id="offset-x-val" class="font-mono text-mute">0px</span>
              </div>
              <input type="range" id="offset-x-slider" min="-300" max="300" step="2" value="0" class="w-full h-1 bg-canvas-soft-2 rounded-lg appearance-none cursor-pointer accent-primary border border-hairline" />
            </div>

            <!-- Y Offset -->
            <div class="flex flex-col gap-1">
              <div class="flex justify-between text-[10px] font-medium select-none">
                <span class="text-body">Move Vertical (Y)</span>
                <span id="offset-y-val" class="font-mono text-mute">0px</span>
              </div>
              <input type="range" id="offset-y-slider" min="-300" max="300" step="2" value="0" class="w-full h-1 bg-canvas-soft-2 rounded-lg appearance-none cursor-pointer accent-primary border border-hairline" />
            </div>

            <!-- Reset Portrait Position -->
            <button id="reset-position-btn" type="button" class="text-[10px] text-mute hover:text-ink font-semibold flex items-center justify-center gap-1 select-none self-end cursor-pointer">
              <RefreshCw class="w-2.5 h-2.5" /> Center Portrait
            </button>
          </div>
        </div>

        <!-- Global Actions -->
        <div class="flex flex-col gap-2">
          <button id="download-btn" class="bg-primary text-on-primary hover:bg-primary/95 text-xs font-semibold h-10 rounded-pill flex items-center justify-center gap-1.5 transition-all shadow-level-3 cursor-pointer active:scale-95">
            <Download class="w-4 h-4" />
            Download Passport Photo
          </button>
          <button id="reset-btn" class="bg-canvas border border-hairline hover:bg-canvas-soft text-ink text-xs font-semibold h-10 rounded-pill flex items-center justify-center gap-1.5 transition-all shadow-level-1 cursor-pointer active:scale-95">
            <RefreshCw class="w-3.5 h-3.5" />
            Load Different Image
          </button>
        </div>

      </div>

      <!-- Main workspace: Preview canvas Studio (2 columns) -->
      <div class="flex flex-col gap-6 lg:col-span-2 order-1 lg:order-2">
        <div class="bg-canvas border border-hairline rounded-md p-6 shadow-level-3 flex flex-col gap-4">
          <div class="flex items-center justify-between select-none">
            <h3 class="font-sans font-semibold text-sm text-ink">Passport Studio Canvas</h3>
            <div class="flex items-center gap-2">
              <span id="dropper-indicator" class="hidden font-mono text-[9px] text-amber-500 font-bold bg-amber-50 border border-amber-200 px-2 py-0.5 rounded-sm animate-pulse">Dropper Active: Click background color</span>
              <span id="brush-indicator" class="hidden font-mono text-[9px] text-violet font-bold bg-violet-soft/20 border border-violet-soft/30 px-2 py-0.5 rounded-sm">Brush Active</span>
              <span id="canvas-dimensions" class="font-mono text-[10px] text-mute uppercase">0 × 0 px</span>
            </div>
          </div>

          <!-- Studio Viewport Area -->
          <div class="border border-hairline bg-canvas-soft-2 rounded-sm h-[480px] overflow-hidden flex items-center justify-center p-4 relative select-none">
            
            <div id="canvas-wrapper" class="relative inline-block max-h-full max-w-full select-none cursor-default">
              
              <!-- Main Preview Canvas -->
              <canvas id="studio-canvas" class="max-h-[440px] max-w-full object-contain border border-hairline bg-white shadow-level-2 pointer-events-auto"></canvas>
              
              <!-- SVG Face Alignment Guides Overlay (pointer-events-none) -->
              <svg id="alignment-guide" class="absolute inset-0 w-full h-full pointer-events-none select-none z-10" viewBox="0 0 100 100" preserveAspectRatio="xMidYMid meet">
                <!-- Outer silhouette dotted border -->
                <!-- Head Oval shape -->
                <ellipse cx="50" cy="40" rx="18" ry="25" fill="none" stroke="rgb(0, 112, 243)" stroke-width="1" stroke-dasharray="2,2" opacity="0.8" />
                <!-- Eyes line guide -->
                <line x1="28" y1="36" x2="72" y2="36" stroke="rgb(0, 112, 243)" stroke-width="0.5" stroke-dasharray="2,2" opacity="0.6" />
                <!-- Chin line guide -->
                <line x1="30" y1="65" x2="70" y2="65" stroke="rgb(0, 112, 243)" stroke-width="0.5" stroke-dasharray="2,2" opacity="0.6" />
                <!-- Center vertical axis crosshair -->
                <line x1="50" y1="5" x2="50" y2="95" stroke="rgb(0, 112, 243)" stroke-width="0.3" stroke-dasharray="3,3" opacity="0.5" />
                <line x1="5" y1="40" x2="95" y2="40" stroke="rgb(0, 112, 243)" stroke-width="0.3" stroke-dasharray="3,3" opacity="0.5" />
              </svg>
            </div>

          </div>
        </div>
      </div>

    </div>

  </div>
</ToolLayout>

<script>
  import { addProcessedFile, getProcessedFile } from '../../utils/db.js';

  // Elements
  const uploadZone = document.getElementById('upload-zone');
  const fileInput = document.getElementById('file-input') as HTMLInputElement;
  const workspace = document.getElementById('workspace');

  const studioCanvas = document.getElementById('studio-canvas') as HTMLCanvasElement;
  const canvasWrapper = document.getElementById('canvas-wrapper');
  const alignmentGuide = document.getElementById('alignment-guide');



  const brushTabs = document.querySelectorAll('.brush-tab');
  const brushSizeSlider = document.getElementById('brush-size-slider') as HTMLInputElement;
  const brushSizeVal = document.getElementById('brush-size-val');
  const clearMaskBtn = document.getElementById('clear-mask-btn');

  const sizeSelect = document.getElementById('passport-size-select') as HTMLSelectElement;
  const guideToggle = document.getElementById('guide-toggle') as HTMLInputElement;

  const zoomSlider = document.getElementById('zoom-slider') as HTMLInputElement;
  const zoomVal = document.getElementById('zoom-val');
  const offsetXSlider = document.getElementById('offset-x-slider') as HTMLInputElement;
  const offsetXVal = document.getElementById('offset-x-val');
  const offsetYSlider = document.getElementById('offset-y-slider') as HTMLInputElement;
  const offsetYVal = document.getElementById('offset-y-val');
  const resetPositionBtn = document.getElementById('reset-position-btn');

  const colorBtns = document.querySelectorAll('.bg-color-btn');
  const gradBtns = document.querySelectorAll('.bg-grad-btn');
  const bgFileInput = document.getElementById('bg-file-input') as HTMLInputElement;
  const bgUploadBtn = document.getElementById('bg-upload-btn');

  const downloadBtn = document.getElementById('download-btn');
  const resetBtn = document.getElementById('reset-btn');
  const canvasDims = document.getElementById('canvas-dimensions');
  const dropperIndicator = document.getElementById('dropper-indicator');
  const brushIndicator = document.getElementById('brush-indicator');

  // Adjustments & Enhance Elements
  const magicEnhanceToggle = document.getElementById('magic-enhance-toggle') as HTMLInputElement;
  const brightnessSlider = document.getElementById('brightness-slider') as HTMLInputElement;
  const brightnessVal = document.getElementById('brightness-val');
  const contrastSlider = document.getElementById('contrast-slider') as HTMLInputElement;
  const contrastVal = document.getElementById('contrast-val');
  const saturationSlider = document.getElementById('saturation-slider') as HTMLInputElement;
  const saturationVal = document.getElementById('saturation-val');
  const blurSlider = document.getElementById('blur-slider') as HTMLInputElement;
  const blurVal = document.getElementById('blur-val');

  // Text Overlay Elements
  const addTextBtn = document.getElementById('add-text-btn');
  const textEditorContainer = document.getElementById('text-editor-container');
  const noTextSelectedMsg = document.getElementById('no-text-selected-msg');
  const textContentInput = document.getElementById('text-content-input') as HTMLInputElement;
  const textFontFamily = document.getElementById('text-font-family') as HTMLSelectElement;
  const textColorPicker = document.getElementById('text-color-picker') as HTMLInputElement;
  const textColorHex = document.getElementById('text-color-hex') as HTMLInputElement;
  const textSizeSlider = document.getElementById('text-size-slider') as HTMLInputElement;
  const textSizeVal = document.getElementById('text-size-val');
  const textBoldBtn = document.getElementById('text-bold-btn');
  const textItalicBtn = document.getElementById('text-italic-btn');
  const deleteTextBtn = document.getElementById('delete-text-btn');

  // Portrait States
  let activeFile: File | null = null;
  let sourceImage = new Image();

  // Foreground states
  let foregroundImage: HTMLImageElement | HTMLCanvasElement = sourceImage;
  let aiImage: HTMLImageElement | HTMLCanvasElement | null = null;
  let removeBackground: any = null;

  // Background state
  let bgColor = '#a4c2f4'; // default light blue
  let bgGradient = ''; // empty means solid color
  let bgImageElement: HTMLImageElement | null = null;

  // Chroma key state (Kept internally for compatibility, color pickers removed)
  let chromaKeyEnabled = false;
  let keyColor: { r: number; g: number; b: number } | null = null;
  let tolerance = 55;

  // Brush states
  let activeBrushMode: 'none' | 'erase' | 'restore' = 'none';
  let brushSize = 30;
  let isDrawing = false;
  let lastPoint: { x: number; y: number } | null = null;

  // Adjustments states
  let brightness = 100;
  let contrast = 100;
  let saturation = 100;
  let blur = 0;
  let magicEnhance = false;

  // Text Overlay state
  interface TextLayer {
    id: string;
    text: string;
    x: number; // relative coordinate 0 to 1
    y: number; // relative coordinate 0 to 1
    color: string;
    fontSize: number;
    fontFamily: string;
    isBold: boolean;
    isItalic: boolean;
  }

  let textLayers: TextLayer[] = [];
  let activeTextLayerId: string | null = null;
  let isDraggingText = false;
  let dragOffset = { x: 0, y: 0 };

  // Offscreen mask canvases (matching original portrait dimension)
  let eraseCanvas = document.createElement('canvas');
  let eraseCtx = eraseCanvas.getContext('2d');
  let restoreCanvas = document.createElement('canvas');
  let restoreCtx = restoreCanvas.getContext('2d');

  // Offscreen pre-processed foreground buffer
  let tempCanvas = document.createElement('canvas');
  let tempCtx = tempCanvas.getContext('2d');
  let restoreBufferCanvas = document.createElement('canvas');
  let restoreBufferCtx = restoreBufferCanvas.getContext('2d');

  // Positioning
  let zoom = 1.0;
  let offsetX = 0;
  let offsetY = 0;

  // Dropper (Kept internally, inactive)
  let dropperActive = false;

  // Sidebar Config Navigation Tabs Switcher
  const sidebarTabs = document.querySelectorAll('.sidebar-config-tab');
  const configSections: Record<string, HTMLElement | null> = {
    cutout: document.getElementById('config-section-cutout'),
    refine: document.getElementById('config-section-refine'),
    backdrop: document.getElementById('config-section-backdrop'),
    adjust: document.getElementById('config-section-adjust'),
    text: document.getElementById('config-section-text'),
    size: document.getElementById('config-section-size')
  };

  sidebarTabs.forEach(tab => {
    tab.addEventListener('click', (e) => {
      e.preventDefault();
      const currentTab = e.currentTarget as HTMLElement;
      const targetSectionName = currentTab.dataset.tab || 'cutout';

      sidebarTabs.forEach(t => {
        t.classList.remove('bg-canvas', 'shadow-level-1', 'text-ink');
        t.classList.add('text-body', 'hover:text-ink');
      });
      currentTab.classList.add('bg-canvas', 'shadow-level-1', 'text-ink');
      currentTab.classList.remove('text-body', 'hover:text-ink');

      Object.entries(configSections).forEach(([name, element]) => {
        if (element) {
          if (name === targetSectionName) {
            element.classList.remove('hidden');
          } else {
            element.classList.add('hidden');
          }
        }
      });
    });
  });

  // Upload Actions
  uploadZone?.addEventListener('click', () => fileInput.click());
  bgUploadBtn?.addEventListener('click', () => bgFileInput.click());

  uploadZone?.addEventListener('dragover', (e) => {
    e.preventDefault();
    uploadZone.classList.add('border-primary', 'bg-canvas-soft');
  });
  uploadZone?.addEventListener('dragleave', () => {
    uploadZone.classList.remove('border-primary', 'bg-canvas-soft');
  });
  uploadZone?.addEventListener('drop', (e) => {
    e.preventDefault();
    uploadZone.classList.remove('border-primary', 'bg-canvas-soft');
    if (e.dataTransfer?.files && e.dataTransfer.files.length > 0) {
      handleFileSelection(e.dataTransfer.files[0]);
    }
  });

  fileInput?.addEventListener('change', () => {
    if (fileInput.files && fileInput.files.length > 0) {
      handleFileSelection(fileInput.files[0]);
    }
  });



  bgFileInput?.addEventListener('change', () => {
    if (bgFileInput.files && bgFileInput.files.length > 0) {
      const reader = new FileReader();
      reader.onload = (e) => {
        const img = new Image();
        img.onload = () => {
          bgImageElement = img;
          bgGradient = ''; // deactivate gradient
          bgColor = ''; // deactivate solid color
          
          // Clear active background borders
          clearBgButtonsBorders();
          bgUploadBtn?.classList.add('border-primary', 'text-link');
          
          processForeground();
          renderCanvas();
        };
        img.src = e.target?.result as string;
      };
      reader.readAsDataURL(bgFileInput.files[0]);
    }
  });

  function handleFileSelection(file: File) {
    if (!file.type.startsWith('image/')) {
      alert('Please upload a valid image.');
      return;
    }
    activeFile = file;
    uploadZone?.classList.add('hidden');
    workspace?.classList.remove('hidden');

    const reader = new FileReader();
    reader.onload = (e) => {
      sourceImage.onload = () => {
        // Configure offscreen canvases to match original portrait dims
        const w = sourceImage.width;
        const h = sourceImage.height;

        const customWidthInput = document.getElementById('custom-width') as HTMLInputElement;
        const customHeightInput = document.getElementById('custom-height') as HTMLInputElement;
        if (customWidthInput) customWidthInput.value = w.toString();
        if (customHeightInput) customHeightInput.value = h.toString();

        eraseCanvas.width = w;
        eraseCanvas.height = h;
        eraseCtx?.clearRect(0, 0, w, h);

        restoreCanvas.width = w;
        restoreCanvas.height = h;
        restoreCtx?.clearRect(0, 0, w, h);

        tempCanvas.width = w;
        tempCanvas.height = h;
        tempCtx?.clearRect(0, 0, w, h);

        restoreBufferCanvas.width = w;
        restoreBufferCanvas.height = h;
        restoreBufferCtx?.clearRect(0, 0, w, h);

        resetRemovalState();

        processForeground();
        updateCanvasDimensions();
        resetPositionState();
      };
      sourceImage.src = e.target?.result as string;
    };
    reader.readAsDataURL(file);
  }

  function resetPositionState() {
    offsetX = 0;
    offsetY = 0;

    // Calculate dynamic fit zoom based on active canvas size
    const wCanvas = studioCanvas.width || 600;
    const hCanvas = studioCanvas.height || 600;
    const wImg = sourceImage.width || 600;
    const hImg = sourceImage.height || 600;
    
    const fitZoom = Math.min(wCanvas / wImg, hCanvas / hImg);
    zoom = fitZoom;

    if (zoomSlider) {
      zoomSlider.min = (fitZoom * 0.1).toFixed(4);
      zoomSlider.max = (fitZoom * 8.0).toFixed(4);
      zoomSlider.step = (fitZoom * 0.01).toFixed(4);
      zoomSlider.value = fitZoom.toFixed(4);
    }
    if (zoomVal) zoomVal.innerText = `${fitZoom.toFixed(2)}x`;
    
    if (offsetXSlider) {
      offsetXSlider.value = '0';
      offsetXSlider.min = `-${Math.round(wImg / 2)}`;
      offsetXSlider.max = `${Math.round(wImg / 2)}`;
    }
    if (offsetYSlider) {
      offsetYSlider.value = '0';
      offsetYSlider.min = `-${Math.round(hImg / 2)}`;
      offsetYSlider.max = `${Math.round(hImg / 2)}`;
    }
    
    if (offsetXVal) offsetXVal.innerText = '0px';
    if (offsetYVal) offsetYVal.innerText = '0px';
  }

  function resetRemovalState() {
    foregroundImage = sourceImage;
    aiImage = null;

    activeBrushMode = 'none';

    // Reset adjustments
    brightness = 100;
    contrast = 100;
    saturation = 100;
    blur = 0;
    magicEnhance = false;

    if (brightnessSlider) {
      brightnessSlider.value = '100';
      brightnessSlider.disabled = false;
      brightnessSlider.classList.remove('opacity-50', 'cursor-not-allowed');
    }
    if (contrastSlider) {
      contrastSlider.value = '100';
      contrastSlider.disabled = false;
      contrastSlider.classList.remove('opacity-50', 'cursor-not-allowed');
    }
    if (saturationSlider) {
      saturationSlider.value = '100';
      saturationSlider.disabled = false;
      saturationSlider.classList.remove('opacity-50', 'cursor-not-allowed');
    }
    if (blurSlider) blurSlider.value = '0';
    if (magicEnhanceToggle) magicEnhanceToggle.checked = false;

    if (brightnessVal) brightnessVal.innerText = '100%';
    if (contrastVal) contrastVal.innerText = '100%';
    if (saturationVal) saturationVal.innerText = '100%';
    if (blurVal) blurVal.innerText = '0px';

    // Reset text layers
    textLayers = [];
    activeTextLayerId = null;
    isDraggingText = false;
    updateTextEditorUI();

    // Reset brush button styles
    brushTabs.forEach(tab => {
      tab.classList.remove('bg-primary', 'text-on-primary', 'border-hairline-strong');
      tab.classList.add('text-body', 'hover:text-ink', 'border-hairline');
    });
    document.querySelector('[data-brush="none"]')?.classList.add('bg-primary', 'text-on-primary', 'border-hairline-strong');
    document.querySelector('[data-brush="none"]')?.classList.remove('text-body', 'hover:text-ink', 'border-hairline');

    eraseCtx?.clearRect(0, 0, eraseCanvas.width, eraseCanvas.height);
    restoreCtx?.clearRect(0, 0, restoreCanvas.width, restoreCanvas.height);

    brushIndicator?.classList.add('hidden');
  }

  // Pre-process foreground on original portrait resolution
  function processForeground() {
    if (!sourceImage.src || !tempCanvas || !tempCtx) return;

    const w = tempCanvas.width;
    const h = tempCanvas.height;

    tempCtx.clearRect(0, 0, w, h);
    tempCtx.drawImage(foregroundImage, 0, 0);

    // 1. Restore Brush mask (source-in masking)
    if (restoreBufferCtx && restoreCtx) {
      restoreBufferCtx.clearRect(0, 0, w, h);
      restoreBufferCtx.save();
      restoreBufferCtx.drawImage(restoreCanvas, 0, 0); // draw restore strokes mask
      restoreBufferCtx.globalCompositeOperation = 'source-in';
      restoreBufferCtx.drawImage(sourceImage, 0, 0); // draw original image
      restoreBufferCtx.restore();

      // Overlay restored pixels back onto the foreground
      tempCtx.save();
      tempCtx.globalCompositeOperation = 'source-over';
      tempCtx.drawImage(restoreBufferCanvas, 0, 0);
      tempCtx.restore();
    }

    // 2. Erase Brush mask (destination-out masking)
    if (eraseCtx) {
      tempCtx.save();
      tempCtx.globalCompositeOperation = 'destination-out';
      tempCtx.drawImage(eraseCanvas, 0, 0);
      tempCtx.restore();
    }
  }

  function updateCanvasDimensions() {
    const sizeMode = sizeSelect.value;
    let w = 600, h = 600;

    const customSizeInputs = document.getElementById('custom-size-inputs');
    const customWidthInput = document.getElementById('custom-width') as HTMLInputElement;
    const customHeightInput = document.getElementById('custom-height') as HTMLInputElement;

    if (sizeMode === 'custom_dimensions') {
      customSizeInputs?.classList.remove('hidden');
      w = parseInt(customWidthInput?.value) || sourceImage.width || 600;
      h = parseInt(customHeightInput?.value) || sourceImage.height || 600;
    } else {
      customSizeInputs?.classList.add('hidden');
      if (sizeMode === 'us') {
        w = 600; h = 600; // 1:1 ratio
      } else if (sizeMode === 'india') {
        w = 413; h = 531; // ~7:9 ratio (3.5x4.5cm)
      } else if (sizeMode === 'china') {
        w = 390; h = 567; // ~11:16 ratio (3.3x4.8cm)
      } else if (sizeMode === 'custom') {
        w = sourceImage.width || 600;
        h = sourceImage.height || 600;
      }
    }

    studioCanvas.width = w;
    studioCanvas.height = h;

    if (canvasDims) canvasDims.innerText = `${w} × ${h} px`;

    renderCanvas();
  }

  // Draw final canvas preview
  function renderCanvas() {
    const ctx = studioCanvas.getContext('2d');
    if (!ctx) return;

    const w = studioCanvas.width;
    const h = studioCanvas.height;

    ctx.clearRect(0, 0, w, h);

    // 1. Draw Background
    if (bgImageElement) {
      // Draw background image scaled to cover
      const scale = Math.max(w / bgImageElement.width, h / bgImageElement.height);
      const bx = (w - bgImageElement.width * scale) / 2;
      const by = (h - bgImageElement.height * scale) / 2;
      ctx.drawImage(bgImageElement, bx, by, bgImageElement.width * scale, bgImageElement.height * scale);
    } else if (bgGradient) {
      // Render gradient
      let grad;
      if (bgGradient === 'blue-pink') {
        grad = ctx.createLinearGradient(0, 0, w, h);
        grad.addColorStop(0, '#d3e5ff');
        grad.addColorStop(1, '#ffd3e5');
      } else if (bgGradient === 'sunset') {
        grad = ctx.createLinearGradient(0, 0, w, h);
        grad.addColorStop(0, '#ffe5cf');
        grad.addColorStop(1, '#ffcfd3');
      } else if (bgGradient === 'mesh') {
        grad = ctx.createLinearGradient(0, 0, w, h);
        grad.addColorStop(0, '#50e3c2');
        grad.addColorStop(1, '#7928ca');
      } else if (bgGradient === 'monochrome') {
        grad = ctx.createLinearGradient(0, 0, w, h);
        grad.addColorStop(0, '#ebebeb');
        grad.addColorStop(1, '#a1a1a1');
      }
      if (grad) {
        ctx.fillStyle = grad;
        ctx.fillRect(0, 0, w, h);
      }
    } else if (bgColor) {
      // Solid Color background
      ctx.fillStyle = bgColor === 'transparent' ? '#ffffff' : bgColor;
      
      // If transparent selected, draw checkers pattern
      if (bgColor === 'transparent') {
        ctx.clearRect(0, 0, w, h);
        ctx.save();
        const checkSize = 10;
        for (let y = 0; y < h; y += checkSize * 2) {
          for (let x = 0; x < w; x += checkSize * 2) {
            ctx.fillStyle = '#f0f0f0';
            ctx.fillRect(x, y, checkSize, checkSize);
            ctx.fillRect(x + checkSize, y + checkSize, checkSize, checkSize);
            ctx.fillStyle = '#ffffff';
            ctx.fillRect(x + checkSize, y, checkSize, checkSize);
            ctx.fillRect(x, y + checkSize, checkSize, checkSize);
          }
        }
        ctx.restore();
      } else {
        ctx.fillRect(0, 0, w, h);
      }
    }

    // 2. Draw pre-processed Foreground portrait with transformations
    const cx = w / 2;
    const cy = h / 2;

    ctx.save();
    ctx.translate(cx + offsetX, cy + offsetY);
    ctx.scale(zoom, zoom);

    // Centered drawing offsets
    const dx = -sourceImage.width / 2;
    const dy = -sourceImage.height / 2;

    // Apply adjustments filters
    let adjB = brightness;
    let adjC = contrast;
    let adjS = saturation;
    let adjBl = blur;

    if (magicEnhance) {
      adjB = Math.round(adjB * 1.04);
      adjC = Math.round(adjC * 1.12);
      adjS = Math.round(adjS * 1.15);
    }

    ctx.filter = `brightness(${adjB}%) contrast(${adjC}%) saturate(${adjS}%) blur(${adjBl}px)`;
    ctx.drawImage(tempCanvas, dx, dy, sourceImage.width, sourceImage.height);
    ctx.filter = 'none';
    ctx.restore();

    // 3. Draw Text Layers
    textLayers.forEach(layer => {
      ctx.save();
      
      let fontStyle = '';
      if (layer.isItalic) fontStyle += 'italic ';
      if (layer.isBold) fontStyle += 'bold ';
      
      ctx.font = `${fontStyle}${layer.fontSize}px ${layer.fontFamily}`;
      ctx.fillStyle = layer.color;
      ctx.textBaseline = 'middle';
      ctx.textAlign = 'center';
      
      // Draw shadow for text legibility
      ctx.shadowColor = 'rgba(0, 0, 0, 0.4)';
      ctx.shadowBlur = 4;
      ctx.shadowOffsetX = 2;
      ctx.shadowOffsetY = 2;
      
      const tx = layer.x * w;
      const ty = layer.y * h;
      
      ctx.fillText(layer.text, tx, ty);
      
      // Draw bounding box if active text layer
      if (layer.id === activeTextLayerId) {
        ctx.shadowColor = 'transparent';
        ctx.shadowBlur = 0;
        ctx.shadowOffsetX = 0;
        ctx.shadowOffsetY = 0;
        
        ctx.strokeStyle = '#0070f3';
        ctx.lineWidth = 1.5;
        ctx.setLineDash([4, 4]);
        
        const textWidth = ctx.measureText(layer.text).width;
        const textHeight = layer.fontSize;
        
        ctx.strokeRect(
          tx - textWidth / 2 - 8,
          ty - textHeight / 2 - 6,
          textWidth + 16,
          textHeight + 12
        );
      }
      
      ctx.restore();
    });
  }

  // Inverse coordinates calculation: converts canvas point to portrait image coords
  function getOriginalCoords(canvasX: number, canvasY: number) {
    // Map screen cursor on canvas element to internal canvas pixel coordinates
    const rect = studioCanvas.getBoundingClientRect();
    const pixelX = ((canvasX - rect.left) / rect.width) * studioCanvas.width;
    const pixelY = ((canvasY - rect.top) / rect.height) * studioCanvas.height;

    const cx = studioCanvas.width / 2;
    const cy = studioCanvas.height / 2;

    const tx = (pixelX - (cx + offsetX)) / zoom;
    const ty = (pixelY - (cy + offsetY)) / zoom;

    const ix = tx + sourceImage.width / 2;
    const iy = ty + sourceImage.height / 2;

    return { x: ix, y: iy };
  }

  // AI Background Remover
  const aiRemoveBgBtn = document.getElementById('ai-remove-bg-btn');
  const aiRemoveLoading = document.getElementById('ai-remove-loading');
  const aiRemoveLoadingText = document.getElementById('ai-remove-loading-text');

  aiRemoveBgBtn?.addEventListener('click', async () => {
    if (!activeFile) return;

    aiRemoveBgBtn.classList.add('hidden');
    aiRemoveLoading?.classList.remove('hidden');
    aiRemoveLoading?.classList.add('flex');
    if (aiRemoveLoadingText) aiRemoveLoadingText.innerText = "Initializing AI model...";

    try {
      if (!removeBackground) {
        const module = await import('https://cdn.jsdelivr.net/npm/@imgly/background-removal@1.7.0/+esm');
        removeBackground = module.removeBackground;
      }

      if (aiRemoveLoadingText) aiRemoveLoadingText.innerText = "Running AI background removal...";

      const config = {
        model: 'small', // Use 7.5MB model instead of 44MB medium model for lightning speed
        progress: (key: string, current: number, total: number) => {
          const percent = Math.round((current / total) * 100);
          const filename = key.split('/').pop() || key;
          const cleanKey = filename.replace(/_/g, ' ').replace('.onnx', '').replace('.wasm', '');
          if (aiRemoveLoadingText) {
            aiRemoveLoadingText.innerText = `Loading AI model (${cleanKey})... ${percent}%`;
          }
        }
      };

      const resultBlob = await removeBackground(activeFile, config);
      
      if (aiRemoveLoadingText) aiRemoveLoadingText.innerText = "Processing foreground mask...";
      
      const resultUrl = URL.createObjectURL(resultBlob);
      
      const img = new Image();
      img.onload = () => {
        aiImage = img;
        foregroundImage = aiImage;
        
        processForeground();
        renderCanvas();

        aiRemoveLoading?.classList.add('hidden');
        aiRemoveBgBtn?.classList.remove('hidden');
      };
      img.onerror = (err) => {
        console.error("Failed to load background-removed image:", err);
        alert("Failed to load processed image. Please try again.");
        aiRemoveLoading?.classList.add('hidden');
        aiRemoveBgBtn?.classList.remove('hidden');
      };
      img.src = resultUrl;

    } catch (err) {
      console.error("AI Background removal failed:", err);
      alert("AI background removal failed. You can still use the Manual Brush to touch up.");
      aiRemoveLoading?.classList.add('hidden');
      aiRemoveBgBtn.classList.remove('hidden');
    }
  });

  // 1. Adjustments Controls Event Listeners
  magicEnhanceToggle?.addEventListener('change', () => {
    magicEnhance = magicEnhanceToggle.checked;
    
    // Toggle sliders disabled visual state
    [brightnessSlider, contrastSlider, saturationSlider].forEach(slider => {
      if (slider) {
        slider.disabled = magicEnhance;
        if (magicEnhance) {
          slider.classList.add('opacity-50', 'cursor-not-allowed');
        } else {
          slider.classList.remove('opacity-50', 'cursor-not-allowed');
        }
      }
    });

    renderCanvas();
  });

  brightnessSlider?.addEventListener('input', () => {
    brightness = parseInt(brightnessSlider.value);
    if (brightnessVal) brightnessVal.innerText = `${brightness}%`;
    renderCanvas();
  });

  contrastSlider?.addEventListener('input', () => {
    contrast = parseInt(contrastSlider.value);
    if (contrastVal) contrastVal.innerText = `${contrast}%`;
    renderCanvas();
  });

  saturationSlider?.addEventListener('input', () => {
    saturation = parseInt(saturationSlider.value);
    if (saturationVal) saturationVal.innerText = `${saturation}%`;
    renderCanvas();
  });

  blurSlider?.addEventListener('input', () => {
    blur = parseInt(blurSlider.value);
    if (blurVal) blurVal.innerText = `${blur}px`;
    renderCanvas();
  });

  // 2. Text Layer Editor Event Listeners & Drag Handling Helpers
  function findTextLayerAt(clientX: number, clientY: number) {
    const rect = studioCanvas.getBoundingClientRect();
    const pixelX = ((clientX - rect.left) / rect.width) * studioCanvas.width;
    const pixelY = ((clientY - rect.top) / rect.height) * studioCanvas.height;

    const ctx = studioCanvas.getContext('2d');
    if (!ctx) return null;

    for (let i = textLayers.length - 1; i >= 0; i--) {
      const layer = textLayers[i];
      ctx.save();
      
      let fontStyle = '';
      if (layer.isItalic) fontStyle += 'italic ';
      if (layer.isBold) fontStyle += 'bold ';
      ctx.font = `${fontStyle}${layer.fontSize}px ${layer.fontFamily}`;
      
      const textWidth = ctx.measureText(layer.text).width;
      const textHeight = layer.fontSize;
      
      const tx = layer.x * studioCanvas.width;
      const ty = layer.y * studioCanvas.height;
      
      const minX = tx - textWidth / 2 - 12;
      const maxX = tx + textWidth / 2 + 12;
      const minY = ty - textHeight / 2 - 10;
      const maxY = ty + textHeight / 2 + 10;
      
      ctx.restore();

      if (pixelX >= minX && pixelX <= maxX && pixelY >= minY && pixelY <= maxY) {
        return layer;
      }
    }
    return null;
  }

  function updateTextEditorUI() {
    const activeLayer = textLayers.find(l => l.id === activeTextLayerId);
    if (activeLayer) {
      textEditorContainer?.classList.remove('hidden');
      noTextSelectedMsg?.classList.add('hidden');

      if (textContentInput) textContentInput.value = activeLayer.text;
      if (textFontFamily) textFontFamily.value = activeLayer.fontFamily;
      if (textColorPicker) textColorPicker.value = activeLayer.color;
      if (textColorHex) textColorHex.value = activeLayer.color;
      if (textSizeSlider) textSizeSlider.value = activeLayer.fontSize.toString();
      if (textSizeVal) textSizeVal.innerText = `${activeLayer.fontSize}px`;

      // Bold & Italic button styles
      if (activeLayer.isBold) {
        textBoldBtn?.classList.add('bg-primary', 'text-on-primary', 'border-hairline-strong');
        textBoldBtn?.classList.remove('text-ink', 'hover:bg-canvas-soft');
      } else {
        textBoldBtn?.classList.remove('bg-primary', 'text-on-primary', 'border-hairline-strong');
        textBoldBtn?.classList.add('text-ink', 'hover:bg-canvas-soft');
      }

      if (activeLayer.isItalic) {
        textItalicBtn?.classList.add('bg-primary', 'text-on-primary', 'border-hairline-strong');
        textItalicBtn?.classList.remove('text-ink', 'hover:bg-canvas-soft');
      } else {
        textItalicBtn?.classList.remove('bg-primary', 'text-on-primary', 'border-hairline-strong');
        textItalicBtn?.classList.add('text-ink', 'hover:bg-canvas-soft');
      }
    } else {
      textEditorContainer?.classList.add('hidden');
      noTextSelectedMsg?.classList.remove('hidden');
    }
  }

  addTextBtn?.addEventListener('click', () => {
    const newId = 'text_' + Date.now();
    const newLayer: TextLayer = {
      id: newId,
      text: 'Double click to edit text',
      x: 0.5,
      y: 0.5,
      color: '#ffffff',
      fontSize: 24,
      fontFamily: "'Outfit', sans-serif",
      isBold: false,
      isItalic: false
    };

    textLayers.push(newLayer);
    activeTextLayerId = newId;

    updateTextEditorUI();
    renderCanvas();

    if (textContentInput) {
      textContentInput.value = newLayer.text;
      textContentInput.focus();
      textContentInput.select();
    }
  });

  textContentInput?.addEventListener('input', () => {
    if (activeTextLayerId) {
      const activeLayer = textLayers.find(l => l.id === activeTextLayerId);
      if (activeLayer) {
        activeLayer.text = textContentInput.value;
        renderCanvas();
      }
    }
  });

  textFontFamily?.addEventListener('change', () => {
    if (activeTextLayerId) {
      const activeLayer = textLayers.find(l => l.id === activeTextLayerId);
      if (activeLayer) {
        activeLayer.fontFamily = textFontFamily.value;
        renderCanvas();
      }
    }
  });

  textColorPicker?.addEventListener('input', () => {
    if (activeTextLayerId) {
      const activeLayer = textLayers.find(l => l.id === activeTextLayerId);
      if (activeLayer) {
        activeLayer.color = textColorPicker.value;
        if (textColorHex) textColorHex.value = activeLayer.color;
        renderCanvas();
      }
    }
  });

  textColorHex?.addEventListener('input', () => {
    if (activeTextLayerId) {
      const activeLayer = textLayers.find(l => l.id === activeTextLayerId);
      if (activeLayer) {
        const hex = textColorHex.value;
        if (/^#[0-9A-F]{6}$/i.test(hex)) {
          activeLayer.color = hex;
          if (textColorPicker) textColorPicker.value = hex;
          renderCanvas();
        }
      }
    }
  });

  textSizeSlider?.addEventListener('input', () => {
    if (activeTextLayerId) {
      const activeLayer = textLayers.find(l => l.id === activeTextLayerId);
      if (activeLayer) {
        const size = parseInt(textSizeSlider.value);
        activeLayer.fontSize = size;
        if (textSizeVal) textSizeVal.innerText = `${size}px`;
        renderCanvas();
      }
    }
  });

  textBoldBtn?.addEventListener('click', () => {
    if (activeTextLayerId) {
      const activeLayer = textLayers.find(l => l.id === activeTextLayerId);
      if (activeLayer) {
        activeLayer.isBold = !activeLayer.isBold;
        updateTextEditorUI();
        renderCanvas();
      }
    }
  });

  textItalicBtn?.addEventListener('click', () => {
    if (activeTextLayerId) {
      const activeLayer = textLayers.find(l => l.id === activeTextLayerId);
      if (activeLayer) {
        activeLayer.isItalic = !activeLayer.isItalic;
        updateTextEditorUI();
        renderCanvas();
      }
    }
  });

  deleteTextBtn?.addEventListener('click', () => {
    if (activeTextLayerId) {
      textLayers = textLayers.filter(l => l.id !== activeTextLayerId);
      activeTextLayerId = null;
      updateTextEditorUI();
      renderCanvas();
    }
  });

  // Brush Modes toggling
  brushTabs.forEach(tab => {
    tab.addEventListener('click', () => {
      brushTabs.forEach(t => {
        t.classList.remove('bg-primary', 'text-on-primary', 'border-hairline-strong');
        t.classList.add('text-body', 'hover:text-ink', 'border-hairline');
      });
      tab.classList.add('bg-primary', 'text-on-primary', 'border-hairline-strong');
      tab.classList.remove('text-body', 'hover:text-ink', 'border-hairline');

      activeBrushMode = (tab as HTMLElement).dataset.brush as any || 'none';
      
      if (activeBrushMode !== 'none') {
        brushIndicator?.classList.remove('hidden');
        // Deselect text layer if brush is active to prevent overlapping drag actions
        activeTextLayerId = null;
        updateTextEditorUI();
        renderCanvas();
      } else {
        brushIndicator?.classList.add('hidden');
      }
    });
  });

  brushSizeSlider?.addEventListener('input', () => {
    brushSize = parseInt(brushSizeSlider.value);
    if (brushSizeVal) brushSizeVal.innerText = `${brushSize}px`;
  });

  clearMaskBtn?.addEventListener('click', () => {
    eraseCtx?.clearRect(0, 0, eraseCanvas.width, eraseCanvas.height);
    restoreCtx?.clearRect(0, 0, restoreCanvas.width, restoreCanvas.height);
    processForeground();
    renderCanvas();
  });

  // Canvas Mouse & Touch Drawing & Text Dragging Handlers
  const drawStart = (clientX: number, clientY: number) => {
    if (activeBrushMode === 'none') {
      const textAtPoint = findTextLayerAt(clientX, clientY);
      if (textAtPoint) {
        activeTextLayerId = textAtPoint.id;
        isDraggingText = true;

        const rect = studioCanvas.getBoundingClientRect();
        const pixelX = ((clientX - rect.left) / rect.width) * studioCanvas.width;
        const pixelY = ((clientY - rect.top) / rect.height) * studioCanvas.height;

        const tx = textAtPoint.x * studioCanvas.width;
        const ty = textAtPoint.y * studioCanvas.height;

        dragOffset = {
          x: pixelX - tx,
          y: pixelY - ty
        };

        updateTextEditorUI();
        renderCanvas();
      } else {
        activeTextLayerId = null;
        updateTextEditorUI();
        renderCanvas();
      }
      return;
    }

    isDrawing = true;
    const coords = getOriginalCoords(clientX, clientY);
    lastPoint = coords;

    drawStroke(coords.x, coords.y, true);
  };

  const drawMove = (clientX: number, clientY: number) => {
    if (isDraggingText && activeTextLayerId) {
      const rect = studioCanvas.getBoundingClientRect();
      const pixelX = ((clientX - rect.left) / rect.width) * studioCanvas.width;
      const pixelY = ((clientY - rect.top) / rect.height) * studioCanvas.height;

      const activeLayer = textLayers.find(l => l.id === activeTextLayerId);
      if (activeLayer) {
        const newTx = pixelX - dragOffset.x;
        const newTy = pixelY - dragOffset.y;

        activeLayer.x = Math.max(0, Math.min(1, newTx / studioCanvas.width));
        activeLayer.y = Math.max(0, Math.min(1, newTy / studioCanvas.height));

        renderCanvas();
      }
      return;
    }

    if (!isDrawing || !lastPoint) return;
    const coords = getOriginalCoords(clientX, clientY);

    drawStroke(coords.x, coords.y, false);
    lastPoint = coords;
  };

  const drawEnd = () => {
    isDrawing = false;
    isDraggingText = false;
    lastPoint = null;
  };

  function drawStroke(x: number, y: number, isStart = false) {
    let ctxToUse = activeBrushMode === 'erase' ? eraseCtx : restoreCtx;
    if (!ctxToUse || !lastPoint) return;

    // Calculate scale ratio between source image size and studio canvas screen display size
    const scaleRatio = sourceImage.width / studioCanvas.width;
    const currentBrushWidth = brushSize * scaleRatio;

    ctxToUse.save();
    ctxToUse.lineWidth = currentBrushWidth;
    ctxToUse.lineCap = 'round';
    ctxToUse.lineJoin = 'round';
    ctxToUse.strokeStyle = '#000000';

    if (isStart) {
      ctxToUse.beginPath();
      ctxToUse.arc(x, y, currentBrushWidth / 2, 0, Math.PI * 2);
      ctxToUse.fillStyle = '#000000';
      ctxToUse.fill();
    } else {
      ctxToUse.beginPath();
      ctxToUse.moveTo(lastPoint.x, lastPoint.y);
      ctxToUse.lineTo(x, y);
      ctxToUse.stroke();
    }

    ctxToUse.restore();

    // Dynamically clear overlapping strokes on alternative mask canvas
    const alternateCtx = activeBrushMode === 'erase' ? restoreCtx : eraseCtx;
    
    if (alternateCtx && lastPoint) {
      alternateCtx.save();
      alternateCtx.lineWidth = currentBrushWidth;
      alternateCtx.lineCap = 'round';
      alternateCtx.lineJoin = 'round';
      alternateCtx.globalCompositeOperation = 'destination-out';
      alternateCtx.strokeStyle = '#000000';

      if (isStart) {
        alternateCtx.beginPath();
        alternateCtx.arc(x, y, currentBrushWidth / 2, 0, Math.PI * 2);
        alternateCtx.fillStyle = '#000000';
        alternateCtx.fill();
      } else {
        alternateCtx.beginPath();
        alternateCtx.moveTo(lastPoint.x, lastPoint.y);
        alternateCtx.lineTo(x, y);
        alternateCtx.stroke();
      }
      alternateCtx.restore();
    }

    processForeground();
    renderCanvas();
  }

  // Mouse Listener Bindings
  studioCanvas?.addEventListener('mousedown', (e) => drawStart(e.clientX, e.clientY));
  document.addEventListener('mousemove', (e) => {
    if (isDrawing || isDraggingText) drawMove(e.clientX, e.clientY);
  });
  document.addEventListener('mouseup', drawEnd);

  // Touch Listener Bindings
  studioCanvas?.addEventListener('touchstart', (e) => {
    if (e.touches.length > 0) {
      drawStart(e.touches[0].clientX, e.touches[0].clientY);
    }
  }, { passive: true });
  document.addEventListener('touchmove', (e) => {
    if ((isDrawing || isDraggingText) && e.touches.length > 0) {
      drawMove(e.touches[0].clientX, e.touches[0].clientY);
    }
  }, { passive: true });
  document.addEventListener('touchend', drawEnd);

  // Background Settings Listeners
  function clearBgButtonsBorders() {
    colorBtns.forEach(b => b.classList.remove('border-primary', 'ring-2', 'ring-primary/20'));
    gradBtns.forEach(b => b.classList.remove('border-primary', 'ring-2', 'ring-primary/20'));
    bgUploadBtn?.classList.remove('border-primary', 'text-link');
  }

  colorBtns.forEach(btn => {
    btn.addEventListener('click', (e) => {
      const color = (e.currentTarget as HTMLElement).dataset.color || '#a4c2f4';
      bgColor = color;
      bgGradient = '';
      bgImageElement = null;

      clearBgButtonsBorders();
      (e.currentTarget as HTMLElement).classList.add('border-primary', 'ring-2', 'ring-primary/20');

      renderCanvas();
    });
  });

  gradBtns.forEach(btn => {
    btn.addEventListener('click', (e) => {
      const grad = (e.currentTarget as HTMLElement).dataset.grad || '';
      bgGradient = grad;
      bgColor = '';
      bgImageElement = null;

      clearBgButtonsBorders();
      (e.currentTarget as HTMLElement).classList.add('border-primary', 'ring-2', 'ring-primary/20');

      renderCanvas();
    });
  });

  // Size Presets Selector
  sizeSelect?.addEventListener('change', () => {
    updateCanvasDimensions();
    resetPositionState();
    renderCanvas();
  });

  const customWidthInput = document.getElementById('custom-width') as HTMLInputElement;
  const customHeightInput = document.getElementById('custom-height') as HTMLInputElement;

  customWidthInput?.addEventListener('input', () => {
    updateCanvasDimensions();
    resetPositionState();
  });
  customHeightInput?.addEventListener('input', () => {
    updateCanvasDimensions();
    resetPositionState();
  });

  // Alignment Guide Toggle
  guideToggle?.addEventListener('change', () => {
    if (guideToggle.checked) {
      alignmentGuide?.classList.remove('hidden');
    } else {
      alignmentGuide?.classList.add('hidden');
    }
  });

  // Positioning slider events
  zoomSlider?.addEventListener('input', () => {
    zoom = parseFloat(zoomSlider.value);
    if (zoomVal) zoomVal.innerText = `${zoom.toFixed(2)}x`;
    renderCanvas();
  });

  offsetXSlider?.addEventListener('input', () => {
    offsetX = parseInt(offsetXSlider.value);
    if (offsetXVal) offsetXVal.innerText = `${offsetX}px`;
    renderCanvas();
  });

  offsetYSlider?.addEventListener('input', () => {
    offsetY = parseInt(offsetYSlider.value);
    if (offsetYVal) offsetYVal.innerText = `${offsetY}px`;
    renderCanvas();
  });

  resetPositionBtn?.addEventListener('click', () => {
    resetPositionState();
    renderCanvas();
  });

  // Action Reset workspace
  resetBtn?.addEventListener('click', () => {
    activeFile = null;
    fileInput.value = '';
    bgFileInput.value = '';
    
    workspace?.classList.add('hidden');
    uploadZone?.classList.remove('hidden');

    sourceImage.removeAttribute('src');
    bgImageElement = null;
    bgColor = '#a4c2f4';
    bgGradient = '';

    clearBgButtonsBorders();
    document.querySelector('[data-color="#a4c2f4"]')?.classList.add('border-primary', 'ring-2', 'ring-primary/20');

    resetPositionState();
    resetRemovalState();
  });

  // Download compiled Passport image
  downloadBtn?.addEventListener('click', async () => {
    if (!activeFile || !sourceImage.src) return;

    // To ensure full resolution without checkerboards / guidelines,
    // we compile the canvas offscreen exactly to the preset sizes!
    const outCanvas = document.createElement('canvas');
    outCanvas.width = studioCanvas.width;
    outCanvas.height = studioCanvas.height;

    const outCtx = outCanvas.getContext('2d');
    if (!outCtx) return;

    const w = outCanvas.width;
    const h = outCanvas.height;

    // 1. Background drawing
    if (bgImageElement) {
      const scale = Math.max(w / bgImageElement.width, h / bgImageElement.height);
      const bx = (w - bgImageElement.width * scale) / 2;
      const by = (h - bgImageElement.height * scale) / 2;
      outCtx.drawImage(bgImageElement, bx, by, bgImageElement.width * scale, bgImageElement.height * scale);
    } else if (bgGradient) {
      let grad;
      if (bgGradient === 'blue-pink') {
        grad = outCtx.createLinearGradient(0, 0, w, h);
        grad.addColorStop(0, '#d3e5ff');
        grad.addColorStop(1, '#ffd3e5');
      } else if (bgGradient === 'sunset') {
        grad = outCtx.createLinearGradient(0, 0, w, h);
        grad.addColorStop(0, '#ffe5cf');
        grad.addColorStop(1, '#ffcfd3');
      } else if (bgGradient === 'mesh') {
        grad = outCtx.createLinearGradient(0, 0, w, h);
        grad.addColorStop(0, '#50e3c2');
        grad.addColorStop(1, '#7928ca');
      } else if (bgGradient === 'monochrome') {
        grad = outCtx.createLinearGradient(0, 0, w, h);
        grad.addColorStop(0, '#ebebeb');
        grad.addColorStop(1, '#a1a1a1');
      }
      if (grad) {
        outCtx.fillStyle = grad;
        outCtx.fillRect(0, 0, w, h);
      }
    } else if (bgColor) {
      if (bgColor === 'transparent') {
        // Keep transparent
        outCtx.clearRect(0, 0, w, h);
      } else {
        outCtx.fillStyle = bgColor;
        outCtx.fillRect(0, 0, w, h);
      }
    }

    // 2. Foreground drawing
    const cx = w / 2;
    const cy = h / 2;

    outCtx.save();
    outCtx.translate(cx + offsetX, cy + offsetY);
    outCtx.scale(zoom, zoom);

    const dx = -sourceImage.width / 2;
    const dy = -sourceImage.height / 2;

    // Apply adjustments filters
    let adjB = brightness;
    let adjC = contrast;
    let adjS = saturation;
    let adjBl = blur;

    if (magicEnhance) {
      adjB = Math.round(adjB * 1.04);
      adjC = Math.round(adjC * 1.12);
      adjS = Math.round(adjS * 1.15);
    }

    outCtx.filter = `brightness(${adjB}%) contrast(${adjC}%) saturate(${adjS}%) blur(${adjBl}px)`;
    outCtx.drawImage(tempCanvas, dx, dy, sourceImage.width, sourceImage.height);
    outCtx.filter = 'none';
    outCtx.restore();

    // 3. Draw Text Layers (without the active bounding box selection guide)
    textLayers.forEach(layer => {
      outCtx.save();
      
      let fontStyle = '';
      if (layer.isItalic) fontStyle += 'italic ';
      if (layer.isBold) fontStyle += 'bold ';
      
      outCtx.font = `${fontStyle}${layer.fontSize}px ${layer.fontFamily}`;
      outCtx.fillStyle = layer.color;
      outCtx.textBaseline = 'middle';
      outCtx.textAlign = 'center';
      
      // Draw shadow for text legibility
      outCtx.shadowColor = 'rgba(0, 0, 0, 0.4)';
      outCtx.shadowBlur = 4;
      outCtx.shadowOffsetX = 2;
      outCtx.shadowOffsetY = 2;
      
      const tx = layer.x * w;
      const ty = layer.y * h;
      
      outCtx.fillText(layer.text, tx, ty);
      outCtx.restore();
    });

    // Export & download
    const mimeType = 'image/png';
    const ext = 'png';
    
    const cleanName = activeFile.name.substring(0, activeFile.name.lastIndexOf('.')) || activeFile.name;
    const downloadName = `${cleanName}-passport.${ext}`;

    const dataUrl = outCanvas.toDataURL(mimeType);

    const link = document.createElement('a');
    link.href = dataUrl;
    link.download = downloadName;
    document.body.appendChild(link);
    link.click();
    document.body.removeChild(link);

    // Save to IndexedDB
    try {
      const response = await fetch(dataUrl);
      const blob = await response.blob();
      await addProcessedFile(downloadName, mimeType, blob.size, 'bg-remover', blob);
    } catch (err) {
      console.error('Failed to save passport photo to history:', err);
    }
  });

  // Load from editId query parameters on initialization
  window.addEventListener('load', async () => {
    // Set default color border highlight
    document.querySelector('[data-color="#a4c2f4"]')?.classList.add('border-primary', 'ring-2', 'ring-primary/20');

    const urlParams = new URLSearchParams(window.location.search);
    const editId = urlParams.get('editId');
    if (editId) {
      const record = await getProcessedFile(parseInt(editId));
      if (record) {
        const file = new File([record.blob], record.name, { type: record.type });
        handleFileSelection(file);
      }
    }
  });
</script>
