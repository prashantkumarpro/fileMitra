---
import ToolLayout from '../../layouts/ToolLayout.astro';
import { Upload, Download, Sparkles, RefreshCw, Layers } from 'lucide-astro';
---

<ToolLayout
  title="Compress Image"
  description="Reduce file sizes of PNG, JPG, and WebP images. Set custom compression levels and preview original vs. compressed images side-by-side client-side."
  activeTool="image-compress"
>
  <div class="flex-grow flex flex-col gap-6">
    
    <!-- Drag & Drop Upload Zone (ex-empty-state-card style) -->
    <div
      id="upload-zone"
      class="border-2 border-dashed border-hairline hover:border-hairline-strong bg-canvas rounded-lg p-16 flex flex-col items-center justify-center text-center cursor-pointer transition-all duration-200 shadow-level-2 select-none group"
    >
      <input type="file" id="file-input" accept="image/png, image/jpeg, image/webp" class="hidden" />
      <span class="p-4 bg-canvas-soft rounded-full text-mute group-hover:text-primary border border-hairline mb-4 transition-colors">
        <Upload class="w-6 h-6 animate-pulse" />
      </span>
      <h3 class="text-ink font-semibold text-lg mb-1">Drag and drop your image</h3>
      <p class="text-mute text-xs max-w-xs mb-4">
        Supports PNG, JPEG, and WebP formats. Files never leave your device.
      </p>
      <button class="bg-primary text-on-primary hover:bg-primary/95 text-xs font-semibold px-4 py-2 rounded-pill shadow-level-2 transition-all">
        Select File
      </button>
    </div>

    <!-- Active Workspace Area (Hidden by default) -->
    <div id="workspace" class="hidden grid grid-cols-1 lg:grid-cols-3 gap-6 items-start">
      
      <!-- Left side: Controls Panel (1 column) -->
      <div class="flex flex-col gap-6 lg:col-span-1">
        <div class="bg-canvas border border-hairline rounded-md p-6 shadow-level-3 flex flex-col gap-6">
          <h3 class="font-sans font-semibold text-sm text-ink pb-3 border-b border-hairline select-none flex items-center gap-1.5">
            <Layers class="w-4 h-4 text-mute" />
            Compression Profile
          </h3>

          <!-- Quality Range Slider -->
          <div class="flex flex-col gap-2">
            <div class="flex justify-between items-center text-xs font-medium">
              <span class="text-ink select-none">Quality Level</span>
              <span id="quality-display" class="font-mono text-primary bg-canvas-soft-2 border border-hairline px-2 py-0.5 rounded-sm">75%</span>
            </div>
            <input
              type="range"
              id="quality-slider"
              min="10"
              max="100"
              value="75"
              class="w-full h-1 bg-canvas-soft-2 rounded-lg appearance-none cursor-pointer accent-primary border border-hairline"
            />
            <div class="flex justify-between text-[10px] text-mute select-none font-mono">
              <span>Max Size</span>
              <span>Balanced</span>
              <span>Min Size</span>
            </div>
          </div>

          <!-- Format conversion option -->
          <div class="flex flex-col gap-2">
            <label for="format-select" class="font-medium text-xs text-ink select-none">Output Format</label>
            <select
              id="format-select"
              class="w-full bg-canvas text-ink border border-hairline focus:border-hairline-strong text-xs rounded-sm px-2.5 h-9 outline-none transition-all shadow-level-1 cursor-pointer"
            >
              <option value="original">Keep Original Format</option>
              <option value="image/jpeg">JPEG (Smaller file size)</option>
              <option value="image/png">PNG (Lossless compression)</option>
              <option value="image/webp">WebP (Next-gen performance)</option>
            </select>
          </div>

          <!-- Target File Size (Optional) -->
          <div class="flex flex-col gap-2 pt-2 border-t border-hairline">
            <div class="flex justify-between items-center">
              <label for="target-size-input" class="font-medium text-xs text-ink select-none">Target File Size (KB)</label>
              <span class="text-[10px] text-mute font-mono">(Optional)</span>
            </div>
            <input
              type="number"
              id="target-size-input"
              placeholder="e.g. 100"
              min="5"
              class="bg-canvas text-ink border border-hairline focus:border-hairline-strong text-xs rounded-sm px-2.5 h-9 outline-none transition-all shadow-level-1"
            />
            <p class="text-[9px] text-mute leading-normal">
              If specified, we will adjust the quality to match or stay just below your target size.
            </p>
          </div>

          <!-- Live Stats Card -->
          <div class="bg-canvas-soft border border-hairline rounded-sm p-4 flex flex-col gap-3">
            <span class="font-mono text-[10px] text-mute uppercase font-semibold select-none">Compression Yield</span>
            
            <div class="flex items-center justify-between text-xs">
              <span class="text-body select-none">Original Size:</span>
              <span id="original-size" class="font-mono text-ink">0 KB</span>
            </div>
            <div class="flex items-center justify-between text-xs">
              <span class="text-body select-none">Compressed Size:</span>
              <span id="compressed-size" class="font-mono text-ink font-semibold">Calculating...</span>
            </div>
            
            <div class="border-t border-hairline my-1"></div>
            
            <div class="flex items-center justify-between text-xs">
              <span class="text-body select-none">File size reduction:</span>
              <span id="savings" class="font-mono text-emerald-500 font-bold bg-emerald-50 border border-emerald-200 px-2 py-0.5 rounded-sm">0%</span>
            </div>
          </div>

          <!-- CTA Buttons -->
          <div class="flex flex-col gap-2">
            <button id="download-btn" class="bg-primary text-on-primary hover:bg-primary/95 text-xs font-semibold h-10 rounded-pill flex items-center justify-center gap-1.5 transition-all shadow-level-3">
              <Download class="w-4 h-4" />
              Download Compressed Image
            </button>
            <button id="reset-btn" class="bg-canvas border border-hairline hover:bg-canvas-soft text-ink text-xs font-semibold h-10 rounded-pill flex items-center justify-center gap-1.5 transition-all shadow-level-1">
              <RefreshCw class="w-3.5 h-3.5" />
              Clear & Load Another
            </button>
          </div>
        </div>
      </div>

      <!-- Right side: Previews (2 columns) -->
      <div class="flex flex-col gap-6 lg:col-span-2">
        <div class="bg-canvas border border-hairline rounded-md p-6 shadow-level-3 flex flex-col gap-4">
          <div class="flex items-center justify-between select-none">
            <h3 class="font-sans font-semibold text-sm text-ink">Side-by-Side Comparison</h3>
            <span class="font-mono text-[10px] text-mute uppercase">Offline canvas preview</span>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <!-- Original Preview Frame -->
            <div class="flex flex-col gap-2">
              <span class="font-mono text-[10px] text-mute uppercase font-semibold select-none">Original</span>
              <div class="border border-hairline bg-canvas-soft-2 rounded-sm h-64 overflow-hidden flex items-center justify-center p-2">
                <img id="img-original" class="max-h-full max-w-full object-contain" alt="Original Image" />
              </div>
              <div class="flex justify-between text-xs text-mute font-mono">
                <span id="original-dimensions">0 × 0 px</span>
                <span id="original-format">PNG</span>
              </div>
            </div>

            <!-- Compressed Preview Frame -->
            <div class="flex flex-col gap-2">
              <span class="font-mono text-[10px] text-mute uppercase font-semibold select-none flex items-center gap-1">
                Compressed
                <span id="rendering-spinner" class="hidden animate-spin"><RefreshCw class="w-3 h-3 text-mute" /></span>
              </span>
              <div class="border border-hairline bg-canvas-soft-2 rounded-sm h-64 overflow-hidden flex items-center justify-center p-2 relative">
                <img id="img-compressed" class="max-h-full max-w-full object-contain" alt="Compressed Preview" />
              </div>
              <div class="flex justify-between text-xs text-mute font-mono">
                <span id="compressed-dimensions">0 × 0 px</span>
                <span id="compressed-format">JPEG</span>
              </div>
            </div>
          </div>
        </div>
      </div>

    </div>

  </div>
</ToolLayout>

<script>
  import { addProcessedFile, getProcessedFile } from '../../utils/db.js';

  const uploadZone = document.getElementById('upload-zone');
  const fileInput = document.getElementById('file-input') as HTMLInputElement;
  const workspace = document.getElementById('workspace');
  const qualitySlider = document.getElementById('quality-slider') as HTMLInputElement;
  const qualityDisplay = document.getElementById('quality-display');
  const formatSelect = document.getElementById('format-select') as HTMLSelectElement;
  const targetSizeInput = document.getElementById('target-size-input') as HTMLInputElement;
  
  const imgOriginal = document.getElementById('img-original') as HTMLImageElement;
  const imgCompressed = document.getElementById('img-compressed') as HTMLImageElement;
  
  const originalSizeText = document.getElementById('original-size');
  const compressedSizeText = document.getElementById('compressed-size');
  const savingsText = document.getElementById('savings');
  
  const originalDimensionsText = document.getElementById('original-dimensions');
  const compressedDimensionsText = document.getElementById('compressed-dimensions');
  
  const originalFormatText = document.getElementById('original-format');
  const compressedFormatText = document.getElementById('compressed-format');
  
  const downloadBtn = document.getElementById('download-btn');
  const resetBtn = document.getElementById('reset-btn');
  const spinner = document.getElementById('rendering-spinner');

  let activeFile: File | null = null;
  let sourceImage = new Image();
  let compressedDataUrl = '';

  // Trigger file dialog on zone click
  uploadZone?.addEventListener('click', () => {
    fileInput.click();
  });

  // Handle Drag Over
  uploadZone?.addEventListener('dragover', (e) => {
    e.preventDefault();
    uploadZone.classList.add('border-primary', 'bg-canvas-soft');
  });

  // Handle Drag Leave
  uploadZone?.addEventListener('dragleave', () => {
    uploadZone.classList.remove('border-primary', 'bg-canvas-soft');
  });

  // Handle Drop
  uploadZone?.addEventListener('drop', (e) => {
    e.preventDefault();
    uploadZone.classList.remove('border-primary', 'bg-canvas-soft');
    if (e.dataTransfer?.files && e.dataTransfer.files.length > 0) {
      handleFileSelection(e.dataTransfer.files[0]);
    }
  });

  // Handle File Input Change
  fileInput?.addEventListener('change', (e) => {
    if (fileInput.files && fileInput.files.length > 0) {
      handleFileSelection(fileInput.files[0]);
    }
  });

  function handleFileSelection(file: File) {
    if (!file.type.startsWith('image/')) {
      alert('Please upload an image file.');
      return;
    }
    activeFile = file;

    // Transition panels
    uploadZone?.classList.add('hidden');
    workspace?.classList.remove('hidden');

    // Read original size
    if (originalSizeText) {
      originalSizeText.innerText = formatBytes(file.size);
    }
    if (originalFormatText) {
      originalFormatText.innerText = file.type.split('/')[1].toUpperCase();
    }

    // Read file as data URL to draw
    const reader = new FileReader();
    reader.onload = function (e) {
      const dataUrl = e.target?.result as string;
      imgOriginal.src = dataUrl;
      
      sourceImage.onload = function () {
        if (originalDimensionsText) {
          originalDimensionsText.innerText = `${sourceImage.width} × ${sourceImage.height} px`;
        }
        if (compressedDimensionsText) {
          compressedDimensionsText.innerText = `${sourceImage.width} × ${sourceImage.height} px`;
        }
        compressImage();
      };
      sourceImage.src = dataUrl;
    };
    reader.readAsDataURL(file);
  }

  function compressImage() {
    if (!activeFile || !sourceImage.src) return;
    spinner?.classList.remove('hidden');

    let mimeType = formatSelect.value;
    if (mimeType === 'original') {
      mimeType = activeFile.type;
    }

    // Create drawing canvas
    const canvas = document.createElement('canvas');
    canvas.width = sourceImage.width;
    canvas.height = sourceImage.height;
    
    const ctx = canvas.getContext('2d');
    if (!ctx) {
      spinner?.classList.add('hidden');
      return;
    }
    ctx.drawImage(sourceImage, 0, 0);

    const qualityMimeTypes = ['image/jpeg', 'image/webp'];
    const supportsQuality = qualityMimeTypes.includes(mimeType) || (mimeType === 'original' && qualityMimeTypes.includes(activeFile.type));
    
    const targetKb = parseFloat(targetSizeInput.value) || 0;

    if (supportsQuality && targetKb > 0) {
      // Run binary search to get closest quality yielding size <= targetKb
      const targetBytes = targetKb * 1024;
      let minQ = 0.01;
      let maxQ = 1.0;
      let bestQ = 0.75;
      let bestDataUrl = '';
      let bestBytes = 0;

      for (let i = 0; i < 7; i++) {
        const midQ = (minQ + maxQ) / 2;
        const dataUrl = canvas.toDataURL(mimeType, midQ);
        const bytes = estimateBase64Bytes(dataUrl);

        if (bytes <= targetBytes) {
          bestQ = midQ;
          bestDataUrl = dataUrl;
          bestBytes = bytes;
          minQ = midQ; // try higher quality
        } else {
          maxQ = midQ; // too big, decrease quality
          if (!bestDataUrl) {
            bestDataUrl = dataUrl;
            bestBytes = bytes;
          }
        }
      }

      compressedDataUrl = bestDataUrl;
      const calculatedPct = Math.round(bestQ * 100);
      qualitySlider.value = calculatedPct.toString();
      if (qualityDisplay) {
        qualityDisplay.innerText = `${calculatedPct}% (Auto)`;
      }
    } else {
      const quality = parseInt(qualitySlider.value) / 100;
      compressedDataUrl = canvas.toDataURL(mimeType, supportsQuality ? quality : undefined);
      const calculatedPct = Math.round(quality * 100);
      if (qualityDisplay) {
        qualityDisplay.innerText = `${calculatedPct}%`;
      }
    }
    
    // Set compressed preview
    imgCompressed.src = compressedDataUrl;

    if (compressedFormatText) {
      compressedFormatText.innerText = mimeType.split('/')[1].toUpperCase();
    }

    // Calculate yield
    const compressedBytes = estimateBase64Bytes(compressedDataUrl);
    if (compressedSizeText) {
      compressedSizeText.innerText = formatBytes(compressedBytes);
    }

    const savings = activeFile.size > compressedBytes
      ? Math.round(((activeFile.size - compressedBytes) / activeFile.size) * 100)
      : 0;

    if (savingsText) {
      savingsText.innerText = `-${savings}%`;
      if (savings > 0) {
        savingsText.className = 'font-mono text-emerald-500 font-bold bg-emerald-50 border border-emerald-200 px-2 py-0.5 rounded-sm';
      } else {
        savingsText.className = 'font-mono text-mute bg-canvas-soft-2 border border-hairline px-2 py-0.5 rounded-sm';
        savingsText.innerText = '+0%';
      }
    }

    spinner?.classList.add('hidden');
  }

  // Quality Slider Input Event
  qualitySlider?.addEventListener('input', (e) => {
    const val = (e.target as HTMLInputElement).value;
    if (qualityDisplay) {
      qualityDisplay.innerText = `${val}%`;
    }
  });

  // Change event trigger compression
  qualitySlider?.addEventListener('change', compressImage);
  formatSelect?.addEventListener('change', compressImage);
  targetSizeInput?.addEventListener('input', compressImage);
  targetSizeInput?.addEventListener('change', compressImage);

  // Clear workspace reset state
  resetBtn?.addEventListener('click', () => {
    activeFile = null;
    compressedDataUrl = '';
    fileInput.value = '';
    targetSizeInput.value = '';
    
    workspace?.classList.add('hidden');
    uploadZone?.classList.remove('hidden');
    
    imgOriginal.removeAttribute('src');
    imgCompressed.removeAttribute('src');
  });

  // Perform Download output
  downloadBtn?.addEventListener('click', async () => {
    if (!compressedDataUrl || !activeFile) return;

    let mimeType = formatSelect.value;
    if (mimeType === 'original') mimeType = activeFile.type;
    const ext = mimeType.split('/')[1];

    const cleanName = activeFile.name.substring(0, activeFile.name.lastIndexOf('.')) || activeFile.name;
    const downloadName = `${cleanName}-compressed.${ext}`;

    const link = document.createElement('a');
    link.href = compressedDataUrl;
    link.download = downloadName;
    document.body.appendChild(link);
    link.click();
    document.body.removeChild(link);

    // Save to IndexedDB
    try {
      const response = await fetch(compressedDataUrl);
      const blob = await response.blob();
      await addProcessedFile(downloadName, mimeType, blob.size, 'image-compress', blob);
    } catch (err) {
      console.error('Failed to save compressed image to history:', err);
    }
  });

  // Check for editId on load
  window.addEventListener('load', async () => {
    const urlParams = new URLSearchParams(window.location.search);
    const editId = urlParams.get('editId');
    if (editId) {
      const record = await getProcessedFile(parseInt(editId));
      if (record) {
        const file = new File([record.blob], record.name, { type: record.type });
        handleFileSelection(file);
      }
    }
  });

  // Utilities helper
  function formatBytes(bytes: number, decimals = 2) {
    if (bytes === 0) return '0 Bytes';
    const k = 1024;
    const dm = decimals < 0 ? 0 : decimals;
    const sizes = ['Bytes', 'KB', 'MB', 'GB'];
    const i = Math.floor(Math.log(bytes) / Math.log(k));
    return parseFloat((bytes / Math.pow(k, i)).toFixed(dm)) + ' ' + sizes[i];
  }

  function estimateBase64Bytes(base64String: string) {
    if (!base64String) return 0;
    const base64Data = base64String.substring(base64String.indexOf(',') + 1);
    return Math.round((base64Data.length * 3) / 4);
  }
</script>
